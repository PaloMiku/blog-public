[{"data":1,"prerenderedAt":666},["ShallowReactive",2],{"global-music-player":3,"post-/previews/misae-sagara":66,"surround-/previews/misae-sagara":665},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":642,"date":643,"description":644,"draft":645,"extension":646,"hide-info":647,"image":648,"meta":649,"navigation":645,"path":651,"permalink":65,"published":65,"readingTime":652,"recommend":65,"references":65,"seo":657,"sitemap":658,"stem":659,"subtitle":65,"tags":660,"type":663,"updated":65,"__hash__":664},"content/previews/misae-sagara.md","Clannad 游戏人物路线攻略：相乐美佐枝",{"type":70,"value":71,"toc":623},"minimark",[72,76,80,83,111,116,119,123,130,133,136,139,148,152,155,171,515,518,522,525,528,531,534,538,569,572,575,578,581,584,588,598,601],[73,74,75],"h2",{"id":75},"人物简介",[77,78,79],"p",{},"担任光坂高中男生宿舍的管理员。曾是学校第一个女性学生会长，创造\"全校学生无迟到周\"的事迹，其领导力深刻影响了坂上智代，后者继承其理念成为新任学生会会长。",[77,81,82],{},"相楽 美佐枝（さがら みさえ），血型 B 型，生日 4 月 3 日（白羊座），身高 166 cm，体重 51kg，游戏内配音是雪野五月(ゆきの さつき)。",[84,85,86,93,96,99,102,105,108],"folding",{},[87,88,90],"template",{"v-slot:title":89},"",[77,91,92],{},"相关剧情（含剧透）",[77,94,95],{},"美佐枝在学生时期爱慕著一名叫五十岚的男生，可是被他误会了身边的陌生男生志麻贺津纪是她的男朋友。贺津纪表示曾在医院中受到美佐枝的鼓励而鼓起勇气，希望能为她实现一个愿望。",[77,97,98],{},"五十岚拜托贺津纪转告美佐枝他已经有女朋友，可是贺津纪无法直接说出口。结果美佐枝亲眼看到五十岚与他的女朋友在一起，然后跑着离开了贺津纪。其后美佐枝渐渐喜欢上贺津纪，并邀请他一起到秋祭。",[77,100,101],{},"事实上真正的贺津纪早已过世，而现在的贺津纪只是他身边的饲养的一只猫，为了贺津纪想要报答美佐枝的遗愿而化身成为人类。",[77,103,104],{},"最后美佐枝向贺津纪许的愿望是“请一直喜欢着我”，之后贺津纪在和美佐枝逛庙会时消失，重新变回猫的样子一直陪在美佐枝的身边，后来朋也和春原经常在宿舍中看到的那只猫就是他。",[77,106,107],{},"回到现在，贺津纪让朋也发了一场梦，拜托朋也在秋祭时将他的心愿告诉美佐枝。",[77,109,110],{},"在坂上智代路线，美佐枝抱着小猫在秋祭中渡过了一个晚上。",[112,113],"pic",{"caption":114,"src":115},"相乐美佐枝 宿舍","https://images.steamusercontent.com/ugc/404558073175177648/EBAEC3439803753F5498F9DE6C783AFDB72E1C1B/",[73,117,118],{"id":118},"游戏攻略",[120,121,122],"h3",{"id":122},"路线提示",[77,124,125,126],{},"美佐枝的“光”在自己的路线中无法得到，而是在完成路线后由智代路线取得。 ",[127,128,129],"blur",{},"在坂上智代线里，化形的猫陪美佐枝逛了庙会，实现了心愿（这就是美佐枝的光）",[77,131,132],{},"一般把美佐枝放在第一个攻略，其原因一则是其路线较短，二则是其结局在一定程度上抽象地对幻想世界进行了诠释，三也为朋也埋下了伏笔。",[77,134,135],{},"在 4.20 日遇到芳野佑介时，不能选“跟他去→再看一会儿→帮忙”，会导致脱离美佐枝路线。",[77,137,138],{},"如果 4.21 日前进入了坂上智代或宫泽有纪宁的路线，在 4.21 日选择“还是去美佐枝的房间”可以回到美佐枝路线。",[77,140,141,142,147],{},"在美佐枝路线上存在的隐藏要素是：",[143,144,146],"a",{"href":145},"#%E9%9A%90%E8%97%8F%E8%A6%81%E7%B4%A0","向美佐枝咨询的人","，会导致路线内部分演出呈现不同。",[112,149],{"caption":150,"src":151},"相乐美佐枝 京都动画版杂志图片","https://i227.photobucket.com/albums/dd130/irisfairy/kyoto/misae_01.jpg",[120,153,154],{"id":154},"选项表格",[156,157,158,161],"alert",{},[77,159,160],{},"标记有（✲）号的，表示该选项是关键选项。没有标记的，表示可以任意选，对结局没有影响。",[77,162,163,164,170],{},"感谢",[143,165,169],{"href":166,"rel":167},"https://steamcommunity.com/sharedfiles/filedetails/?id=928184392",[168],"nofollow","Clannad 全成就指南","整理了此表格。",[172,173,174,193],"table",{},[175,176,177],"thead",{},[178,179,180,184,187,190],"tr",{},[181,182,183],"th",{},"日期",[181,185,186],{},"英文版",[181,188,189],{},"中文版",[181,191,192],{},"备注",[194,195,196,210,222,235,247,259,271,283,295,307,319,332,361,374,384,397,409,419,432,446,458,471,487,501],"tbody",{},[178,197,198,202,205,208],{},[199,200,201],"td",{},"4.14",[199,203,204],{},"Record your own voice over it",[199,206,207],{},"录点东西进去覆盖掉",[199,209],{},[178,211,212,214,217,220],{},[199,213],{},[199,215,216],{},"Just say whatever comes to mind",[199,218,219],{},"随便想点词出来",[199,221],{},[178,223,224,227,230,233],{},[199,225,226],{},"4.15",[199,228,229],{},"Ignore her",[199,231,232],{},"不当回事",[199,234],{},[178,236,237,239,242,245],{},[199,238],{},[199,240,241],{},"Sit through class",[199,243,244],{},"上课",[199,246],{},[178,248,249,251,254,257],{},[199,250],{},[199,252,253],{},"Go down to the courtyard",[199,255,256],{},"前往中庭",[199,258],{},[178,260,261,263,266,269],{},[199,262],{},[199,264,265],{},"Keep talking",[199,267,268],{},"继续听下去",[199,270],{},[178,272,273,275,278,281],{},[199,274],{},[199,276,277],{},"Watch how things turn out",[199,279,280],{},"看热闹",[199,282],{},[178,284,285,287,290,293],{},[199,286],{},[199,288,289],{},"I'm not interested in this",[199,291,292],{},"毫无兴趣",[199,294],{},[178,296,297,299,302,305],{},[199,298],{},[199,300,301],{},"I feel concerned",[199,303,304],{},"很在意",[199,306],{},[178,308,309,311,314,317],{},[199,310],{},[199,312,313],{},"Talk to her（✲）",[199,315,316],{},"上前搭话（✲）",[199,318],{},[178,320,321,324,327,330],{},[199,322,323],{},"4.16",[199,325,326],{},"Don't skip",[199,328,329],{},"还是算了",[199,331],{},[178,333,334,336,339,342],{},[199,335],{},[199,337,338],{},"No reason to make that much of an effort",[199,340,341],{},"没必要那么上心",[199,343,344,345,348,349,351,352,354,355,357,358,360],{},"如果4.15日选择 \"Apologize（道歉）\"，",[346,347],"br",{},"或者4.15日下午没有选 \"I feel concerned（很在意）\"，",[346,350],{},"则不会出现此选项。",[346,353],{},"另外，如果这里选择 \"Run to buy a sanwich（跑去买）\"，",[346,356],{},"下一个选择别选 \"Help（帮忙）\"，",[346,359],{},"会离开美佐枝路线，进入渚线。",[178,362,363,366,369,372],{},[199,364,365],{},"4.17",[199,367,368],{},"Waste time outside school",[199,370,371],{},"去校外玩",[199,373],{},[178,375,376,378,380,382],{},[199,377],{},[199,379,313],{},[199,381,316],{},[199,383],{},[178,385,386,389,392,395],{},[199,387,388],{},"4.18",[199,390,391],{},"Have her read my fortune",[199,393,394],{},"自己来占卜",[199,396],{},[178,398,399,401,404,407],{},[199,400],{},[199,402,403],{},"Return to the classroom after all",[199,405,406],{},"还是回教室吧",[199,408],{},[178,410,411,413,415,417],{},[199,412],{},[199,414,313],{},[199,416,316],{},[199,418],{},[178,420,421,424,427,430],{},[199,422,423],{},"4.19",[199,425,426],{},"Go straight home",[199,428,429],{},"直接回家",[199,431],{},[178,433,434,437,440,443],{},[199,435,436],{},"4.20",[199,438,439],{},"Ignore him",[199,441,442],{},"无视",[199,444,445],{},"选择另一个选项会离开美佐枝路线",[178,447,448,450,453,456],{},[199,449],{},[199,451,452],{},"Ask whether I can come again（✲）",[199,454,455],{},"询问是否能再来这里（✲）",[199,457],{},[178,459,460,463,466,469],{},[199,461,462],{},"4.21",[199,464,465],{},"Wake up like a good student",[199,467,468],{},"老老实实起来去上课",[199,470],{},[178,472,473,475,478,481],{},[199,474],{},[199,476,477],{},"How you scold（✲）",[199,479,480],{},"喜欢你会训斥别人（✲）",[199,482,483,484,486],{},"三个选择，错一个就是Bad Ending，",[346,485],{},"三个选择的次序不能对换",[178,488,489,491,494,497],{},[199,490],{},[199,492,493],{},"How you worry（✲）",[199,495,496],{},"喜欢你会关心别人（✲）",[199,498,483,499,486],{},[346,500],{},[178,502,503,505,508,511],{},[199,504],{},[199,506,507],{},"How your futon smells nice（✲）",[199,509,510],{},"喜欢你被子的香味（✲）",[199,512,483,513,486],{},[346,514],{},[120,516,517],{"id":517},"隐藏要素",[519,520,521],"h4",{"id":521},"事件描述",[77,523,524],{},"谁会来找美佐枝咨询恋爱问题呢？",[519,526,527],{"id":527},"选择条件",[77,529,530],{},"一共有两个可能：古河渚 和 藤林椋，在 4.15 日的选择就决定了是谁会去找美佐枝咨询。",[519,532,533],{"id":533},"古河渚",[112,535],{"caption":536,"src":537},"古河渚 咨询问题","https://images.steamusercontent.com/ugc/933805219275332869/D45E1FCA9DF926F3AB50FA9F1877D0AEA2533EBF/",[172,539,540,549],{},[175,541,542],{},[178,543,544,546],{},[181,545,183],{},[181,547,548],{},"选项",[194,550,551,557,563],{},[178,552,553,555],{},[199,554,226],{},[199,556,256],{},[178,558,559,561],{},[199,560],{},[199,562,268],{},[178,564,565,567],{},[199,566],{},[199,568,304],{},[519,570,571],{"id":571},"藤林椋",[77,573,574],{},"4.15 日若没有按照古河渚的顺序选择，则就是藤林椋去了。",[120,576,577],{"id":577},"包含成就",[77,579,580],{},"名称：Right beside her... forever（一直就在身边）\n条件：完成美佐枝路线",[120,582,583],{"id":583},"路线结局",[112,585],{"caption":586,"src":587},"相乐美佐枝 高中时","https://images.steamusercontent.com/ugc/1689401291935794528/86D253C9A599ABD7D86EE019250A92D7F0A020E1/",[589,590,591,595],"ul",{},[592,593,594],"li",{},"Good Ending：朋也对美佐枝更加敬佩，并得知其高中时往事。",[592,596,597],{},"Bad Ending：朋也回到正常生活，并未得知美佐枝的往事，直接返回标题画面。",[73,599,600],{"id":600},"相关资料",[589,602,603,609,616],{},[592,604,605],{},[143,606,608],{"href":166,"rel":607},[168],"Clannad Steam 全成就指南",[592,610,611],{},[143,612,615],{"href":613,"rel":614},"https://clannad.fandom.com/zh/wiki/%E7%9B%B8%E6%A8%82%E7%BE%8E%E4%BD%90%E6%9E%9D",[168],"Fandom Wiki 相乐美佐枝",[592,617,618],{},[143,619,622],{"href":620,"rel":621},"http://clannad.ffsky.cn",[168],"Clannad 天幻网攻略资料",{"title":89,"searchDepth":624,"depth":624,"links":625},4,[626,628,641],{"id":75,"depth":627,"text":75},2,{"id":118,"depth":627,"text":118,"children":629},[630,632,633,639,640],{"id":122,"depth":631,"text":122},3,{"id":154,"depth":631,"text":154},{"id":517,"depth":631,"text":517,"children":634},[635,636,637,638],{"id":521,"depth":624,"text":521},{"id":527,"depth":624,"text":527},{"id":533,"depth":624,"text":533},{"id":571,"depth":624,"text":571},{"id":577,"depth":631,"text":577},{"id":583,"depth":631,"text":583},{"id":600,"depth":627,"text":600},[118],"2025-10-28 07:00:00","相乐美佐枝，光坂宿舍管理员，昔日传奇学生会长。其线短而先攻，埋幻想伏线。关键在 4.21 三连夸，错即 Bad End。完成智代线得“光”。",true,"md",false,"https://images.steamusercontent.com/ugc/1496838371449188646/859EBEBD0935795BC6067C0C05AA028A0A078229/",{"slots":650},{},"/previews/misae-sagara",{"text":653,"minutes":654,"time":655,"words":656},"7 min read",6.94,416400,1388,{"title":68,"description":644},{"loc":651},"previews/misae-sagara",[661,662],"Clannad","游戏人物","tech","iFIAQIX6aV6nrP6yrhd_TuY1AbQSW90NBs2W-Gb42rg",[65,65],1773069189982]