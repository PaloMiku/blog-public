://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":264,"date":65,"description":187,"draft":266,"extension":267,"hide-info":268,"image":65,"meta":269,"navigation":268,"path":271,"permalink":65,"published":65,"readingTime":272,"recommend":65,"references":65,"seo":277,"sitemap":278,"stem":279,"subtitle":65,"tags":280,"type":281,"updated":65,"__hash__":282},"content/about.md","关于",{"type":70,"value":71,"toc":255},"minimark",[72,77,81,84,87,90,93,96,99,102,107,111,115,119,125,128,131,134,137,141,144,148,151,160,163,167,170,174,177,180,199,202],[73,74,76],"h2",{"id":75},"我","我？",[78,79,80],"p",{},"这是Mikuの鬆，也是一只鬆，也可能是蓝鱼儿，这些都是我曾经的网名，你可以选择任何一种方式称呼我，你开心就好。",[78,82,83],{},"16人格：INFP-A 调停者",[78,85,86],{},"现实中，我认为我自己因为优柔寡断错过了许多选择，目前是山东某专科大数据技术专业两年生。",[78,88,89],{},"身体比较一般（例如 185 的个子却只有 60 公斤😓 ，然而我一顿饭吃的却是三个人的量，狂吃不胖 ing），所以对除了跑步与打羽毛球以外的运动不大喜欢。",[78,91,92],{},"有点懒（不是起床气），希望事情尽量能做到一劳永逸（然而总是事和愿违）",[78,94,95],{},"认真投入（限定于感兴趣的事），深度投入到个人喜欢的事情，对于感兴趣的事情愿意不吃不喝为之连续投入😋 。当然，一般不是玩的事情（确信）。",[78,97,98],{},"演讲恐惧症：我不要演讲啊啊啊啊！",[78,100,101],{},"喜欢山楂制品，包括山楂，不管生的熟的或者酸的甜的，全部通吃。",[103,104],"project-group",{":items":105,"title":106},"[{\"title\":\"Zen Browser\",\"description\":\"Workspace Productivity Browser\",\"icon\":\"simple-icons:zenbrowser\",\"link\":\"https://zen-browser.app/\"},{\"title\":\"Chrome\",\"description\":\"Google Browser\",\"icon\":\"devicon:chrome\",\"link\":\"https://www.google.com/chrome/\"}]","浏览器",[103,108],{":items":109,"title":110},"[{\"title\":\"VS Code\",\"description\":\"AI Code Editor\",\"icon\":\"devicon:vscode\",\"link\":\"https://code.visualstudio.com/\"},{\"title\":\"PyCharm\",\"description\":\"Python IDE\",\"icon\":\"devicon:pycharm\",\"link\":\"https://www.jetbrains.com/pycharm/\"},{\"title\":\"DataGrip\",\"description\":\"Database Editor\",\"icon\":\"devicon:datagrip\",\"link\":\"https://www.jetbrains.com/datagrip/\"}]","开发工具",[103,112],{":items":113,"title":114},"[{\"title\":\"Fedora KDE Plasma\",\"description\":\"Honor X16 Ryzen 2024\",\"icon\":\"devicon:fedora\",\"link\":\"https://www.fedoraproject.org/kde/\"},{\"title\":\"Bazzite GNOME\",\"description\":\"Steam Deck LCD 2T\",\"icon\":\"devicon:fedora\",\"link\":\"https://bazzite.gg/\"}]","开发环境",[73,116,118],{"id":117},"恋爱观","恋爱观？",[120,121,122],"blockquote",{},[78,123,124],{},"身心相许，以恋结缘；生生世世，不离不弃。",[78,126,127],{},"在看到了友链晓空所述的恋爱观以后，我也打算写出我对此的想法，也引用了他的部分内容。",[78,129,130],{},"我是一个纯爱党，在生理上就排斥各种奇奇怪怪的恋爱观，在恋爱上偏传统，愿意真心对她好。",[78,132,133],{},"恋爱、结婚、还有传宗接代，这是大自然赋予给一切生灵的使命和责任，同样也是每个人都会经历的义务和旅程。",[78,135,136],{},"有些事情，它们也应该是高尚而纯洁的，也并非那么的不堪，但同样也不该以此取乐。",[73,138,140],{"id":139},"tags","Tags",[78,142,143],{},"大学牲 / 二次元 / 动漫党 / 瞎折腾 / 搞事情 / 日常生产bug",[73,145,147],{"id":146},"找我","找我？",[78,149,150],{},"个人在社交工具上偏QQ，微信多为熟人（现实中认识的人），我的QQ是：2319665062。",[78,152,153,154,159],{},"邮箱上可以发 Outlook 邮箱（",[155,156,158],"a",{"href":157},"mailto:palomiku@outlook.com","palomiku@outlook.com","），着急了也可以往我 QQ 邮箱发。",[78,161,162],{},"你也可以通过联邦宇宙（Fediverse Misskey）方式与我取得联系！：",[103,164],{":items":165,"title":166},"[{\"title\":\"Circlari Fediverse\",\"description\":\"主用联邦实例\",\"icon\":\"https://circlari-sharky.s3.bitiful.net/sitelogo_128x128.png\",\"link\":\"https://circle.tkg3.top/@PaloMiku\"},{\"title\":\"咪社 Misskey\",\"description\":\"无联邦，活跃发癫\",\"icon\":\"simple-icons:misskey\",\"link\":\"https://misskey.site/@NukiMiku\"},{\"title\":\"鸟白岛 Torishiro\",\"description\":\"备用防丢，鸟白岛\",\"icon\":\"https://sa.torishiro.com/misskey/d888c9f4-6edc-4e07-ae70-e38523edc1bc.png\",\"link\":\"https://torishiro.com/@PaloMiku\"}]","联邦宇宙",[78,168,169],{},"想和我一起玩崩坏星穹铁道嘛，通过UID：101045700（官服）添加我为好友吧。",[73,171,173],{"id":172},"投食","投食！",[78,175,176],{},"这个博主目前还是个可怜巴巴的学生党，如果你愿意的话可以投喂他！",[78,178,179],{},"大部分应该都会用到站点维护工作上，也有可能优先解决个人存活问题（比如吃饭），适当投喂鸽子可以减少鸽子咕咕咕的概率，投喂博主也会减少博主咕咕咕的概率（Bushi）",[181,182,184,194],"tab",{":tabs":183},"[\"微信\", \"支付宝\"]",[185,186,188],"template",{"v-slot:tab1":187},"",[78,189,190],{},[191,192],"img",{"alt":187,"src":193},"https://pic.imgdb.cn/item/672059a6d29ded1a8cd554b5.png",[185,195,196],{"v-slot:tab2":187},[78,197,198],{},"等待更新",[78,200,201],{},"如果你选择投食，你可以留下你的话，我都会展示在这里，不管数额有多少。（我可能也会列出我的回复）",[203,204,205,224],"table",{},[206,207,208],"thead",{},[209,210,211,215,218,221],"tr",{},[212,213,214],"th",{},"赞助者",[212,216,217],{},"金额",[212,219,220],{},"时间",[212,222,223],{},"备注",[225,226,227,242],"tbody",{},[209,228,229,233,236,239],{},[230,231,232],"td",{},"Lfem",[230,234,235],{},"￥39",[230,237,238],{},"2025.08.10",[230,240,241],{},"至永恒的当下，森林繁花化作无数的诗篇",[209,243,244,247,249,252],{},[230,245,246],{},"辰灿汐",[230,248,235],{},[230,250,251],{},"2025.08.12",[230,253,254],{},"以自己的一切面对世间",{"title":187,"searchDepth":256,"depth":256,"links":257},4,[258,260,261,262,263],{"id":75,"depth":259,"text":76},2,{"id":117,"depth":259,"text":118},{"id":139,"depth":259,"text":140},{"id":146,"depth":259,"text":147},{"id":172,"depth":259,"text":173},[265],"未分类",false,"md",true,{"slots":270},{},"/about",{"text":273,"minutes":274,"time":275,"words":276},"4 min read",3.805,228300,761,{"title":68,"description":187},{"loc":271},"about",[],"tech","pyF_-29LJlNu-zPiYlTUm_pr4XyLPs_A37ic09oyDX0",[65,65],1774206433763]