[{"data":1,"prerenderedAt":210},["ShallowReactive",2],{"global-music-player":3,"post-/2024/09/1panel-appstore-refused":66,"surround-/2024/09/1panel-appstore-refused":199},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":175,"date":177,"description":178,"draft":179,"extension":180,"hide-info":179,"image":65,"meta":181,"navigation":183,"path":184,"permalink":65,"published":65,"readingTime":185,"recommend":65,"references":65,"seo":190,"sitemap":191,"stem":192,"subtitle":65,"tags":193,"type":196,"updated":197,"__hash__":198},"content/posts/2024/09/1panel-appstore-refused.md","记一次被1Panel官方应用商店拒绝合并",{"type":70,"value":71,"toc":172},"minimark",[72,76,79,92,95,98,109,112,119,122,125,128,131,134,137,140,143,149,158,161,164,169],[73,74,75],"p",{},"我也算是个1Panel老用户了，从他们还没出Lts版本之前我就一直在用，它们的应用商店是可以通过本地撰写配置文件来实现自定义安装的，因此你可以导入第三方应用商店仓库来帮助你安装更多的应用，官方的应用商店也提供了途径允许你去自己提交应用。",[73,77,78],{},"理论只要项目满足下列条件，就可以尝试提交：",[80,81,82,86,89],"ul",{},[83,84,85],"li",{},"活跃的开源项目",[83,87,88],{},"有官方Docker镜像",[83,90,91],{},"项目比较知名（GitHub高Star）",[73,93,94],{},"然后最近在研究Ghost博客系统，它可以通过Docker部署，这玩意在国外非常出名，但是国内生态很一般，甚至官方中文也没有，网上中文教程也不是很多。",[73,96,97],{},"我想了想，本着一个促进传播的想法，我写了个1Panel应用商店可用的配置文件，本地也进行了安装测试，工作很完美！可以一键安装并自动设置其要求的数据库（MySQL，MariaDB），各种设置做的总体来说挺易用的，毕竟1Panel应用商店的交互逻辑本身就还不错。",[73,99,100,101,108],{},"看了下Ghost应该也算满足官方要求的上面条件，也希望能有更多需要这个博客系统的人能更加便捷的安装它，就整理了一下去提交了一个官方应用商店仓库的",[102,103,107],"a",{"href":104,"rel":105},"https://github.com/1Panel-dev/appstore/pull/2125",[106],"nofollow","GitHub拉取请求","。",[73,110,111],{},"大概是过了两三天吧，收到了回信：",[73,113,114],{},[115,116],"img",{"alt":117,"src":118},"","https://r2-file.101045700.xyz/2024/image_editor_output_image2047887735-17266569364718465991064078587678.webp",[73,120,121],{},"Emm，虽然我赞同你的实话实说，但是这个理由从逻辑上似乎还是难以说通。",[73,123,124],{},"直接说的话其实有些扶持自家产品之嫌了，不愿意其他竞品上架。",[73,126,127],{},"我们不做情绪化的理解，理性点说的话，不大合适。",[73,129,130],{},"首先，如我前面所说，Ghost博客系统在国内的生态很差，简体中文都是爱好者后期添加的，其他主题和插件更是稀缺。",[73,132,133],{},"而Halo在国内的生态可以说一直在稳步发展，可以说在寻找自己用的博客系统的用户应该不会选择去绕过Halo，去硬选Ghost博客系统。",[73,135,136],{},"其次，这样很容易寒了用户的心，我整理写出配置文件大概花了一个小时吧，也不算特别费事。",[73,138,139],{},"但是在基本条件都符合的情况下你采取这样一个方式拒绝，属实是不大合适，格局有那么一点的小。",[73,141,142],{},"多的我也不说了，1Panel是个优秀的产品，我们不能奢求它一定成为我们希望的样子。但我希望它不要被绑上商业化的标签，不要再活成第二个宝塔。",[73,144,145],{},[146,147,148],"strong",{},"补充：",[73,150,151,152,157],{},"有人说我可以提交到第三方应用商店仓库，比如",[102,153,156],{"href":154,"rel":155},"https://github.com/okxlin/appstore",[106],"okxlin/appstore","，但是我说一下我对它的评价，只是个人主观观点。",[73,159,160],{},"在我看来这个第三方应用商店仓库有那么一些的乱，各种提交的应用有些质量不大行，起码配置文件和介绍写的不怎么规范。我在之前曾经为其贡献过Mix-Space和NodeBB，后面我在自己拉取使用的时候感觉是真的乱，包括一些与官方应用商店重叠的应用，以及里面部分应用你居然还需要到目录下手动docker compose -d 来启动。",[73,162,163],{},"我感谢为此做出贡献的所有人们，但我应该不会去使用它，后面我打算自己写一个干净一些的商店仓库集合。",[73,165,166],{},[146,167,168],{},"更新：",[73,170,171],{},"在 25 年 4 月 10 日的一次合并请求中他们合并了Ghost博客系统，还顺带告知了我一下，我不好评价...",{"title":117,"searchDepth":173,"depth":173,"links":174},4,[],[176],"技术探索","2024-09-07T19:24:26","本文介绍了向 1Panel 官方应用商店提交 Ghost 博客应用却被以“与 Halo 功能重叠”为由拒绝的经过，指出官方做法有排斥竞品之嫌，易挫伤社区热情；记录了本地撰写配置文件、一键部署数据库的完整测试流程与体验；分享了作者对第三方商店仓库质量参差、手动启动繁琐的不满，并计划自建整洁仓库的后续思路，为同类 Docker 应用上架与生态选择提供参考。",false,"md",{"slots":182},{},true,"/2024/09/1panel-appstore-refused",{"text":186,"minutes":187,"time":188,"words":189},"5 min read",4.79,287400,958,{"title":68,"description":178},{"loc":184},"posts/2024/09/1panel-appstore-refused",[194,195],"1Panel","Docker","tech","2025-04-11T18:00:00","Nr947-J293CRND-cheMBbCE4eqtlts1pBwF4EEZWohM",[200,205],{"title":201,"path":202,"stem":203,"date":204,"type":196,"children":-1},"Docker部署Outline并使用Github作为OAuth服务","/2024/08/docker-deploy-outline","posts/2024/08/docker-deploy-outline","2024-08-07T19:24:26",{"title":206,"path":207,"stem":208,"date":209,"type":196,"children":-1},"编写1Panel应用商店第三方程序","/2024/10/write-1panel-app","posts/2024/10/write-1panel-app","2024-10-17T19:24:26",1774206436084]