[{"data":1,"prerenderedAt":170},["ShallowReactive",2],{"global-music-player":3,"post-/2024/03/takagi":66,"surround-/2024/03/takagi":164},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":139,"date":141,"description":142,"draft":143,"extension":144,"hide-info":143,"image":65,"meta":145,"navigation":147,"path":148,"permalink":65,"published":65,"readingTime":149,"recommend":65,"references":65,"seo":154,"sitemap":155,"stem":156,"subtitle":65,"tags":157,"type":161,"updated":162,"__hash__":163},"content/posts/2024/03/takagi.md","君と光：我与高木圈的故事",{"type":70,"value":71,"toc":131},"minimark",[72,76,79,82,85,88,92,95,98,101,104,107,110,113,116,119,122,125,128],[73,74,75],"p",{},"在 2022 年的那个暑假，天气很热，在这样一个天气，没有什么是比家里蹲吹风扇，刷 B 站更好的事情了（Doge），于是我打开了 B 站，然后它给我推送了一个视频：“”西片太太开车预警“，我有点好奇的点进了这个视频，然后就有了一种莫名其妙的感觉：”这是什么番，我要看一看。”",[73,77,78],{},"在评论区的引导下，我在B站搜索到了《擅长捉弄的高木同学》第二季（当时B站并没有第一季，然而现在上线了也把视频那段删了，悲），我决定先看一看第二季，于是我打开了第二季第一集…",[73,80,81],{},"25 分钟后…. 我：”甜啊！太甜了！“",[73,83,84],{},"于是我前往某些地方从第一季开始看，然后无法自拔…",[73,86,87],{},"没错，就这样我成为了一个高木粉！（十分草率）",[89,90,91],"h2",{"id":91},"机缘",[73,93,94],{},"光看没人聊可不行啊？然后碰巧 QQ 有 QQ 频道这个功能，我便莫名其妙的去搜索高木同学，于是就加入了 QQ 频道，但此时我处于潜水状态，我选择再去二刷番剧（扭动），然后我在频道内搜寻相关资源打算存下来收藏看，但此时却发现频道还在使用万恶的百度网盘共享文件，这玩意的下载速度…简直要命，不过好在频道有一位大佬提供了番剧直链，我得以获取到了视频资源。",[73,96,97],{},"但作为一个爱折腾的人，碰巧此时，我对建站产生了兴趣并正在研究建站。",[73,99,100],{},"在网上看到有人搭建资源站以后，我产生了一个改变了我以后在高木圈做的事情的想法：建一个资源站，让大家都能在线下载和预览高木同学的相关资源。",[73,102,103],{},"于是在一番钻研和鼓捣以后，2022 年 10 月，我建立了一个属于高木的资源站。",[73,105,106],{},"此时我在做的事情就是搬砖，把资源搬过去，不过这是一件麻烦的事情，我在频道把我的资源站拿了出来，然后此时对我之后建设起了重要贡献的人出现了－－牧丰。",[73,108,109],{},"他看到了资源站并表示愿意帮我填充资源，这肯定是一件好事，能减少我的工作量，也能更快的完成资源站的基本建设。 于是在他的帮助下，我完成了基本资源建设，资源站就这样放在那。",[89,111,112],{"id":112},"深入",[73,114,115],{},"再往后随着我们兴趣的提升，已经不能简单的鼓捣一个资源站了，于是2023年末期有了木创社的雏形——一个Github组织，建设了高木Wiki站，高木Fan社区（项目还是暴死了），我也结识了更多朋友，比如南栀，还有WaterApple，Ice Year等等，不尽其数，遇到了他们，大家也度过了一段快乐的时光。",[89,117,118],{"id":118},"结语",[73,120,121],{},"本段结语来自Ice Year的文章《君と光》（灵感丧失）",[73,123,124],{},"2023 年 10 月 12 日，《擅长捉弄人的高木同学》的漫画也正式完结。在夏日祭的烟火之下，相互的表明心意与拥抱圆满了一直脑补的场景（喜极而泣）。",[73,126,127],{},"或许以后，了解高木同学的人可能终将会会逐渐减少吧，甚至哪怕是高木和西片也终将走向平常的生活（原高木同学可以印证） 然而，这种 “一期一会”，我想也正是《擅长捉弄人的高木同学》想表现的，没有惊天动地，没有缠绵萦绕，只是日常。细节与碎片中，更表现了高木与西片相遇的珍贵，也表现了观者与其相遇的珍贵。",[73,129,130],{},"认真体悟其中的美好和温暖，这便是意义所在吧。多年以后，当回想起曾经的温暖的时候，“君と光 映すだけ”，便足够了。",{"title":132,"searchDepth":133,"depth":133,"links":134},"",4,[135,137,138],{"id":91,"depth":136,"text":91},2,{"id":112,"depth":136,"text":112},{"id":118,"depth":136,"text":118},[140],"动漫番剧","2024-03-07T19:24:26","本文记录了作者于2022年暑假因B站一条“西片太太开车预警”视频入坑《擅长捉弄的高木同学》，先追第二季再补第一季，瞬间被高糖日常俘获的草率契机；分享了随后潜行高木QQ频道、不满百度网盘限速、自学建站并于2022年10月上线直链资源站，又在网友牧丰帮助下完成初期搬运的幕后故事；同时回顾2023年末牵头成立“木创社”GitHub组织，共建高木Wiki与Fan社区，结识南栀、WaterApple、Ice Year等伙伴的快乐时光；最后借Ice Year《君と光》一文，感慨漫画于2023年10月12日完结后“一期一会”的珍贵，铭记“只要映出与你共度的光”便足够温暖。",false,"md",{"slots":146},{},true,"/2024/03/takagi",{"text":150,"minutes":151,"time":152,"words":153},"6 min read",5.125,307500,1025,{"title":68,"description":142},{"loc":148},"posts/2024/03/takagi",[158,159,160],"动漫","番剧","高木","tech","2024-03-08T23:30:53","Fe1mqynTdVcWeh-CJXsZXYOL9u9Udn_98gmI9RJ8C7g",[65,165],{"title":166,"path":167,"stem":168,"date":169,"type":161,"children":-1},"Docker部署Outline并使用Github作为OAuth服务","/2024/08/docker-deploy-outline","posts/2024/08/docker-deploy-outline","2024-08-07T19:24:26",1774206436165]