urce":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":175,"date":177,"description":178,"draft":179,"extension":180,"hide-info":179,"image":65,"meta":181,"navigation":183,"path":184,"permalink":65,"published":65,"readingTime":185,"recommend":65,"references":65,"seo":190,"sitemap":191,"stem":192,"subtitle":65,"tags":193,"type":196,"updated":65,"__hash__":197},"content/posts/2024/12/oyiso-tianligpt.md","为Oyiso主题引入TianliGPT摘要",{"type":70,"value":71,"toc":164},"minimark",[72,76,80,83,86,90,93,112,115,119,130,137,140,143,148,151,161],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"在之前我在使用Hexo主题的时候，当时有些Hexo主题带了TianliGPT摘要功能，当时觉得有点意思并且还买了5万字额度，结果到换系统都没用完（无奈）。",[77,81,82],{},"最近这不是又换回WordPress Oyiso主题了嘛，看了下已经有WordPress主题引入TianliGPT的案例了，对照教程和相关代码照葫芦画瓢把摘要功能又给添上了，也算是解决我那剩下的几万字额度。",[77,84,85],{},"不过现在它已经支持到PostChat了，升级版的对话浮窗，更多功能，无限额度，不过18元/月劝退我了，什么时候我文章够多了再引入这个也不急（穷）",[73,87,89],{"id":88},"什么是tianligpt","什么是TianliGPT",[77,91,92],{},"TianliGPT是一个基于GPT-3.5的文字摘要生成工具，你可以将需要提取摘要的文本内容发送给TianliGPT，稍等一会他就可以给你发送一个基于这段文本内容的摘要。",[94,95,96,100,103,106,109],"ul",{},[97,98,99],"li",{},"实时生成的摘要",[97,101,102],{},"自动生成，无需人工干预",[97,104,105],{},"一次生成，再次生成无需消耗key",[97,107,108],{},"包含文字审核过滤，适用于中国大陆",[97,110,111],{},"支持中国大陆访问",[73,113,114],{"id":114},"引入",[116,117,118],"h3",{"id":118},"安装插件与设置",[77,120,121,122,129],{},"首先前往WordPress PostChat插件的",[123,124,128],"a",{"href":125,"rel":126},"https://github.com/zhheo/wordpress-plugin-postchat",[127],"nofollow","Github仓库","下载插件并在后台上传安装。",[77,131,132],{},[133,134],"img",{"alt":135,"src":136},"","https://file.101045700.xyz/2024/12/84bce8cfe0ab8276ba0f78f1b3db4e86.webp",[77,138,139],{},"打开插件设置，在上面填入你的Key，获取Key和购买额度参考上面引导，如果只需要文章摘要可以关闭智能对话功能。",[116,141,142],{"id":142},"前端引入代码",[77,144,145],{},[133,146],{"alt":135,"src":147},"https://file.101045700.xyz/2024/12/6a03b5d58939f9f070c358bc812c7070.webp",[77,149,150],{},"打开Oyiso主题的自定义代码设置，把下方代码填入自定义HTML代码（头部）或者（底部）都可以，替换里面的tianliGPT_key项为你的Key。",[152,153,158],"pre",{"className":154,"code":156,"language":157},[155],"language-text","\u003Clink rel=\"stylesheet\" href=\"https://ai.tianli0.top/static/public/tianli_gpt.min.css\">\u003Cscript>\nlet tianliGPT_postSelector = '#postchat_postcontent';\nlet tianliGPT_key = '1145141919810'; //填入你的Key\n\u003C/script>\n\u003Cscript src=\"https://ai.tianli0.top/static/public/tianli_gpt.min.js\">\u003C/script>\n","text",[159,160,156],"code",{"__ignoreMap":135},[77,162,163],{},"保存设置，然后Enjoy it.",{"title":135,"searchDepth":165,"depth":165,"links":166},4,[167,169,170],{"id":75,"depth":168,"text":75},2,{"id":88,"depth":168,"text":89},{"id":114,"depth":168,"text":114,"children":171},[172,174],{"id":118,"depth":173,"text":118},3,{"id":142,"depth":173,"text":142},[176],"技术探索","2024-12-07T18:24:26","本文介绍了如何为 WordPress Oyiso 主题一键接入 TianliGPT 智能摘要；本文记录了从安装 PostChat 插件、配置 Key，到插入前端代码、关闭对话浮窗的完整流程；让文章页自动生成摘要，无需人工干预，兼容大陆网络，提升阅读体验与 SEO。",false,"md",{"slots":182},{},true,"/2024/12/oyiso-tianligpt",{"text":186,"minutes":187,"time":188,"words":189},"3 min read",2.295,137700,459,{"title":68,"description":178},{"loc":184},"posts/2024/12/oyiso-tianligpt",[194,195],"Oyiso","WordPress","tech","RVHLF18MDUACWpQEMUIzqyBb_cbH6bVVqxlu1Tj3ZWU",[199,203],{"title":200,"path":201,"stem":202,"date":177,"type":196,"children":-1},"破坏型迁移：站点反复横跳与稳定工作","/2024/12/break-change-2024","posts/2024/12/break-change-2024",{"title":204,"path":205,"stem":206,"date":207,"type":196,"children":-1},"为了一碟醋包了一盘饺子：构建和提交Kazumi AUR包","/2025/01/arch-aur-kazumi","posts/2025/01/arch-aur-kazumi","2025-01-24T18:24:26",1773069189321]