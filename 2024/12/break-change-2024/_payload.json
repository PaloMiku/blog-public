[{"data":1,"prerenderedAt":153},["ShallowReactive",2],{"global-music-player":3,"post-/2024/12/break-change-2024":66,"surround-/2024/12/break-change-2024":143},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":121,"date":123,"description":124,"draft":125,"extension":126,"hide-info":125,"image":65,"meta":127,"navigation":129,"path":130,"permalink":65,"published":65,"readingTime":131,"recommend":65,"references":65,"seo":136,"sitemap":137,"stem":138,"subtitle":65,"tags":139,"type":141,"updated":65,"__hash__":142},"content/posts/2024/12/break-change-2024.md","破坏型迁移：站点反复横跳与稳定工作",{"type":70,"value":71,"toc":117},"minimark",[72,76,79,82,85,88,94,97,104,110],[73,74,75],"p",{},"Hi~我是Mikuの鬆（PaloMiku），好久不见。",[73,77,78],{},"我在自己博客上又做了破坏性迁移，出于多方面考虑，博客域名将迁移到blog子域名上，评论数据等将不会被保留，部分文章被删除（有部分2023年以及之前的文章仍在修订迁移）。",[73,80,81],{},"说来惭愧，因为个人能力问题，所以在站点撰写文章上是可以明显看出水分和个人能力不足。",[73,83,84],{},"我的很多时间可能还是花在了调整站点架构，域名迁移，服务器调整上。",[73,86,87],{},"在本次破坏性迁移后，站点可以保证在2026年9月前在不遇到任何意外情况的前提下，将不再进行域名与服务器迁移工作，可以基本保证站点稳定性。",[73,89,90],{},[91,92,93],"strong",{},"为什么？",[73,95,96],{},"因为本站基本服务结构（服务器和域名）已经可以确定在2026年9月前不会到期，所以就算我人没了，它也会工作到2026年9月18日结束。",[73,98,99],{},[100,101],"img",{"alt":102,"src":103},"华为云华东上海服务器（2026年12月到期）","https://file.101045700.xyz/2024/12/06458ae7237f9879b28bd19ba42984c8.webp",[73,105,106],{},[100,107],{"alt":108,"src":109},"本站域名Whois信息","https://file.101045700.xyz/2024/12/7529e5bea4285b3d5a3fc3bf0f90fb49.webp",[73,111,112,113,116],{},"同时服务器系统已更换为",[91,114,115],{},"Huawei Cloud EulerOS","以保证服务器持续工作稳定性，本站后续更新依旧会保持缓慢进展。",{"title":118,"searchDepth":119,"depth":119,"links":120},"",4,[],[122],"日志记录","2024-12-07T18:24:26","本文记录了博主 PaloMiku 将站点整体迁移至 blog 子域名、丢弃评论与旧文、改用 Huawei Cloud EulerOS 的全过程；本文分享了“破坏型迁移”背后的动机——架构试错、域名续费到 2026-09、服务器同步续费至 2026-12，从而锁定近两年零意外停机；本文承诺在 2026 年 9 月 18 日前不再变动域名与服务器，为读者提供可预期的长期稳定访问。",false,"md",{"slots":128},{},true,"/2024/12/break-change-2024",{"text":132,"minutes":133,"time":134,"words":135},"2 min read",1.545,92700,309,{"title":68,"description":124},{"loc":130},"posts/2024/12/break-change-2024",[140],"迁移","tech","vtQqPdtDiDmsqFQj5NkWoroglkqBkym-zpr2YETNiJg",[144,149],{"title":145,"path":146,"stem":147,"date":148,"type":141,"children":-1},"GitHub Action 构建 Shiroi Docker 镜像","/2024/10/shiroi-docker-deployment","posts/2024/10/shiroi-docker-deployment","2024-10-21T19:24:26",{"title":150,"path":151,"stem":152,"date":123,"type":141,"children":-1},"为Oyiso主题引入TianliGPT摘要","/2024/12/oyiso-tianligpt","posts/2024/12/oyiso-tianligpt",1774206435975]