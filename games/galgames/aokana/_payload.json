":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":531,"date":65,"description":78,"draft":533,"extension":534,"hide-info":535,"image":536,"meta":537,"navigation":535,"path":539,"permalink":65,"published":65,"readingTime":540,"recommend":65,"references":65,"seo":545,"sitemap":546,"stem":547,"subtitle":65,"tags":548,"type":549,"updated":65,"__hash__":550},"content/games/galgames/aokana.md","苍之彼方的四重奏",{"type":70,"value":71,"toc":516},"minimark",[72,317,320,326,331,339,342,347,387,390,397,403,498,501],[73,74,75,83,87,90,93,96,99,102],"folding",{},[76,77,79],"template",{"v-slot:title":78},"",[80,81,82],"p",{},"个人进度 & 路线攻略",[84,85,86],"h2",{"id":86},"版本选择",[80,88,89],{},"Steam 国际中文版，史低购买游戏本体，已安装补丁。",[80,91,92],{},"个人在 Windows 11 和 Linux （Proton）环境运行游玩均通过测试。",[84,94,95],{"id":95},"个人进度",[80,97,98],{},"Steam 成就进度 100%（22/22），游戏内鉴赏模式完成度 100 %。",[84,100,101],{"id":101},"路线攻略",[103,104,105],"card-list",{},[106,107,108,150,170,198,226,249,281],"ul",{},[109,110,111,115,116],"li",{},[112,113,114],"strong",{},"基本选项（随选）","：\n",[106,117,118,121,124,127,130,133,136,139,142,145],{},[109,119,120],{},"打招呼",[109,122,123],{},"因为我希望仓科同学能够学会飞行",[109,125,126],{},"跟真白谈谈如何提高美咲的干劲",[109,128,129],{},"我也要告诉她这肉很好吃",[109,131,132],{},"对待社团活动的态度再认真一点啊",[109,134,135],{},"继续和莉佳一起训练",[109,137,138],{},"考虑一下把这个当作必杀技吧",[109,140,141],{},"告诉她",[109,143,144],{},"叫住美咲",[109,146,147],{},[112,148,149],{},"此时进行存档（存档点 01)",[109,151,152,155],{},[112,153,154],{},"仓科明日香 Asuka Kurashina",[106,156,157,162,165],{},[109,158,159],{},[112,160,161],{},"读取存档点 01（基本选项部分）",[109,163,164],{},"......明白了",[109,166,167],{},[112,168,169],{},"仓科明日香 Asuka Kurashina END",[109,171,172,175],{},[112,173,174],{},"有坂真白 Mashiro Arisaka",[106,176,177,182,185,190,193],{},[109,178,179],{},[112,180,181],{},"读取存档点 01（仓科明日香部分）",[109,183,184],{},"对不起，我做不到",[109,186,187],{},[112,188,189],{},"此时进行存档（存档点 02)",[109,191,192],{},"我想和你一起继续下去",[109,194,195],{},[112,196,197],{},"有坂真白 Mashiro Arisaka END",[109,199,200,203],{},[112,201,202],{},"市之濑莉佳 Rika Ichinose",[106,204,205,210,213,218,221],{},[109,206,207],{},[112,208,209],{},"读取存档点 02（有坂真白部分）",[109,211,212],{},"按你自己想的做就好",[109,214,215],{},[112,216,217],{},"此时进行存档（存档点 03)",[109,219,220],{},"如果我可以的话……我愿意",[109,222,223],{},[112,224,225],{},"市之濑莉佳 Rika Ichinose END",[109,227,228,231],{},[112,229,230],{},"鸢泽美咲 Misaki Tobisawa",[106,232,233,238,241,244],{},[109,234,235],{},[112,236,237],{},"读取存档点 03（市之濑莉佳部分）",[109,239,240],{},"非常抱歉，我做不到",[109,242,243],{},"给我来训练！",[109,245,246],{},[112,247,248],{},"鸢泽美咲 Misaki Tobisawa END",[109,250,251,254],{},[112,252,253],{},"杂项",[106,255,256,261,264,274],{},[109,257,258],{},[112,259,260],{},"FINALE 在彼端的彼端 结局条件：",[109,262,263],{},"完成所有女主 END，会自动进入。",[109,265,266],{},[112,267,268,273],{},[269,270,272],"tip",{"tip":271},"这才是亲闺女吧","美咲的第 5 个 Sence","：",[109,275,276,277,280],{},"在完成",[112,278,279],{},"在彼端的彼端","结局后，可在鉴赏 MEMORIES（回忆纪录）查看美咲的第 5 个 Sence",[109,282,283,286],{},[112,284,285],{},"坏结局（仅供娱乐，成就需求）",[106,287,288,290,292,294,296,299,301,303,305,307,310,312,314],{},[109,289,120],{},[109,291,123],{},[109,293,126],{},[109,295,129],{},[109,297,298],{},"对待社团活动的态度再认真点啊",[109,300,135],{},[109,302,138],{},[109,304,141],{},[109,306,144],{},[109,308,309],{},"不，我做不到",[109,311,212],{},[109,313,240],{},[109,315,316],{},"做你想做的吧",[84,318,319],{"id":319},"简介",[80,321,322],{},[323,324],"img",{"alt":78,"src":325},"https://storage.googleapis.com/studio-design-asset-files/projects/p6aoL8DkWR/s-300x47_60632891-b735-4f45-8228-c353c7134a62.svg",[327,328],"video-embed",{"id":329,"type":330},"BV1Lb411K7Fe","bilibili",[80,332,333,334,338],{},"《苍之彼方的四重奏》（蒼の彼方のフォーリズム，Aokana: Four Rhythm Across the Blue）是由 Sprite（雪碧社）制作的电子游戏，于2014年11月28日发售，并有 ",[269,335,337],{"tip":336},"烂作，改百合是什么抽象操作","动画","、漫画、小说、Fan Disc、Drama CD等衍生作品。",[80,340,341],{},"个人游玩的是2019年9月28日上线的 Steam 国际中文版，基础分辨率提升至2K，由 HIKARI FIELD 发行。",[80,343,344],{},[323,345],{"alt":78,"src":346},"https://storage.googleapis.com/studio-design-asset-files/projects/p6aoL8DkWR/s-1600x1048_v-fms_webp_bf2b3bfd-0efc-4755-be26-5ad8b22d5ace_middle.webp",[73,348,349,354,357,360,363,366,369,372,375,378,381,384],{},[76,350,351],{"v-slot:title":78},[80,352,353],{},"剧情简介",[80,355,356],{},"这是一个在空中飞翔就像骑自行车一样简单的世界。",[80,358,359],{},"反重力粒子被发现后，人类发明了梦想已久的飞空靴——反重力粒子靴（俗称“重力靴”），",[80,361,362],{},"它的问世，为人类带来了全新的视野，而一种使用重力靴的竞技运动“Flying Circus”也随之诞生。",[80,364,365],{},"主人公日向晶也在这项运动上曾是个备受瞩目的新星。",[80,367,368],{},"然而一次压倒性的败北，和某个其他的原因，",[80,370,371],{},"让他就此与赛场诀别——直到他邂逅了转校生仓科明日香。",[80,373,374],{},"在他指导明日香做飞行训练的日子里，曾经的热情也渐渐复苏。",[80,376,377],{},"终于，他以另一种身份，重新出现在Flying Circus的赛场上。",[80,379,380],{},"时而切磋技艺，时而相互鼓励，迎接一个又一个劲敌的挑战。",[80,382,383],{},"与明日香携手共进的主人公，这次能展翅高飞到何处呢——",[80,385,386],{},"这是一部因“飞翔”而相遇的两个人，与伙伴们共同谱写的飞空恋歌。",[84,388,389],{"id":389},"相关链接",[391,392],"link-card",{"description":393,"icon":394,"link":395,"title":396},"《苍之彼方的四重奏》游戏官网（日文）","https://storage.googleapis.com/studio-design-asset-files/projects/p6aoL8DkWR/s-2400x1488_v-frms_webp_e78b276f-d9d2-42d8-b97c-035291c271ae_middle.webp","https://products.sprite.net/aokana","游戏官网（日文）",[391,398],{"description":399,"icon":400,"link":401,"title":402},"《苍之彼方的四重奏》游戏中文 Steam 页面","https://blog-files.101045700.xyz/icons/SteamLogo.png","https://store.steampowered.com/app/1044620/__Aokana__Four_Rhythms_Across_the_Blue/","游戏中文版 Steam 页面",[73,404,405,410,422,427,434,466,470,479,482],{},[76,406,407],{"v-slot:title":78},[80,408,409],{},"游戏资源链接",[411,412,414,419],"alert",{"type":413},"error",[76,415,416],{"v-slot:title":78},[80,417,418],{},"获取前注意！",[80,420,421],{},"有能力请优先支持正版，本站本身不存储任何游戏资源，所有资源均来自网络收集。",[423,424,426],"h3",{"id":425},"touchgal","TouchGal",[80,428,429,430,433],{},"若有解压密码，均为",[431,432,425],"code",{"code":425},"。",[106,435,436,445,452,459],{},[109,437,438,439],{},"游戏详情：",