itle":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":485,"date":65,"description":479,"draft":487,"extension":488,"hide-info":489,"image":65,"meta":490,"navigation":489,"path":492,"permalink":65,"published":65,"readingTime":493,"recommend":65,"references":65,"seo":498,"sitemap":499,"stem":500,"subtitle":65,"tags":501,"type":502,"updated":65,"__hash__":503},"content/games/galgames/clannad/secret/name.md","主角姓名与台词的关系",{"type":70,"value":71,"toc":478},"minimark",[72,79,82,85,89,331,334],[73,74,75],"alert",{},[76,77,78],"p",{},"此特性仅限可修改主角名字的 Full Voice 旧版。",[76,80,81],{},"在 Clannad 中，玩家可以对主角的姓名进行修改（原名为：岡崎 朋也），而修改名字这一功能不仅能够在一定程度上加强玩家的代入感，有一些十分特殊的名字还会在一些特殊情况下令游戏的台词发生变化。",[76,83,84],{},"以下就将这些名字和对应的变化列举出来：",[86,87,88],"h2",{"id":88},"日文版",[90,91,92,114],"table",{},[93,94,95],"thead",{},[96,97,98,102,105,108,111],"tr",{},[99,100,101],"th",{},"日期",[99,103,104],{},"场景",[99,106,107],{},"条件",[99,109,110],{},"示例",[99,112,113],{},"备注",[115,116,117,134,155,170,187,202,229,264,300,315],"tbody",{},[96,118,119,126,128,130,132],{},[120,121,122],"td",{},[123,124,125],"strong",{},"智代路线",[120,127],{},[120,129],{},[120,131],{},[120,133],{},[96,135,136,139,146,149,152],{},[120,137,138],{},"4.17",[120,140,141,142,145],{},"春原第二次挑战智代的时候。",[143,144],"br",{},"若发生春原脸部变形事件则不发生此事件。",[120,147,148],{},"名字不是“朋也”",[120,150,151],{},"岡崎 岡崎",[120,153,154],{},"朋也和智代的名字的首字发音都是“TOMO”，春原发出了“TOMO组合”的感叹，改名后自然不再成立。",[96,156,157,162,164,166,168],{},[120,158,159],{},[123,160,161],{},"有紀寧路线",[120,163],{},[120,165],{},[120,167],{},[120,169],{},[96,171,172,175,178,181,184],{},[120,173,174],{},"4.18",[120,176,177],{},"有紀寧记下主角的姓名的时候。以及之后几次不良们登场时。",[120,179,180],{},"姓“蛭子”",[120,182,183],{},"蛭子 朋也",[120,185,186],{},"未改名时有紀寧误记为“蛭子”，改了之后误记为“江の川”。",[96,188,189,194,196,198,200],{},[120,190,191],{},[123,192,193],{},"渚路线",[120,195],{},[120,197],{},[120,199],{},[120,201],{},[96,203,204,207,210,218,226],{},[120,205,206],{},"4.16",[120,208,209],{},"与古河一家吃饭时。",[120,211,212,213,215,217],{},"情况1：姓“銀河”或“宇宙”或“コスモ”，名“シャア”",[143,214],{},[143,216],{},"情况2：姓“銀河”或“宇宙”或“コスモ”，名为“シャア”以外的任意名字",[120,219,220,221,223,225],{},"情况1：銀河　シャア",[143,222],{},[143,224],{},"情况2：銀河　朋也",[120,227,228],{},"未改名时，古河一家在调侃朋也的名字没有气势，并提到了这些特别的词语。改名后，自然就会改变台词了。",[96,230,231,233,236,249,262],{},[120,232,138],{},[120,234,235],{},"秋生和早苗晚上来公园接渚的时候。",[120,237,238,239,241,243,244,246,248],{},"情况1：姓名为“コスモ　斉藤”",[143,240],{},[143,242],{},"情况2：姓名为“大宇宙　太郎”",[143,245],{},[143,247],{},"情况3：姓名中包含了“コスモ”或“銀河”或“宇宙”，但与情况1和2不同",[120,250,251,252,254,256,257,259,261],{},"情况1：コスモ　斉藤",[143,253],{},[143,255],{},"情况2：大宇宙　太郎",[143,258],{},[143,260],{},"情况3：銀河　朋也",[120,263],{},[96,265,266,269,272,285,298],{},[120,267,268],{},"4.19",[120,270,271],{},"在面包店与秋生见面时。",[120,273,274,275,277,279,280,282,284],{},"情况1：姓“銀河”或“宇宙”或“コスモ”",[143,276],{},[143,278],{},"情况2：名“銀河”或“宇宙”或“コスモ”",[143,281],{},[143,283],{},"情况3：不姓“銀河”或“宇宙”或“コスモ”且名为“ウジ虫”",[120,286,287,288,290,292,293,295,297],{},"情况1：銀河　朋也",[143,289],{},[143,291],{},"情况2：岡崎　銀河",[143,294],{},[143,296],{},"情况3：岡崎　ウジ虫",[120,299],{},[96,301,302,304,307,310,313],{},[120,303,268],{},[120,305,306],{},"去找渚时被早苗叫住。",[120,308,309],{},"姓“宇宙”",[120,311,312],{},"宇宙　朋也",[120,314],{},[96,316,317,320,323,326,329],{},[120,318,319],{},"5.2",[120,321,322],{},"得知早苗开了学社时。",[120,324,325],{},"姓或名为“歌丸”",[120,327,328],{},"岡崎　歌丸",[120,330],{},[86,332,333],{"id":333},"中文版",[90,335,336,350],{},[93,337,338],{},[96,339,340,342,344,346,348],{},[99,341,101],{},[99,343,104],{},[99,345,107],{},[99,347,110],{},[99,349,113],{},[115,351,352,366,382,396,410,444],{},[96,353,354,358,360,362,364],{},[120,355,356],{},[123,357,125],{},[120,359],{},[120,361],{},[120,363],{},[120,365],{},[96,367,368,370,374,377,380],{},[120,369,138],{},[120,371,141,372,145],{},[143,373],{},[120,375,376],{},"名字是“智也”",[120,378,379],{},"冈崎 智也",[120,381],{},[96,383,384,388,390,392,394],{},[120,385,386],{},[123,387,193],{},[120,389],{},[120,391],{},[120,393],{},[120,395],{},[96,397,398,400,402,405,408],{},[120,399,206],{},[120,401,209],{},[120,403,404],{},"姓氏或名字中的一个为“夏亚”，另一个含有“宇宙”或“银河”",[120,406,407],{},"情况1：银河 夏亚",[120,409],{},[96,411,412,414,416,429,442],{},[120,413,138],{},[120,415,235],{},[120,417,418,419,421,423,424,426,428],{},"情况1：姓名为“小宇宙 斋藤”",[143,420],{},[143,422],{},"情况2：姓名为“大宇宙 太郎”",[143,425],{},[143,427],{},"情况3：姓名中包含了“银河”或“宇宙”，但与情况1和2不同",[120,430,431,432,434,436,437,439,441],{},"情况1：小宇宙 斋藤",[143,433],{},[143,435],{},"情况2：大宇宙 太郎",[143,438],{},[143,440],{},"情况3：银河 朋也",[120,443],{},[96,445,446,448,450,463,476],{},[120,447,268],{},[120,449,271],{},[120,451,452,453,455,457,458,460,462],{},"情况1：姓“银河”或“宇宙”",[143,454],{},[143,456],{},"情况2：名“银河”或“宇宙”",[143,459],{},[143,461],{},"情况3：不姓“银河”或“宇宙”且名为“蛆虫”",[120,464,465,466,468,470,471,473,475],{},"情况1：银河 朋也",[143,467],{},[143,469],{},"情况2：冈崎 银河",[143,472],{},[143,474],{},"情况3：冈崎 蛆虫",[120,477],{},{"title":479,"searchDepth":480,"depth":480,"links":481},"",4,[482,484],{"id":88,"depth":483,"text":88},2,{"id":333,"depth":483,"text":333},[486],"未分类",false,"md",true,{"slots":491},{},"/games/galgames/clannad/secret/name",{"text":494,"minutes":495,"time":496,"words":497},"5 min read",4.395,263700,879,{"title":68,"description":479},{"loc":492},"games/galgames/clannad/secret/name",[],"tech","H00vOQdjlmyWbFph3TEUrb9L-jtUjmRx1Zh2FxRZu64",[65,65],1774206437254]