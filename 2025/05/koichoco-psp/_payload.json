9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":291,"date":293,"description":294,"draft":295,"extension":296,"hide-info":295,"image":89,"meta":297,"navigation":299,"path":300,"permalink":65,"published":65,"readingTime":301,"recommend":279,"references":65,"seo":306,"sitemap":307,"stem":308,"subtitle":65,"tags":309,"type":312,"updated":65,"__hash__":313},"content/posts/2025/05/koichoco-psp.md","《恋爱与选举与巧克力》携带版试玩体验",{"type":70,"value":71,"toc":275},"minimark",[72,76,83,87,93,96,101,104,113,116,120,208,211,216,220,223,226,230,233,236,240,243,246,250,253,256,260,263,266,269,272],[73,74,75],"h2",{"id":75},"前言",[77,78],"link-banner",{"banner":79,"description":80,"link":81,"title":82},"https://blog-files.101045700.xyz/Gal2025Up/SPRB/AP2.webp","注意！本文包含以下要素： Ciallo～(∠・ω\u003C )⌒★ ,炒冷饭大师雪碧社😡 ,Key 社你真的...😭","/2025/05/gal-up","旮沓给木太好玩辣——2025年上半Gal历程个人总结",[84,85,86],"p",{},"之前曾在 2025 上半总结博文里提到过自己曾游玩《恋爱与选举与巧克力》高清重制版，截至目前，除了衣更线，个人已完成重制版其他线路剧情。",[77,88],{"banner":89,"description":90,"link":91,"title":92},"https://storage.googleapis.com/studio-design-asset-files/projects/p6aoL8DkWR/s-2400x1522_v-frms_webp_ec50cb5d-345a-4a00-ab32-509e8e36b6a4_regular.webp","个人之前曾觉得“味太冲”的作品，但最近又有些喜爱了。","/games/galgames/koichoco","恋爱与选举与巧克力",[84,94,95],{},"但在之前，个人也曾了解到《恋爱与选举与巧克力》在 PSP 携带版是有枝川希美主角线的。",[97,98],"pic",{"caption":99,"src":100},"枝川希美","https://storage.googleapis.com/studio-design-asset-files/projects/p6aoL8DkWR/s-600x600_v-fs_webp_fcfc82ca-6ca1-4126-b267-1ffca1a8d8fc_small.webp",[73,102,103],{"id":103},"角色",[84,105,106,107,112],{},"希美学姐（前辈）在我游玩时也是一个比较感兴趣的角色， ",[108,109,111],"tip",{"tip":110},"即 PC 原版和后来的高清重制版","所有 PC 版","都没有她的线路个人感觉还是有些可惜的。",[84,114,115],{},"据说是因为 PC 版要涉及 HCG,而希美学姐显得太幼了所以不让上（悲）。",[97,117],{"caption":118,"src":119},"（图片来自 B 站）希美线结局","https://blog-files.101045700.xyz/Galgame/Koichoco-A6.webp",[121,122,123,130,142,146,149,152,155,158,161,164,167,171,179,182,185,188],"folding",{},[124,125,127],"template",{"v-slot:title":126},"",[84,128,129],{},"人物简介和游戏资源链接",[131,132,134,139],"alert",{"type":133},"error",[124,135,136],{"v-slot:title":126},[84,137,138],{},"资源获取前注意！",[84,140,141],{},"有能力请优先支持正版，本站本身不存储任何游戏资源，所有资源均来自网络收集。",[143,144,145],"h3",{"id":145},"人物简介",[84,147,148],{},"身高：148cm，体重：39kg，B72、W50、H78",[84,150,151],{},"高藤学园3年级生，升学科。",[84,153,154],{},"食研的前部长。",[84,156,157],{},"在外国跳级后，回到日本的归国子女。",[84,159,160],{},"超级天才，做出很多离奇古怪的发明品。",[84,162,163],{},"被祐树制作的 “大岛卷” 夺走了心。",[84,165,166],{},"大家都叫她「のんちゃん」。",[143,168,170],{"id":169},"携带版psp","携带版（PSP）",[84,172,173,178],{},[174,175],"img",{"alt":176,"src":177},"恋爱与选举与巧克力 携带版","https://ppcimg.csd02.cn/up/2015-6/201568164521.jpg","\n恋爱与选举与巧克力 携带版",[84,180,181],{},"发行日期：2012年09月27日",[84,183,184],{},"携带版添加各女主角的新事件以及 30 张的新 CG。",[84,186,187],{},"且 PC 版无法攻略的枝川希美将作为新女主角添加在携带版中。",[189,190,191,201],"ul",{},[192,193,194,195],"li",{},"Mikuの空间站：",[196,197,198],"a",{"href":198,"rel":199},"https://share.sotkg.com/drive-cn/PSP/b-koichoco-chs.iso",[200],"nofollow",[192,202,203,204],{},"PaoPaoChe：",[196,205,206],{"href":206,"rel":207},"http://zj.qianguw.com:6888/zj/loveelectionchocolatepspcn.zip",[200],[84,209,210],{},"所以个人就去找来携带版体验了一下，倒是收获了不少小惊喜。",[212,213],"video-embed",{"id":214,"type":215},"BV1Dh41147FN","bilibili",[97,217],{"caption":218,"src":219},"在 Steamdeck 上通过 PPSSPP 模拟器体验《恋爱与选举与巧克力》携带版","https://blog-files.101045700.xyz/Galgame/Koichoco-A1.webp",[73,221,222],{"id":222},"惊喜",[143,224,225],{"id":225},"设置希美全语音覆盖",[97,227],{"caption":228,"src":229},"全都有语音呢，太可爱了有没有。","https://blog-files.101045700.xyz/Galgame/Koichoco-A3.webp",[84,231,232],{},"进游戏调整设置时我就被惊喜了一下，在设置页面我们在调整设置时可以听到希美念出设置项的配音，而且是全部设置项都有。",[143,234,235],{"id":235},"千里你终于可爱了",[97,237],{"caption":238,"src":239},"千里你终于有标准的眼距了😭，这才是我想要的可爱的千里😭。","https://blog-files.101045700.xyz/Galgame/Koichoco-A2.webp",[84,241,242],{},"之前玩高清重制版时候我就想要吐槽，有空高清化重制没空修一下千里脸，都崩成什么样子了，你都能把480P素材修到4K了，却没空改一下这个。",[84,244,245],{},"有图有真相，我们在下面放张图和上面的携带版对比下。",[97,247],{"caption":248,"src":249},"真的，诗人握持。","https://blog-files.101045700.xyz/Galgame/Koichoco-A4.webp",[143,251,252],{"id":252},"人物细节更多",[84,254,255],{},"论素材虽然不如 PC 高清重制版清晰，但携带版也有自己的优势细节表示。",[97,257],{"caption":258,"src":259},"增加些许细节","https://blog-files.101045700.xyz/Galgame/Koichoco-A5.webp",[84,261,262],{},"在人物情绪变化等明显比高清重制版细节更多（所以说重制版真是暴力高清化）",[73,264,265],{"id":265},"后记",[84,267,268],{},"总之在简单上手体验后，我越发感觉携带版才是这游戏最佳体验方式。",[84,270,271],{},"所以说后续可能会在这上面继续体验游戏，高清重制版实在是重置的过于暴力。",[84,273,274],{},"后续完成携带版游戏全部内容以后，也会写一篇新的长文。",{"title":126,"searchDepth":276,"depth":276,"links":277},4,[278,280,285,290],{"id":75,"depth":279,"text":75},2,{"id":103,"depth":279,"text":103,"children":281},[282,284],{"id":145,"depth":283,"text":145},3,{"id":169,"depth":283,"text":170},{"id":222,"depth":279,"text":222,"children":286},[287,288,289],{"id":225,"depth":283,"text":225},{"id":235,"depth":283,"text":235},{"id":252,"depth":283,"text":252},{"id":265,"depth":279,"text":265},[292],"旮瘩给木","2025-05-24T08:20:00","本文介绍了《恋爱与选举与巧克力》PSP携带版的试玩亮点：新增可攻略角色枝川希美全程语音、30张新CG及细节演出；记录了PC高清重制版“暴力拉伸”导致的千里眼距崩坏在携带版得到修复，人物表情更丰富；分享了用PPSSPP在Steam Deck流畅运行、获取简体汉化ISO的完整方案，并附配置与资源指引，助你随时品味这部“真·最佳版本”校园恋爱佳作。",false,"md",{"slots":298},{},true,"/2025/05/koichoco-psp",{"text":302,"minutes":303,"time":304,"words":305},"4 min read",3.585,215100,717,{"title":68,"description":294},{"loc":300},"posts/2025/05/koichoco-psp",[310,311],"Galgame","Koichoco","tech","0QG_2hjS0H_NQZ_Rz2gI-RCznnx5wTDYw2nVP-ihvD4",[315,320],{"title":316,"path":317,"stem":318,"date":319,"type":312,"children":-1},"我又用了一段时间 Misskey，发现和 Sharkey 存在一些区别和不足","/2025/05/shr-misskey","posts/2025/05/shr-misskey","2025-05-22T11:30:00",{"title":321,"path":322,"stem":323,"date":324,"type":312,"children":-1},"《Clannad》HD 官方中文版和 Full Voice 汉化版 Linux 运行","/2025/05/clannad-zh-linux","posts/2025/05/clannad-zh-linux","2025-05-26T17:00:00",1773069188589]