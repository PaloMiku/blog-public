:8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":320,"date":322,"description":323,"draft":324,"extension":325,"hide-info":324,"image":326,"meta":327,"navigation":329,"path":330,"permalink":65,"published":65,"readingTime":331,"recommend":336,"references":65,"seo":337,"sitemap":338,"stem":339,"subtitle":65,"tags":340,"type":342,"updated":65,"__hash__":343},"content/posts/2025/05/maitetsu-video-fix.md","《爱上火车》在 Linux 下的视频播放修复",{"type":70,"value":71,"toc":296},"minimark",[72,89,93,96,99,102,109,112,118,121,125,128,131,149,153,156,161,164,168,172,175,180,183,187,190,193,196,200,203,206,211,214,217,220,223,228,231,234,239,242,247,250,253,256,261,264,269,272,277,280,285,288,291],[73,74,75,86],"alert",{},[76,77,78,85],"p",{},[79,80,84],"a",{"href":81,"rel":82},"https://www.xiaoheihe.cn/app/bbs/link/153105496",[83],"nofollow","本文类似版本","个人首发于小黑盒，你在此看到的版本为基于小黑盒发布版本的二次修订版。",[76,87,88],{},"本次修订版本发布于个人博客，目前仅在小黑盒和个人博客发布过本文。",[90,91,92],"h2",{"id":92},"前言",[76,94,95],{},"之前文章也提到过，我是一个 Steamdeck Gal 玩家，而且是用 Linux 跑 Galgame 的“勇者”。",[76,97,98],{},"既然都用 Linux 跑 Gal 了，那么会遇到各种奇奇怪怪问题都算正常了。",[76,100,101],{},"在 Linux 游玩《爱上火车 LastRun!!》时，我就遇到了相关组件缺失问题，使用环境为Proton 9.0，会出现人物线开场动画无法正常播放问题。",[76,103,104],{},[105,106],"img",{"alt":107,"src":108},"Maitetsu Home","https://blog-files.101045700.xyz/Gal2025Up/Maitetsu/Home.webp",[76,110,111],{},"一开始我尝试使用Proton GE环境再次运行进行尝试，但单纯使用ProtonGE环境后反而问题更加严重，到剧情线开场动画会直接黑屏卡死。",[76,113,114],{},[105,115],{"alt":116,"src":117},"ProtonDB","https://blog-files.101045700.xyz/MaitetsuVideoFix/ProtonDB.webp",[76,119,120],{},"在四处寻找解决方法时，发现ProtonDB下的一位用户提出了解决方案，使用Protontricks进行补丁修补，经过验证，问题得到了很好的解决。",[90,122,124],{"id":123},"为什么不用-wine","为什么不用 Wine？",[76,126,127],{},"这个综合原因是有很多的，但简单来说就是笔者是购买的 Steam 官方中文版，使用 Steam Proton 进行运行游戏，很难切换 Proton 以外的第三方兼容层。",[76,129,130],{},"使用第三方版本在 Deck 的 Gamescope 游戏桌面启动和切换也不方便和不美观。",[73,132,134,141],{"type":133},"question",[135,136,138],"template",{"v-slot:title":137},"",[76,139,140],{},"值得注意！",[76,142,143,148],{},[144,145,147],"tip",{"tip":146},"似乎很多 Linux Galgame 玩家都使用它（雾）","笔者使用的 Linux 发行版为 Arch Linux","，桌面环境为 GNOME，后文教程也主要围绕其进行，对于其他发行版，大部分情况下也就是安装方式和软件包存在差异。",[90,150,152],{"id":151},"安装-protontricks","安装 Protontricks",[76,154,155],{},"对于 Steam 官方中文版，我们需要先安装 Protontricks 来实现对其补丁和环境修复。",[157,158,160],"h3",{"id":159},"arch-linux-命令安装","Arch Linux 命令安装",[76,162,163],{},"对于 Arch Linux 且非 Flathub 用户来说，安装 Protontricks 相当简单，而且不需要额外的权限配置。",[165,166],"copy",{"code":167},"sudo pacman -S protontricks",[157,169,171],{"id":170},"flathub-安装","Flathub 安装",[76,173,174],{},"对于其他 Linux 发行版，首先你先去安装 Flatpak，然后我们可以通过 Flathub 来安装 Protontricks。",[176,177,179],"h4",{"id":178},"切换国内-flathub-官方源","切换国内 Flathub 官方源",[76,181,182],{},"我们可以通过以下指令为 Flatpak 切换中国大陆地区的下载源提高下载速度。",[184,185,186],"h5",{"id":186},"上海交通大学",[165,188],{"code":189},"sudo flatpak remote-modify flathub --url=https://mirror.sjtu.edu.cn/flathub",[184,191,192],{"id":192},"中国科学技术大学",[165,194],{"code":195},"sudo flatpak remote-modify flathub --url=https://mirrors.ustc.edu.cn/flathub",[176,197,199],{"id":198},"获取-protontricks-和-flatseal","获取 Protontricks 和 Flatseal",[184,201,202],{"id":202},"软件中心安装",[76,204,205],{},"前往 GNOME 软件中心搜索并获取 Protontricks 和 Flatseal",[76,207,208],{},[105,209],{"alt":137,"src":210},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Fl_Protontricks.webp",[184,212,213],{"id":213},"命令安装",[76,215,216],{},"我们也可以通过以下命令从 Flatpak 安装程序：",[165,218],{"code":219},"flatpak install flathub com.github.Matoking.protontricks",[165,221],{"code":222},"flatpak install flathub com.github.tchx84.Flatseal",[76,224,225],{},[105,226],{"alt":137,"src":227},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Sh_Protontricks.webp",[90,229,230],{"id":230},"权限配置",[76,232,233],{},"我们需要通过 Flatseal 为 Protontricks 配置相关权限保证它能读写文件和正常运行，首先打开 Flatseal 并找到 Protontricks。",[76,235,236],{},[105,237],{"alt":137,"src":238},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Flatseal01.webp",[76,240,241],{},"向下翻找到文件系统相关配置，把这四个全部打开（勾选），为程序分配全部文件系统访问权限，然后关闭 Flatseal，此处配置操作结束。",[76,243,244],{},[105,245],{"alt":137,"src":246},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Flatseal02.webp",[90,248,249],{"id":249},"修补组件",[76,251,252],{},"接下来打开 Protontricks，会出现一个提示框让我们选择需要打补丁的游戏，我们以爱上火车做例子，在此处选择对应的游戏并且选择 OK",[76,254,255],{},"如果报错请先确定你是否已经通过 Proton 启动过一次游戏，不然此处可能会报错找不到游戏相关 Proton 文件。",[76,257,258],{},[105,259],{"alt":137,"src":260},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Protontricks-01.webp",[76,262,263],{},"在一番确定（可能有选择默认 Proton 容器）操作后，我们可以来到如下页面。",[76,265,266],{},[105,267],{"alt":137,"src":268},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Protontricks-02.webp",[76,270,271],{},"在此处我们选择“安装Windows DLL 或组件”来为游戏安装缺失的相关组件，以爱上火车为例，需要安装 DirectShow 和 WMP9 组件来修补视频播放。",[73,273,274],{},[76,275,276],{},"如果下载组件失败，你可能需要配置海外网络环境。",[76,278,279],{},"选定完需要修补的组件后，单击“确定“开始修补安装，期间可能会弹窗和出现安装页面，全部遵循其标准顺序确定或安装。",[76,281,282],{},[105,283],{"alt":137,"src":284},"https://blog-files.101045700.xyz/MaitetsuVideoFix/Protontricks-03.webp",[90,286,287],{"id":287},"测试",[76,289,290],{},"我们关闭Protontricks然后启动游戏测试效果，测试发现游戏内开场动画已经可以正常得到播放，很显然我们修补成功了！",[76,292,293],{},[105,294],{"alt":137,"src":295},"https://blog-files.101045700.xyz/MaitetsuVideoFix/MaitetsuGames.webp",{"title":137,"searchDepth":297,"depth":297,"links":298},4,[299,301,302,317,318,319],{"id":92,"depth":300,"text":92},2,{"id":123,"depth":300,"text":124},{"id":151,"depth":300,"text":152,"children":303},[304,306],{"id":159,"depth":305,"text":160},3,{"id":170,"depth":305,"text":171,"children":307},[308,313],{"id":178,"depth":297,"text":179,"children":309},[310,312],{"id":186,"depth":311,"text":186},5,{"id":192,"depth":311,"text":192},{"id":198,"depth":297,"text":199,"children":314},[315,316],{"id":202,"depth":311,"text":202},{"id":213,"depth":311,"text":213},{"id":230,"depth":300,"text":230},{"id":249,"depth":300,"text":249},{"id":287,"depth":300,"text":287},[321],"旮瘩给木","2025-05-19T18:30:00","本文介绍了《爱上火车》Linux Proton 环境视频播放修复方案，记录从黑屏卡死到正常播放的排查过程，分享用 Protontricks 补 DirectShow+WMP9 的完整命令与 Flatseal 权限配置，提供 Arch/Flatpak 双安装路径与镜像加速技巧，一站式解决 Steam 中文版动画无法播放痛点，助力 Linux 玩家零切换畅玩 Galgame。",false,"md","https://blog-files.101045700.xyz/MaitetsuVideoFix/Home.webp",{"slots":328},{},true,"/2025/05/maitetsu-video-fix",{"text":332,"minutes":333,"time":334,"words":335},"6 min read",5.055,303300,1011,10,{"title":68,"description":323},{"loc":330},"posts/2025/05/maitetsu-video-fix",[341],"Galgame","tech","0m48JcN6dLB1MB0RF7lntNlXhkIRkB0CVAC_yQMZ86E",[345,351],{"title":346,"path":347,"stem":348,"date":349,"type":350,"children":-1},"旮沓给木太好玩辣——2025年上半Gal历程个人总结","/2025/05/gal-up","posts/2025/05/gal-up","2025-05-19T00:30:00","story",{"title":352,"path":353,"stem":354,"date":355,"type":342,"children":-1},"浅谈个人与 Fediverse 的过往历史和现状","/2025/05/fediverse","posts/2025/05/fediverse","2025-05-20T08:30:00",1773069188227]