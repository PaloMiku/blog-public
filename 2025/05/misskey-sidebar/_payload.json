73,74,75],"h2",{"id":75},"前言",[77,78,79,80,85],"p",{},"Misskey是一个十分强大的 Fediverse 程序，今天我们来讲解一下里面特有的一个 ",[81,82,84],"tip",{"tip":83},"提起来我博客也有 Sidebar Tools（雾）","侧边栏小工具功能","，它还是十分的强大且易用的。",[87,88,90,97],"alert",{"type":89},"warning",[91,92,94],"template",{"v-slot:title":93},"",[77,95,96],{},"注意！",[77,98,99],{},"本文基于 Sharkey 2025.4.2-rc-stelpolva 进行组件和功能示例讲解，可能不适用于所有 Misskey/Sharkey 版本。",[73,101,102],{"id":102},"组件",[77,104,105,106,110],{},"默认情况下，小工具位于 PC/Pad 模式 ",[81,107,109],{"tip":108},"Deck模式下需要手动调出“小工具”页面","右侧侧边栏","部分。",[112,113,115],"h3",{"id":114},"个人资料profile","个人资料（profile）",[117,118,119],"h4",{"id":119},"简介",[77,121,122],{},"非常简单的展示个人资料的组件，分别展示了头像，昵称，个人资料横幅，实例用户地址信息。",[117,124,125],{"id":125},"示例",[77,127,128],{},[129,130],"img",{"alt":131,"src":132},"profile","https://blog-files.101045700.xyz/Fediverse/Sidebar/profile.webp",[117,134,135],{"id":135},"设置",[77,137,138],{},"此组件无额外设置。",[112,140,142],{"id":141},"服务器信息instanceinfo","服务器信息（instanceInfo）",[117,144,119],{"id":145},"简介-1",[77,147,148],{},"整体样式与个人资料一致，展示了服务器（实例）LOGO，名称，资料横幅背景，实例地址。",[117,150,125],{"id":151},"示例-1",[77,153,154],{},[129,155],{"alt":156,"src":157},"instanceInfo","https://blog-files.101045700.xyz/Fediverse/Sidebar/instanceInfo.webp",[117,159,135],{"id":160},"设置-1",[77,162,138],{},[112,164,166],{"id":165},"便签memo","便签（memo）",[117,168,119],{"id":169},"简介-2",[77,171,172],{},"一个可以随时记录的便签小组件，自动保存，用来做备忘不错。",[117,174,125],{"id":175},"示例-2",[77,177,178],{},[129,179],{"alt":180,"src":181},"memo","https://blog-files.101045700.xyz/Fediverse/Sidebar/memo.webp",[117,183,135],{"id":184},"设置-2",[186,187,189],"h5",{"id":188},"showheader","showHeader",[77,191,192],{},"通用开关控件，控制组件是否在小工具栏展示组件标题，默认为开启（展示）。",[186,194,195],{"id":195},"height",[77,197,198],{},"通用数值设置，控制组件在小工具栏的展示高度，默认值为 100。",[112,200,202],{"id":201},"通知notifications","通知（notifications）",[117,204,119],{"id":205},"简介-3",[77,207,208],{},"展示收到的通知，与“通知”页面展示内容一致。",[117,210,125],{"id":211},"示例-3",[77,213,214],{},[129,215],{"alt":216,"src":217},"notifications","https://blog-files.101045700.xyz/Fediverse/Sidebar/notifications.webp",[117,219,135],{"id":220},"设置-3",[186,222,189],{"id":223},"showheader-1",[77,225,192],{},[186,227,195],{"id":228},"height-1",[77,230,231],{},"通用数值设置，控制组件在小工具栏的展示高度，默认值为 300。",[112,233,235],{"id":234},"时间线timeline","时间线（timeline）",[117,237,119],{"id":238},"简介-4",[77,240,241],{},"展示实例时间线，与“时间线”功能一致，有“首页”，“本地”、“社交”、“全局”页面。",[117,243,125],{"id":244},"示例-4",[77,246,247],{},[129,248],{"alt":249,"src":250},"timeline","https://blog-files.101045700.xyz/Fediverse/Sidebar/timeline.webp",[117,252,135],{"id":253},"设置-4",[186,255,189],{"id":256},"showheader-2",[77,258,192],{},[186,260,195],{"id":261},"height-2",[77,263,231],{},[112,265,267],{"id":266},"日历calendar","日历（calendar）",[117,269,119],{"id":270},"简介-5",[77,272,273],{},"通过进度条形式展示年月日进度，左侧为大标题醒目显示日历信息。",[117,275,125],{"id":276},"示例-5",[77,278,279],{},[129,280],{"alt":281,"src":282},"calendar","https://blog-files.101045700.xyz/Fediverse/Sidebar/calendar.webp",[117,284,135],{"id":285},"设置-5",[186,287,288],{"id":288},"transparent",[77,290,291],{},"通用开关控件，控制组件背景是否为全透明，默认为关闭（不透明）。",[112,293,295],{"id":294},"rss-阅读器rss","RSS 阅读器（rss）",[117,297,119],{"id":298},"简介-6",[77,300,301],{},"采集指定地址的 RSS 信息并以列表展示。",[117,303,125],{"id":304},"示例-6",[77,306,307,308],{},"此处使用个人博客（5月20日）RSS 信息作为示例展示。\n",[129,309],{"alt":310,"src":311},"rss","https://blog-files.101045700.xyz/Fediverse/Sidebar/rss.webp",[117,313,135],{"id":314},"设置-6",[186,316,317],{"id":317},"url",[77,319,320],{},"控制组件采集的 RSS 地址，如本博客的 /atom.xml 。",[186,322,324],{"id":323},"refreshintervalsec","refreshIntervalSec",[77,326,327],{},"（应当）是控制组件采集信息的间隔时间，单位为 Sec（秒），默认值为 60。",[186,329,331],{"id":330},"maxentries","maxEntries",[77,333,334],{},"控制组件采集的 RSS 信息条目数，默认值为 15（条）。",[186,336,189],{"id":337},"showheader-3",[77,339,192],{},[112,341,343],{"id":342},"rss-trickerrssticker","RSS Tricker（rssTicker）",[117,345,119],{"id":346},"简介-7",[77,348,349],{},"与 RSS 阅读器组件一样都是采集制定 RSS 信息后展示，但展示方式为滚动横条。",[117,351,125],{"id":352},"示例-7",[77,354,355],{},[129,356],{"alt":357,"src":358},"rssTicker","https://blog-files.101045700.xyz/Fediverse/Sidebar/rssTicker.webp",[117,360,135],{"id":361},"设置-7",[186,363,317],{"id":364},"url-1",[77,366,367],{},"控制组件采集的 RSS 地址。",[186,369,370],{"id":370},"shuffle",[77,372,373],{},"开关控件，控制组件滚动展示的信息（是否）随机排序，默认为开启（随机排序）。",[186,375,324],{"id":376},"refreshintervalsec-1",[77,378,327],{},[186,380,331],{"id":381},"maxentries-1",[77,383,334],{},[186,385,386],{"id":386},"duration",[77,388,389],{},"控制组件信息滚动速度，数值越大则滚动越慢，反之则越快，默认值为 70。",[186,391,392],{"id":392},"reverse",[77,394,395],{},"开关控件，控制组件滚动信息滚动方向，默认为从右向左滚动（关闭），开启则反之。",[186,397,189],{"id":398},"showheader-4",[77,400,401],{},"通用开关控件，控制组件是否在小工具栏展示组件标题，默认为关闭（不展示）。",[186,403,288],{"id":404},"transparent-1",[77,406,291],{},[112,408,410],{"id":409},"趋势hashtags","趋势（hashtags）",[117,412,413],{"id":413},"介绍",[77,415,416],{},"展示（本地/远程）服务器上标签引用趋势。",[117,418,125],{"id":419},"示例-8",[77,421,422],{},[129,423],{"alt":424,"src":425},"hashtags","https://blog-files.101045700.xyz/Fediverse/Sidebar/hashtags.webp",[117,427,135],{"id":428},"设置-8",[186,430,189],{"id":431},"showheader-5",[77,433,192],{},[112,435,437],{"id":436},"时钟clock","时钟（clock）",[117,439,413],{"id":440},"介绍-1",[77,442,443],{},"以“模拟时钟”形式向用户展示用户设备时间。",[117,445,125],{"id":446},"示例-9",[77,448,449],{},[129,450],{"alt":451,"src":452},"clock","https://blog-files.101045700.xyz/Fediverse/Sidebar/clock.webp",[117,454,135],{"id":455},"设置-9",[186,457,288],{"id":458},"transparent-2",[77,460,291],{},[186,462,463],{"id":463},"size",[77,465,466],{},"控制模拟时钟展示大小，有大，中，小三个选项，默认为：中。",[186,468,469],{"id":469},"thickness",[77,471,472],{},"控制模拟时钟指针粗细，有 thin, medium, thick 三个选项，默认为“medium”。",[186,474,475],{"id":475},"graduations",[77,477,478],{},"控制模拟时钟对时间数字的展示形式，有 None（无）, Dots（点）, Numbers（数字），默认为 Numbers（数字）。",[186,480,482],{"id":481},"fadegraduations","fadeGraduations",[77,484,485],{},"开关控件，（测试推测）控制模拟时钟遮罩阴影动态显示，开启时，目前时间无关的时间数值不会显示，默认为开启。",[186,487,489],{"id":488},"sanimation","sAnimati