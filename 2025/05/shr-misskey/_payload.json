[{"data":1,"prerenderedAt":335},["ShallowReactive",2],{"global-music-player":3,"post-/2025/05/shr-misskey":66,"surround-/2025/05/shr-misskey":324},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":300,"date":302,"description":303,"draft":304,"extension":305,"hide-info":304,"image":65,"meta":306,"navigation":308,"path":309,"permalink":65,"published":65,"readingTime":310,"recommend":65,"references":65,"seo":315,"sitemap":316,"stem":317,"subtitle":65,"tags":318,"type":322,"updated":65,"__hash__":323},"content/posts/2025/05/shr-misskey.md","我又用了一段时间 Misskey，发现和 Sharkey 存在一些区别和不足",{"type":70,"value":71,"toc":281},"minimark",[72,76,80,91,94,97,100,103,107,110,113,116,119,122,135,138,143,146,150,153,170,173,176,179,182,185,188,191,195,198,205,209,212,215,218,222,225,228,232,235,238,241,248,254,257,268,271,278],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"最近在 Fediverse 的其他实例（咪社）开了一个自己的“分身”：",[77,81,82,83],{},"账号信息：",[84,85,90],"a",{"href":86,"rel":87,"title":89},"https://misskey.site/@NukiMiku",[88],"nofollow","@NukiMiku","@NukiMiku@misskey.site",[77,92,93],{},"先不解释开这个分身的目的是什么，之前在个人实例一直是使用 Sharkey 作为个人使用程序，借着开分身我也算是重新体验了原汁原味的 Misskey。",[77,95,96],{},"不过在使用之后，却发现与 Sharkey 相比存在了一些区别和不足（可能自己被 Sharkey 惯坏了）。",[73,98,99],{"id":99},"不足",[77,101,102],{},"我所说的任何不足都没有批判 Misskey 的意思，毕竟 Sharkey 是它的分支版本，做出自己的任何更改 Misskey 都没有义务去遵守合并。",[104,105,106],"h3",{"id":106},"缺失直接编辑",[77,108,109],{},"我在发帖的时候有时可能比较着急和欠考虑，发出去之后就可能想改一下。",[77,111,112],{},"于是我打开 Misskey 的帖子额外菜单寻思再“编辑”一下。",[77,114,115],{},"然后我发现只有“删除并编辑”，之前在使用 Sharkey 时是有直接编辑这个选项的。",[77,117,118],{},"没有直接编辑功能分别是存在好处和坏处的：",[77,120,121],{},"好处：",[123,124,125,129],"ul",{},[126,127,128],"li",{},"与其他程序（Gotosocial，Mastodon）的兼容效果会更好，这些程序也没有直接意义上的“编辑”选项。",[126,130,131],{},[132,133,134],"del",{},"不会有别人知道你曾经写错了帖子。",[77,136,137],{},"坏处：",[123,139,140],{},[126,141,142],{},"对于一些发布时间较久的帖子，你如果发现错误想要修改，你再选择“删除并编辑”就有点突兀了。",[77,144,145],{},"总之在这点上个人还是站 Sharkey 这边的，尤其是最近发现自己比较久远帖子有个错误时候（也没有不承认错误“毁尸灭迹”的意思，实际上 Sharkey 会展示这个帖子的历史编辑，当然也可能会略占用更多数据库资源）。",[104,147,149],{"id":148},"缺失单独私密化","缺失单独“私密化”（",[77,151,152],{},"如果说上面没有直接编辑还能找理由的话， Misskey 有关这个帖子没有单独的“私密化”设置我就有点想不通了。",[154,155,157,164,167],"alert",{"type":156},"question",[158,159,161],"template",{"v-slot:title":160},"",[77,162,163],{},"什么是“私密化”？",[77,165,166],{},"似乎是在 Misskey 系列中出现的功能，用户可以把“私密化”标签打到帖子上，然后这个帖子就会进入“私密”状态，只有用户自己才能看到这个帖子的内容。",[77,168,169],{},"不过实际上可能只有 Misskey 系列程序会遵守“私密化”，聊胜于无吧。",[77,171,172],{},"在 Misskey 里只能为某个时间段之前的帖子做出“私密化”，也就是“一私私一片”。",[77,174,175],{},"而在 Sharkey 里，我们就可以单独为帖子“私密化”，而不是群体私密化。",[77,177,178],{},"这点 Misskey 还是不大舒服的其实。",[104,180,181],{"id":181},"缺失注册审批",[77,183,184],{},"这点我其实现在也不是很清楚 Misskey 是否已经完善了，总之 Sharkey 还是有的，当多管理员或者审批组时会很有用，即“开放注册”但需要“填写注册理由”然后等待“管理审核”，这样相对来说比直接使用邀请码注册开放，也更安全。",[73,186,187],{"id":187},"差异",[77,189,190],{},"差异包含了一些“不那么重要”或者说“低使用率”的需求。",[104,192,194],{"id":193},"listenbrainz-集成","ListenBrainz 集成",[77,196,197],{},"个人不是十分了解这个集成方式，同实例的朋友之前有使用过：",[77,199,200,201],{},"贴文：",[84,202,203],{"href":203,"rel":204},"https://circle.tkg3.top/notes/a60lb602rznr000m",[88],[104,206,208],{"id":207},"兼容-mastodon-api","兼容 Mastodon API",[77,210,211],{},"Sharkey 在他们文档里有表示他们兼容 Mastodon 的 API，直观点理解就是可以使用 Mastodon 的客户端程序登陆和管理你的 Sharkey。",[77,213,214],{},"这点个人其实用不大上，为了去验证也拿 Mastodon 的客户端试了下，确实可以登录并且发帖等。",[77,216,217],{},"当然其实还是用处不大，毕竟 Misskey 的特色功能全都无法正常使用，MfM 语法也无法正常显示，插入表情可能也会出现差异问题。",[104,219,221],{"id":220},"像猫一样说话与是猫分开","“像猫一样说话”与“是猫”分开",[77,223,224],{},"其实就是可以设定获得猫耳但不学猫说话（）",[77,226,227],{},"但是 Misskey 确实只能同时获得。",[104,229,231],{"id":230},"ui-风格变化","UI 风格变化",[77,233,234],{},"Sharkey 的风格明显方正，而 Misskey 则是圆润。",[77,236,237],{},"这点影响也不大，但个人应该更喜欢 Sharkey 的风格（在 Sharkey 设置中可以随时切回 Misskey 风格）。",[77,239,240],{},"简单放个对比图（上为 Sharkey，下为 Misskey）",[77,242,243],{},[244,245],"img",{"alt":246,"src":247},"Sharkey Use","https://blog-files.101045700.xyz/Fediverse/SharkeyUse.webp",[77,249,250],{},[244,251],{"alt":252,"src":253},"Misskey Use","https://blog-files.101045700.xyz/Fediverse/MisskeyUse.webp",[73,255,256],{"id":256},"其他小细节差异",[123,258,259,262,265],{},[126,260,261],{},"Sharkey 的发帖时的所有输入框高度大小均可调（包括注解等在内），Misskey 只有部分输入框可调高度（不足）",[126,263,264],{},"可以导入你从 Mastodon 导出的帖子，也包括 Pleroma / Akkoma和 Misskey / Firefish 及其分支、Twitter、Instagram、Facebook，包括附件。",[126,266,267],{},"可以自定义前端使用字体。",[73,269,270],{"id":270},"后言",[77,272,273,274],{},"也有参考 Sharkey 官方列举差异文档：",[84,275,276],{"href":276,"rel":277},"https://docs.joinsharkey.org/docs/comparison/misskey",[88],[77,279,280],{},"目前个人可能还是更为喜欢 Sharkey 的设计，本文将持续更新 Sharkey 和 Misskey 个人使用对比供犹豫使用什么程序的站长和用户参考！",{"title":160,"searchDepth":282,"depth":282,"links":283},4,[284,286,292,298,299],{"id":75,"depth":285,"text":75},2,{"id":99,"depth":285,"text":99,"children":287},[288,290,291],{"id":106,"depth":289,"text":106},3,{"id":148,"depth":289,"text":149},{"id":181,"depth":289,"text":181},{"id":187,"depth":285,"text":187,"children":293},[294,295,296,297],{"id":193,"depth":289,"text":194},{"id":207,"depth":289,"text":208},{"id":220,"depth":289,"text":221},{"id":230,"depth":289,"text":231},{"id":256,"depth":285,"text":256},{"id":270,"depth":285,"text":270},[301],"联邦宇宙","2025-05-22T11:30:00","本文记录了作者重新体验 Misskey 后，相较 Sharkey 感受到的不足：缺少直接编辑、单帖私密化、注册审批；并列出 ListenBrainz 集成、Mastodon API 兼容、UI 风格等差异，倾向继续使用 Sharkey。",false,"md",{"slots":307},{},true,"/2025/05/shr-misskey",{"text":311,"minutes":312,"time":313,"words":314},"7 min read",6.16,369600,1232,{"title":68,"description":303},{"loc":309},"posts/2025/05/shr-misskey",[319,320,321],"Fediverse","Misskey","Sharkey","tech","aO6OaHK_GwInwXT_cVpc3JSjhzVBbnzc9aFiMJMjqYY",[325,330],{"title":326,"path":327,"stem":328,"date":329,"type":322,"children":-1},"Misskey/Sharkey 工具栏：强大且精心的小功能","/2025/05/misskey-sidebar","posts/2025/05/misskey-sidebar","2025-05-20T11:30:00",{"title":331,"path":332,"stem":333,"date":334,"type":322,"children":-1},"《恋爱与选举与巧克力》携带版试玩体验","/2025/05/koichoco-psp","posts/2025/05/koichoco-psp","2025-05-24T08:20:00",1774206435891]