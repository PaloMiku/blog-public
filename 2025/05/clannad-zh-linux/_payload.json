source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":156,"date":158,"description":159,"draft":160,"extension":161,"hide-info":160,"image":162,"meta":163,"navigation":165,"path":166,"permalink":65,"published":65,"readingTime":167,"recommend":65,"references":65,"seo":172,"sitemap":173,"stem":174,"subtitle":65,"tags":175,"type":177,"updated":65,"__hash__":178},"content/posts/2025/05/clannad-zh-linux.md","《Clannad》HD 官方中文版和 Full Voice 汉化版 Linux 运行",{"type":70,"value":71,"toc":148},"minimark",[72,76,86,93,96,99,102,105,112,122,125,128,131,136,144],[73,74,75],"h2",{"id":75},"前言",[77,78,79,80,85],"p",{},"今年也玩了不少 Galgame 了， ",[81,82,84],"tip",{"tip":83},"除了来自 2010 年的《恋爱与选举与巧克力》，但个人之前游玩的又是 25 年的重制版，但没动剧情所以也可以说只是画面重置","不过严格意义上都算是比较新的 Galgame","，最近在朋友建议下打算游玩一款真正“有年代感”的 Galgame。",[87,88],"link-banner",{"banner":89,"description":90,"link":91,"title":92},"https://blog-files.101045700.xyz/backgrounds/Clannad.webp","如果您愿意的话，让我带您去吧，这座小镇，愿望实现的地方……","/games/galgames/clannad","Clannad",[77,94,95],{},"最后选择的是《Clannad》这个代表，个人没有看过它的动画版，思考后是打算先玩游戏版，毕竟游改番基本都是游比较详细吧？",[73,97,98],{"id":98},"版本选择",[77,100,101],{},"PC 版上带有配音的 Clannad Full Voice 于2008年2月29日发售。",[77,103,104],{},"游戏的英文版由 Sekai Project 于2015年11月23日在 Steam 上发行，其中加入 Steam 独占内容团子百科（Dangopedia)，用来向外国人科普在游戏中出现的关于日本的一些名词。",[77,106,107,108],{},"2019年10月17日，以更新的方式添加了简体中文翻译。 ",[109,110,111],"blur",{},"中文版由于引擎由原先的RealLive更换为SiglusEngine的缘故，与英文版存档不互通。",[77,113,114,115,121],{},"个人征询了下对《Clannad》比较了解的朋友 ",[116,117,120],"badge",{"img":118,"link":119},"https://blog.iceyear.eu.org/img/avatar_hu_a03d367ff590d53f.webp","https://blog.iceyear.eu.org","Ice Year"," 的意见，最后选择的版本是官方中文版。",[77,123,124],{},"就是目前的价格让我有些望而却步，所以最终只能选择第三方学习版，史低有钱就去补一份吧。",[73,126,127],{"id":127},"运行情况",[77,129,130],{},"对比一下的话，我去把官中 HD 版和民汉 Full Voice 版本都下载了下来。",[132,133],"pic",{"caption":134,"src":135},"两版本并列！","https://blog-files.101045700.xyz/Galgame/Clannad-Linux.webp",[77,137,138,139,143],{},"目前是都能运行成功，且使用 Steam Linux 默认的",[140,141,142],"code",{"code":142},"Proton 9.0-4","即可。",[132,145],{"caption":146,"src":147},"调整兼容层版本为 Proton 9.0-4","https://blog-files.101045700.xyz/Galgame/Clannad-Proton-9.webp",{"title":149,"searchDepth":150,"depth":150,"links":151},"",4,[152,154,155],{"id":75,"depth":153,"text":75},2,{"id":98,"depth":153,"text":98},{"id":127,"depth":153,"text":127},[157],"旮瘩给木","2025-05-26T17:00:00","本文介绍了《Clannad》HD官方中文版与Full Voice汉化版在Linux下的运行方案；本文记录了使用Proton 9.0-4即可双版本完美启动的实测过程，并对比引擎差异及存档兼容性；本文分享了老Galgame在Linux平台零补丁畅玩的经验，为同人及正版补票玩家提供一站式兼容层设置指南。",false,"md","https://shared.cloudflare.steamstatic.com/store_item_assets/steam/apps/324160/ss_820eb3b554040d3829bbf3b511988480ca2ca521.600x338.jpg?t=1711546691",{"slots":164},{},true,"/2025/05/clannad-zh-linux",{"text":168,"minutes":169,"time":170,"words":171},"2 min read",1.755,105300,351,{"title":68,"description":159},{"loc":166},"posts/2025/05/clannad-zh-linux",[176,92],"Galgame","tech","tHPVdoOhSc4FDgweDJEOAYbMGJRrT4g0VjkNmZBaT_0",[180,185],{"title":181,"path":182,"stem":183,"date":184,"type":177,"children":-1},"《恋爱与选举与巧克力》携带版试玩体验","/2025/05/koichoco-psp","posts/2025/05/koichoco-psp","2025-05-24T08:20:00",{"title":186,"path":187,"stem":188,"date":189,"type":177,"children":-1},"更换网站字体为霞鹜文楷屏幕阅读版（LXGW WenKai Screen）","/2025/05/lxgw-wenkai-web","posts/2025/05/lxgw-wenkai-web","2025-05-28T18:24:26",1773069189167]