[{"data":1,"prerenderedAt":128},["ShallowReactive",2],{"\u002F2025\u002F05\u002Fclannad-zh-linux":3,"surround-\u002F2025\u002F05\u002Fclannad-zh-linux":117},{"id":4,"title":5,"body":6,"categories":93,"date":95,"description":96,"draft":97,"extension":98,"image":99,"meta":100,"navigation":102,"path":103,"permalink":104,"published":104,"readingTime":105,"recommend":104,"references":104,"seo":110,"sitemap":111,"stem":112,"subtitle":104,"tags":113,"type":115,"updated":104,"__hash__":116},"content\u002Fposts\u002F2025\u002F05\u002Fclannad-zh-linux.md","《Clannad》HD 官方中文版和 Full Voice 汉化版 Linux 运行",{"type":7,"value":8,"toc":85},"minimark",[9,13,23,30,33,36,39,42,49,59,62,65,68,73,81],[10,11,12],"h2",{"id":12},"前言",[14,15,16,17,22],"p",{},"今年也玩了不少 Galgame 了， ",[18,19,21],"tip",{"tip":20},"除了来自 2010 年的《恋爱与选举与巧克力》，但个人之前游玩的又是 25 年的重制版，但没动剧情所以也可以说只是画面重置","不过严格意义上都算是比较新的 Galgame","，最近在朋友建议下打算游玩一款真正“有年代感”的 Galgame。",[24,25],"link-banner",{"banner":26,"description":27,"link":28,"title":29},"https:\u002F\u002Fblog-files.101045700.xyz\u002Fbackgrounds\u002FClannad.webp","如果您愿意的话，让我带您去吧，这座小镇，愿望实现的地方……","\u002Fgames\u002Fgalgames\u002Fclannad","Clannad",[14,31,32],{},"最后选择的是《Clannad》这个代表，个人没有看过它的动画版，思考后是打算先玩游戏版，毕竟游改番基本都是游比较详细吧？",[10,34,35],{"id":35},"版本选择",[14,37,38],{},"PC 版上带有配音的 Clannad Full Voice 于2008年2月29日发售。",[14,40,41],{},"游戏的英文版由 Sekai Project 于2015年11月23日在 Steam 上发行，其中加入 Steam 独占内容团子百科（Dangopedia)，用来向外国人科普在游戏中出现的关于日本的一些名词。",[14,43,44,45],{},"2019年10月17日，以更新的方式添加了简体中文翻译。 ",[46,47,48],"blur",{},"中文版由于引擎由原先的RealLive更换为SiglusEngine的缘故，与英文版存档不互通。",[14,50,51,52,58],{},"个人征询了下对《Clannad》比较了解的朋友 ",[53,54,57],"badge",{"img":55,"link":56},"https:\u002F\u002Fblog.iceyear.eu.org\u002Fimg\u002Favatar_hu_a03d367ff590d53f.webp","https:\u002F\u002Fblog.iceyear.eu.org","Ice Year"," 的意见，最后选择的版本是官方中文版。",[14,60,61],{},"就是目前的价格让我有些望而却步，所以最终只能选择第三方学习版，史低有钱就去补一份吧。",[10,63,64],{"id":64},"运行情况",[14,66,67],{},"对比一下的话，我去把官中 HD 版和民汉 Full Voice 版本都下载了下来。",[69,70],"pic",{"caption":71,"src":72},"两版本并列！","https:\u002F\u002Fblog-files.101045700.xyz\u002FGalgame\u002FClannad-Linux.webp",[14,74,75,76,80],{},"目前是都能运行成功，且使用 Steam Linux 默认的",[77,78,79],"code",{"code":79},"Proton 9.0-4","即可。",[69,82],{"caption":83,"src":84},"调整兼容层版本为 Proton 9.0-4","https:\u002F\u002Fblog-files.101045700.xyz\u002FGalgame\u002FClannad-Proton-9.webp",{"title":86,"searchDepth":87,"depth":87,"links":88},"",4,[89,91,92],{"id":12,"depth":90,"text":12},2,{"id":35,"depth":90,"text":35},{"id":64,"depth":90,"text":64},[94],"旮瘩给木","2025-05-26 17:00:00","本文介绍了《Clannad》HD官方中文版与Full Voice汉化版在Linux下的运行方案；本文记录了使用Proton 9.0-4即可双版本完美启动的实测过程，并对比引擎差异及存档兼容性；本文分享了老Galgame在Linux平台零补丁畅玩的经验，为同人及正版补票玩家提供一站式兼容层设置指南。",false,"md","https:\u002F\u002Fshared.cloudflare.steamstatic.com\u002Fstore_item_assets\u002Fsteam\u002Fapps\u002F324160\u002Fss_820eb3b554040d3829bbf3b511988480ca2ca521.600x338.jpg?t=1711546691",{"slots":101},{},true,"\u002F2025\u002F05\u002Fclannad-zh-linux",null,{"text":106,"minutes":107,"time":108,"words":109},"2 min read",1.755,105300,351,{"title":5,"description":96},{"loc":103},"posts\u002F2025\u002F05\u002Fclannad-zh-linux",[114,29],"Galgame","tech","9I01KhhTaU-PwRyaGekujl6J-Hs_BTBkb7NxIeczFTE",[118,123],{"title":119,"path":120,"stem":121,"date":122,"type":115,"children":-1},"《恋爱与选举与巧克力》携带版试玩体验","\u002F2025\u002F05\u002Fkoichoco-psp","posts\u002F2025\u002F05\u002Fkoichoco-psp","2025-05-24 08:20:00",{"title":124,"path":125,"stem":126,"date":127,"type":115,"children":-1},"更换网站字体为霞鹜文楷屏幕阅读版（LXGW WenKai Screen）","\u002F2025\u002F05\u002Flxgw-wenkai-web","posts\u002F2025\u002F05\u002Flxgw-wenkai-web","2025-05-28 18:24:26",1775025021803]