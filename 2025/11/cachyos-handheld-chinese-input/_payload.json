[{"data":1,"prerenderedAt":164},["ShallowReactive",2],{"\u002F2025\u002F11\u002Fcachyos-handheld-chinese-input":3,"surround-\u002F2025\u002F11\u002Fcachyos-handheld-chinese-input":152},{"id":4,"title":5,"body":6,"categories":127,"date":129,"description":130,"draft":131,"extension":132,"image":133,"meta":134,"navigation":136,"path":137,"permalink":138,"published":138,"readingTime":139,"recommend":138,"references":138,"seo":144,"sitemap":145,"stem":146,"subtitle":147,"tags":148,"type":150,"updated":138,"__hash__":151},"content\u002Fposts\u002F2025\u002F11\u002Fcachyos-handheld-chinese-input.md","在 CachyOS Handheld 下恢复 Steam Input 中文输入",{"type":7,"value":8,"toc":119},"minimark",[9,13,17,20,23,26,32,47,57,60,67,75,78,82,93,99,116],[10,11,12],"h2",{"id":12},"前言",[14,15,16],"p",{},"我个人目前在 Steamdeck LCD 上使用的系统并非 SteamOS，而是 CachyOS Handheld，它也是基于 Archlinux 发行的版本，支持 SteamOS 的大部分组件，但是相比 SteamOS 它更为自由一些，软件也是跟随 arch 滚动最新的。",[14,18,19],{},"它不限制系统分区只读，可以自由使用 pacman 和 aur 安装想要的程序。",[14,21,22],{},"不过它毕竟是“仿照” SteamOS 实现的，并且要追求最新组件，所以有些老顽固功能比如 X11 是用 Wayland 替代的，部分应用也不附带，所以经典困扰 Linux 用户的输入法问题又出现了。",[10,24,25],{"id":25},"安装组件",[27,28,29],"alert",{},[14,30,31],{},"只恢复了游戏桌面下的游戏内 Steam Input 输入，且需要强制降级部分组件，请注意！",[14,33,34,35,39,40,43,44],{},"安装",[36,37,38],"code",{"code":38},"ibus","和",[36,41,42],{"code":42},"ibus-pinyin","以及",[36,45,46],{"code":46},"ibus-anthy",[48,49,55],"pre",{"className":50,"code":52,"language":53,"meta":54},[51],"language-bash","paru -S ibus ibus-pinyin ibus-anthy\n","bash","",[36,56,52],{"__ignoreMap":54},[10,58,59],{"id":59},"修改文件",[14,61,62,63,66],{},"打开",[36,64,65],{"code":65},"\u002Fusr\u002Fshare\u002Fgamescope-session-plus\u002Fgamescope-session-plus","，找到以下行并修改：",[48,68,73],{"className":69,"code":71,"language":72,"meta":54},[70],"language-shell","# Input method support if present\nif command -v \u002Fusr\u002Fbin\u002Fibus-daemon >\u002Fdev\u002Fnull; then\n\t\u002Fusr\u002Fbin\u002Fibus-daemon -d -r --panel=disable --emoji-extension=disable # [!code --]\n\t\u002Fusr\u002Fbin\u002Fibus-daemon -d -r --panel=\u002Fusr\u002Flib\u002Fkimpanel-ibus-panel --emoji-extension=disable # [!code ++]\nfi\n","shell",[36,74,71],{"__ignoreMap":54},[14,76,77],{},"重启设备，进入游戏桌面后添加中文键盘即可。",[10,79,81],{"id":80},"输入数字","输入数字？",[14,83,84,85,88,89,92],{},"如果你不降级",[36,86,87],{"code":87},"libxkbcommon","组件，会出现中文输入候选输入后为数字的情况，我们可以使用",[36,90,91],{"code":91},"downgrade","组件来帮助我们快速便捷的降级。",[48,94,97],{"className":95,"code":96,"language":72,"meta":54},[70],"# 安装 downgrade 组件\nparu -S downgrade\n# 降级 libxkbcommon 组件\nsudo downgrade libxkbcommon\n",[36,98,96],{"__ignoreMap":54},[14,100,101,102,104,105,108,109,112,113],{},"稍等片刻，就会出现组件版本列表，我们选择",[36,103,87],{"code":87},"的",[36,106,107],{"code":107},"1.11.0","版本，安装完成后还会提示你是否需要把包加入到",[36,110,111],{"code":111},"IgnorePkg","（后续升级也忽略），我们选择",[36,114,115],{"code":115},"y",[14,117,118],{},"等待降级完成后重启设备，再次尝试应该就是中文了。",{"title":54,"searchDepth":120,"depth":120,"links":121},4,[122,124,125,126],{"id":12,"depth":123,"text":12},2,{"id":25,"depth":123,"text":25},{"id":59,"depth":123,"text":59},{"id":80,"depth":123,"text":81},[128],"技术探索","2025-11-24 01:00:00","本文介绍了在 CachyOS Handheld 系统上恢复 Steam Input 中文输入的解决方案。主要步骤包括安装 `ibus`、`ibus-pinyin` 和 `ibus-anthy` 输入法组件，修改 `\u002Fusr\u002Fshare\u002Fgamescope-session-plus\u002Fgamescope-session-plus` 配置文件，并降级 `libxkbcommon` 组件至 1.11.0 版本以解决中文输入显示为数字的问题。",false,"md","https:\u002F\u002Fcachyos.org\u002F_astro\u002Fhandheld.DYNjpH4Q_Z2fmd8a.webp",{"slots":135},{},true,"\u002F2025\u002F11\u002Fcachyos-handheld-chinese-input",null,{"text":140,"minutes":141,"time":142,"words":143},"3 min read",2.035,122100,407,{"title":5,"description":130},{"loc":137},"posts\u002F2025\u002F11\u002Fcachyos-handheld-chinese-input","Arch 是最好用的 Linux 发行版？",[149],"Linux","tech","Z-x6-jqbdW6udMQ_Qp2hpL4H8-Kk4xbVmx1egfUgy0I",[153,158],{"title":154,"path":155,"stem":156,"date":157,"type":150,"children":-1},"Fedora Cosmic desktop Beta 一日游","\u002F2025\u002F11\u002Ffedora-cosmic-beta","posts\u002F2025\u002F11\u002Ffedora-cosmic-beta","2025-11-13 20:00:00",{"title":159,"path":160,"stem":161,"date":162,"type":163,"children":-1},"Riddle Joker：剧情不足，人设也不足","\u002F2025\u002F11\u002Friddle-joker","posts\u002F2025\u002F11\u002Friddle-joker","2025-11-24 21:00:00","story",1774773593244]