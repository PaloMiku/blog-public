[{"data":1,"prerenderedAt":194},["ShallowReactive",2],{"global-music-player":3,"post-/2025/11/fedora-cosmic-beta":66,"surround-/2025/11/fedora-cosmic-beta":182},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":159,"date":161,"description":162,"draft":163,"extension":164,"hide-info":163,"image":65,"meta":165,"navigation":167,"path":168,"permalink":65,"published":65,"readingTime":169,"recommend":65,"references":65,"seo":174,"sitemap":175,"stem":176,"subtitle":177,"tags":178,"type":180,"updated":65,"__hash__":181},"content/posts/2025/11/fedora-cosmic-beta.md","Fedora Cosmic desktop Beta 一日游",{"type":70,"value":71,"toc":152},"minimark",[72,76,80,83,86,89,92,95,98,107,110,113,116,127,130,136,139,142],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"最近看到 Cosmic desktop 发版 Beta 1 了，之前就对这个桌面环境很是感兴趣，毕竟它汇聚了以下瞩目特性：Rust 开发，平铺和窗口自由切换，占用资源小等等。",[77,81,82],{},"个人一直在 Fedora 上使用 KDE Plasma 6 桌面，一直在筹划更换 Cosmic，只是之前的 Alpha 版本还达不到可以日用的程度，目前既然发版 Beta 1 了，那么它的日用性怎么样了呢？",[77,84,85],{},"先说总结：能用，但是细节还需要打磨，目前已经可以达到基本日用的程度。",[77,87,88],{},"不过还是要先吐槽一下，国内应用的 Linux 版对规范支持是比较一般的，在个人实测中，比如 QQ 和微信都不能正确跟随 Cosmic 设置的 125% 缩放，需要自己在程序变量让他们手动 1.25x 缩放。",[77,90,91],{},"当然 Cosmic 的合成器也确实欠打磨，目前 Wayland 到 XWayland 应用也不能互相拖放文件，海外应用这边会好一些，缩放问题基本比较少。",[73,93,94],{"id":94},"安装",[77,96,97],{},"在 Fedora 上体验 Cosmic 有两种方式：从存储库安装 cosmic-desktop 或者选择预装的 Fedora Cosmic Spin（或 Atomic），但是 Fedora Cosmic Spin 个人体验预装似乎有些旧了，安装完后桌面环境是 Cosmic Alpha 时期的英文且还有异常卡顿的 Bug,中文用户的体验很显然是不大行的。",[77,99,100,101],{},"当然预装 Cosmic 的系统有很多，可以参见：",[102,103,104],"a",{"href":104,"rel":105},"https://system76.com/cosmic/download",[106],"nofollow",[77,108,109],{},"包括 Arch，Nix，openSUSE 在内的流行发行版也有预装提供。或者你也可以选择 Cosmic 官方的 Pop OS Beta，它是基于 Ubuntu 24.04 LTS 的，我个人目前也不用 deb 系发行版，所以还是选择 Fedora。",[77,111,112],{},"那么 Fedora 预装不好用，我们就只能在已有 Fedora 上自己装了，我直接在我的 Fedora KDE 版上执行安装指令也是可以安装的，KDE 和 Cosmic 可以双持，在 SDDM 登录切换就可以了。",[77,114,115],{},"首先先要确保系统软件包是最新的：",[117,118,124],"pre",{"className":119,"code":121,"language":122,"meta":123},[120],"language-bash","sudo dnf update\nsudo dnf upgrade --refresh\n","bash","",[125,126,121],"code",{"__ignoreMap":123},[77,128,129],{},"然后执行以下指令从 Fedora 官方存储库安装 Cosmic Desktop 和 Cosmic 配套软件（可选）",[117,131,134],{"className":132,"code":133,"language":122,"meta":123},[120],"sudo dnf group install \"cosmic-desktop\"\nsudo dnf group install \"cosmic-desktop-apps\"\n",[125,135,133],{"__ignoreMap":123},[77,137,138],{},"然后登出就可以在 SDDM 选择 COSMIC 桌面环境登录了。",[73,140,141],{"id":141},"常见问题",[143,144,145,149],"ul",{},[146,147,148],"li",{},"应用缩放问题：上面已经提到过了，使用环境变量强制缩放即可。",[146,150,151],{},"中文输入：使用 Fcitx5 加环境变量可以使用，iBus 个人测试似乎无法使用，听说 Cosmic 开发者在重写类似 GNOME 的输入法实现。",{"title":123,"searchDepth":153,"depth":153,"links":154},4,[155,157,158],{"id":75,"depth":156,"text":75},2,{"id":94,"depth":156,"text":94},{"id":141,"depth":156,"text":141},[160],"技术探索","2025-11-13T20:00:00","Cosmic Desktop Beta 1 已可在 Fedora 上日常“基本可用”，但细节仍显粗糙。Fedora 上官方仓库 dnf group install \"cosmic-desktop\" 即可与 KDE 双持；Fedora Cosmic Spin 版本旧、中文支持差，不推荐。中文输入目前仅 Fcitx5 可用，iBus 失效；开发者正重写输入法框架。",false,"md",{"slots":166},{},true,"/2025/11/fedora-cosmic-beta",{"text":170,"minutes":171,"time":172,"words":173},"4 min read",3.25,195000,650,{"title":68,"description":162},{"loc":168},"posts/2025/11/fedora-cosmic-beta","平铺窗口缝合ing",[179],"Linux","tech","Oom0EBe3ZD_adSD5Zy0s-k8QqxY4V7jgyekD0le8hJ0",[183,189],{"title":184,"path":185,"stem":186,"date":187,"type":188,"children":-1},"博客～真周年随笔（大概是一周年）","/2025/11/blog-1th-note","posts/2025/11/blog-1th-note","2025-11-04T08:00:00","story",{"title":190,"path":191,"stem":192,"date":193,"type":180,"children":-1},"在 CachyOS Handheld 下恢复 Steam Input 中文输入","/2025/11/cachyos-handheld-chinese-input","posts/2025/11/cachyos-handheld-chinese-input","2025-11-24T01:00:00",1773069187982]