[{"data":1,"prerenderedAt":1507},["ShallowReactive",2],{"\u002F2025\u002F12\u002Foss-prepare-list":3,"surround-\u002F2025\u002F12\u002Foss-prepare-list":1495},{"id":4,"title":5,"body":6,"categories":1468,"date":1470,"description":1471,"draft":1472,"extension":1473,"image":1474,"meta":1475,"navigation":1477,"path":1478,"permalink":1479,"published":1479,"readingTime":1480,"recommend":1485,"references":1479,"seo":1486,"sitemap":1487,"stem":1488,"subtitle":1489,"tags":1490,"type":1493,"updated":1479,"__hash__":1494},"content\u002Fposts\u002F2025\u002F12\u002Foss-prepare-list.md","国内外主流对象存储价格对比",{"type":7,"value":8,"toc":1437},"minimark",[9,13,17,20,26,29,32,35,67,70,73,76,79,82,85,88,93,101,110,113,120,127,130,174,177,180,183,190,263,266,270,273,276,283,286,289,331,335,338,345,348,411,414,418,421,427,430,437,441,444,450,453,492,495,538,541,544,547,550,553,561,564,568,571,665,668,671,810,814,817,824,827,834,838,841,844,847,850,853,856,862,865,868,1026,1029,1032,1036,1039,1042,1049,1052,1111,1123,1127,1138,1141,1144,1151,1154,1161,1164,1168,1174,1180,1183,1186,1192,1195,1199,1202,1208,1211,1214,1217,1221,1224,1230,1249,1252,1255,1259,1270,1277,1280,1283,1286,1289],[10,11,12],"h2",{"id":12},"前言",[14,15,16],"p",{},"在很多 Blog 交流群有时能看到有些博主们在商量自己网站在用什么 CDN，什么 OSS 存储啊，也互相夸赞你的站打开有多快，图片加载有多快等。",[14,18,19],{},"对于 OSS 存储其实在个人以往的《自建一个 Fediverse 实例，我们需要准备什么？》文章中对此已经略有提及，也要感谢猫猫博客站长 Firefly 的博文整理资料参考。",[21,22],"link-banner",{"banner":23,"link":24,"title":25},"https:\u002F\u002Fengagemedia.org\u002Fwp-content\u002Fuploads\u002F2020\u002F07\u002FFediverse-3D_logojpg.jpg","\u002F2025\u002F06\u002Fself-fediverse-prepare","自建一个 Fediverse 实例，我们需要准备什么？",[14,27,28],{},"不过比起当时的整理来说，目前已经有了些许形势变化，所以还是可以再来回过头看看各家存储的新变化的。",[10,30,31],{"id":31},"须知",[14,33,34],{},"本文介绍以下情况：",[36,37,38,46,52,55,58,61,64],"ul",{},[39,40,41,42],"li",{},"假设用户使用 100GB 标准非归档等存储，会列出",[43,44,45],"strong",{},"选择购买对应存储资源包的情况",[39,47,48,49],{},"假如出站流量也为 100GB 的情况，",[43,50,51],{},"也同样列出购买资源包的情况",[39,53,54],{},"对于国内服务商，也会尽量介绍中国大陆和其他地区计费情况，单位会使用人民币（￥），对于海外服务商则以他们在定价页面标出的货币为准，毕竟汇率也是具有时效性的。",[39,56,57],{},"也可能包括其他优惠可能性等列出，但可能具有时效性",[39,59,60],{},"所有计费等资料均以本文成文时最新资料为准，后续更新不一定及时，个人有更新也会及时在文章内标示。",[39,62,63],{},"如果对象存储方案提供商提供的起步方案高于 100GB，则会灵活变化。",[39,65,66],{},"不列出国内服务商按量计费价格，因为各家政策和实际使用情况实在是乱糟糟，海外按情况给出。",[14,68,69],{},"有人可能会问：“你 100GB 是不是设的门槛太高了？很多个人博客可能压根到不了 100GB。”",[14,71,72],{},"实话说这已经是个人感觉比较好计算（各家基本都有 100GB 标准，低于 100GB 就乱七八糟的了）和未来扩张性比较灵活的一个门槛了，如果你的需求更低还是建议你自行查看他们相关文档。",[14,74,75],{},"注意下文购买资源包的价格都是一个月的情况，且本文只列出提供预付费资源包的价格，按量计费请查看官方文档或价格计算器。",[10,77,78],{"id":78},"国内服务商",[14,80,81],{},"曾经谈起国内 OSS 那是无不色变，“一夜一套房”的梦魇可以说缠绕很多包括我在内的站长许久，那么现在好了很多吗？好像也没有。",[14,83,84],{},"实话说如果你不需要对存储有那么敏感的读写速度要求和稳定性，尤其是个人博客站长，还是适当委屈下访客，担心下自己的钱包选择海外对象存储厂商吧，国内的性价比还是难说的。",[14,86,87],{},"尤其是现在 EdgeOne 免费后，有些站长使用它反代海外对象存储，理论上也算是一种好办法。",[89,90,92],"h3",{"id":91},"腾讯云-cos","腾讯云 COS",[14,94,95,96,100],{},"首先先请出 EdgeOne 的缔造者，",[97,98,99],"del",{},"最大良心云","腾讯云出场。",[14,102,103,104],{},"腾讯云 COS 全文档页面：",[105,106,107],"a",{"href":107,"rel":108},"https:\u002F\u002Fcloud.tencent.com\u002Fdocument\u002Fproduct\u002F436",[109],"nofollow",[14,111,112],{},"实话说对于国内对象存储的价格和其他评价是比较难以客观的，毕竟它们确实有很多乱七八糟的活动和资源包以及免费（试用）额度在内的各种情况，包括猫猫博客的站长在个人相关文章中也没有直接把它加入比较，因为活动和变化可能都太多了，所以我们在本文的比较计划是对于它们的直接计费做出比较，活动等为辅。",[14,114,115,116,119],{},"首先腾讯云 COS 在免费额度上，为所有新用户（即首次开通 COS 服务的个人和企业用户）提供一定量的免费额度资源包，可用于抵扣",[43,117,118],{},"标准存储类型","的数据产生的标准存储容量费用。",[14,121,122,123],{},"免费额度文档页面：",[105,124,125],{"href":125,"rel":126},"https:\u002F\u002Fcloud.tencent.com\u002Fdocument\u002Fproduct\u002F436\u002F6240",[109],[14,128,129],{},"具体的话就是（以二进制计算，例如1TB = 1024GB）：",[131,132,133,149],"table",{},[134,135,136],"thead",{},[137,138,139,143,146],"tr",{},[140,141,142],"th",{},"面向对象",[140,144,145],{},"免费额度资源包",[140,147,148],{},"有效期",[150,151,152,164],"tbody",{},[137,153,154,158,161],{},[155,156,157],"td",{},"个人用户",[155,159,160],{},"50GB标准存储容量包",[155,162,163],{},"6个月（180天）",[137,165,166,169,172],{},[155,167,168],{},"企业用户",[155,170,171],{},"1TB标准存储容量包",[155,173,163],{},[14,175,176],{},"然后什么公有云地域免费，怎么领取balabala等请查看官方文档介绍，本文不做赘述。",[14,178,179],{},"首先我们知道，大部分运营商的政策都是按量计费，腾讯云也是一样的，就算是资源包预付费，也是在超出用量后转按量计费，不盯紧点一夜一套房不是梦。",[14,181,182],{},"首先假如我们在存储和流量上都选择半年 100GB 资源包，那么计费情况会如下所示（划线价格为他们标出的原价，定价页面也有提供折扣情况）：",[14,184,185,186],{},"腾讯云 COS 定价：",[105,187,188],{"href":188,"rel":189},"https:\u002F\u002Fbuy.cloud.tencent.com\u002Fprice\u002Fcos",[109],[131,191,192,217],{},[134,193,194],{},[137,195,196,199,202,205,208,211,214],{},[140,197,198],{},"存储地区",[140,200,201],{},"存储包规格",[140,203,204],{},"存储包价格",[140,206,207],{},"流量地区",[140,209,210],{},"流量包规格",[140,212,213],{},"流量包价格",[140,215,216],{},"最终价格",[150,218,219,242],{},[137,220,221,224,227,230,233,236,239],{},[155,222,223],{},"中国大陆通用",[155,225,226],{},"标准存储容量包 100GB",[155,228,229],{},"8.14",[155,231,232],{},"中国大陆",[155,234,235],{},"外网下行流量包 100GB",[155,237,238],{},"34.5",[155,240,241],{},"42.64",[137,243,244,247,249,252,255,257,260],{},[155,245,246],{},"中国香港和海外通用",[155,248,226],{},[155,250,251],{},"9.38",[155,253,254],{},"中国香港和海外",[155,256,235],{},[155,258,259],{},"45.54",[155,261,262],{},"54.92",[14,264,265],{},"什么，你说中国大陆到海外或者海外到中国大陆流量？那可真是难计算了。",[89,267,269],{"id":268},"阿里云-oss","阿里云 OSS",[14,271,272],{},"实话说我以前对阿里云的好感还可以，但是现在是真的不算很好，尤其是在整理本篇文章的时候，阿里云的对象存储文档写的相比腾讯云的文档真的只能说毫无美感。",[14,274,275],{},"尤其是很多页面都有 SPM 追踪统计，我就更无语了，价格计算器在移除 SPM 统计以后甚至不能正常访问，所以本文无法给出 OSS 价格计算器的链接。",[14,277,278,279],{},"官方概述页面：",[105,280,281],{"href":281,"rel":282},"https:\u002F\u002Fwww.aliyun.com\u002Fproduct\u002Foss",[109],[14,284,285],{},"总之快速过一下，有关阿里云免费试用额度这块他们是没有明确写在文档页面里的，所以我也不做有效参考资料加入本文。",[14,287,288],{},"资源包只有大陆地区支持购买。",[131,290,291,309],{},[134,292,293],{},[137,294,295,297,299,301,303,305,307],{},[140,296,198],{},[140,298,201],{},[140,300,204],{},[140,302,207],{},[140,304,210],{},[140,306,213],{},[140,308,216],{},[150,310,311],{},[137,312,313,315,318,321,323,325,328],{},[155,314,232],{},[155,316,317],{},"标准 - 本地冗余存储包 100GB",[155,319,320],{},"11",[155,322,232],{},[155,324,235],{},[155,326,327],{},"49",[155,329,330],{},"60",[89,332,334],{"id":333},"华为云-obs","华为云 OBS",[14,336,337],{},"华为云比起前两家来说，要论个人体验似乎也不能说多么好，但个人也算部分服务长久用户了，包括备案也是在华为云办理的，他们比起腾讯云的文档略逊一筹，但比起阿里云的文档来说那是比较好了。",[14,339,340,341],{},"官方文档页面：",[105,342,343],{"href":343,"rel":344},"https:\u002F\u002Fsupport.huaweicloud.com\u002Fobs\u002Findex.html",[109],[14,346,347],{},"话说它有免费试用吗？没用过不知道，总之文档里没写，资源包也没有前两家那么通用，需要按地域购买。",[131,349,350,368],{},[134,351,352],{},[137,353,354,356,358,360,362,364,366],{},[140,355,198],{},[140,357,201],{},[140,359,204],{},[140,361,207],{},[140,363,210],{},[140,365,213],{},[140,367,216],{},[150,369,370,391],{},[137,371,372,375,378,381,383,386,388],{},[155,373,374],{},"华北-北京4",[155,376,377],{},"标准单 AZ 存储包 100GB",[155,379,380],{},"9",[155,382,374],{},[155,384,385],{},"公网流出流量包 100GB",[155,387,327],{},[155,389,390],{},"58",[137,392,393,396,398,401,403,405,408],{},[155,394,395],{},"中国-香港",[155,397,377],{},[155,399,400],{},"14",[155,402,395],{},[155,404,385],{},[155,406,407],{},"79",[155,409,410],{},"93",[14,412,413],{},"说实话这个香港流量价格确实有点让人惊掉下巴。",[89,415,417],{"id":416},"又拍云-uss","又拍云 USS",[14,419,420],{},"相信很多博主了解到它还是“又拍云联盟”，到现在为止也可以申请，提供 CDN 和云存储的高额代金券（免费获取每月 10GB 存储空间 + 15GB 流量，需要每年手动申请），只需要页脚挂一个 footer 就行了。",[14,422,278,423],{},[105,424,425],{"href":425,"rel":426},"https:\u002F\u002Fwww.upyun.com\u002Fproducts\u002Ffile-storage",[109],[14,428,429],{},"超出这个额度的计费就不是很划算了，也同样是超额转按量，所以被刷了也是要注意的，他们也没有明确的价格文档或者资源包售卖，只有一个价格计算器。",[14,431,432,433],{},"价格计算器：",[105,434,435],{"href":435,"rel":436},"https:\u002F\u002Fwww.upyun.com\u002Fpricing",[109],[89,438,440],{"id":439},"七牛云-kodo","七牛云 Kodo",[14,442,443],{},"大不大小不小我也不好说的厂商。",[14,445,278,446],{},[105,447,448],{"href":448,"rel":449},"https:\u002F\u002Fwww.qiniu.com\u002Fproducts\u002Fkodo",[109],[14,451,452],{},"七牛云也有免费额度，表格如下：",[131,454,455,474],{},[134,456,457],{},[137,458,459,462,465,468,471],{},[140,460,461],{},"标准存储每月免费空间",[140,463,464],{},"标准存储每月免费 CDN 回源流量",[140,466,467],{},"标准存储每月免费请求 PUT\u002FDELETE",[140,469,470],{},"标准存储每月免费读取请求 GET",[140,472,473],{},"每月免费上传流量",[150,475,476],{},[137,477,478,481,483,486,489],{},[155,479,480],{},"10GB",[155,482,480],{},[155,484,485],{},"10万次",[155,487,488],{},"100万次",[155,490,491],{},"无上限",[14,493,494],{},"支持预购买资源包方式，超出资源包的部分一样需要按量付费，只有中国大陆通用的资源包销售，可以选择是当月 1 日生效还是次月 1 日生效：",[131,496,497,515],{},[134,498,499],{},[137,500,501,503,505,507,509,511,513],{},[140,502,198],{},[140,504,201],{},[140,506,204],{},[140,508,207],{},[140,510,210],{},[140,512,213],{},[140,514,216],{},[150,516,517],{},[137,518,519,521,524,527,529,532,535],{},[155,520,232],{},[155,522,523],{},"标准存储空间 100GB",[155,525,526],{},"9.8",[155,528,232],{},[155,530,531],{},"外网流出流量100GB",[155,533,534],{},"28.5",[155,536,537],{},"38.3",[89,539,540],{"id":540},"雨云对象存储",[14,542,543],{},"实话说，我个人是比较支持新兴 IDC 的，理论上只要保证折腾备份，就能便宜（",[14,545,546],{},"当然你要说稳定性的话，个人了解雨云崩过几次，稳定性肯定是不如大厂的。",[14,548,549],{},"对象存储后台也不能说多么好用，不过也兼容 AWS S3，功能持续开发不好说。",[14,551,552],{},"最大的好处是他们确实是真的按资源包计费，弹性计费功能是可开关的，关闭弹性计费超额就停止服务而不是继续出账了。",[14,554,555,556],{},"雨云对象存储链接（恰饭.jpg）：",[105,557,560],{"href":558,"rel":559},"https:\u002F\u002Fwww.rainyun.com\u002Fros\u002Fpalomiku_",[109],"前往雨云官网，带AFF",[14,562,563],{},"他们在本文完稿时有两个地区：浙江宁波和湖北十堰，我们很难说价格问题，因为两边提供的资源包是规格不一的，不过可以稍微简单列举一下。",[565,566,567],"h4",{"id":567},"浙江宁波",[14,569,570],{},"地区介绍为高带宽，低延迟 SSD（固态硬盘），读写应该更快，稳定性就不好说了。",[131,572,573,586],{},[134,574,575],{},[137,576,577,580,583],{},[140,578,579],{},"存储空间 + 流量",[140,581,582],{},"每日平均费用 (元)",[140,584,585],{},"每月费用 (元\u002F月)",[150,587,588,599,610,621,632,643,654],{},[137,589,590,593,596],{},[155,591,592],{},"10G 存储 + 50G 流量",[155,594,595],{},"0.3",[155,597,598],{},"10",[137,600,601,604,607],{},[155,602,603],{},"20G 存储 + 100G 流量",[155,605,606],{},"0.5",[155,608,609],{},"15",[137,611,612,615,618],{},[155,613,614],{},"40G 存储 + 200G 流量",[155,616,617],{},"0.8",[155,619,620],{},"24",[137,622,623,626,629],{},[155,624,625],{},"80G 存储 + 400G 流量",[155,627,628],{},"1.5",[155,630,631],{},"45",[137,633,634,637,640],{},[155,635,636],{},"200G 存储 + 1T 流量",[155,638,639],{},"3.3",[155,641,642],{},"100",[137,644,645,648,651],{},[155,646,647],{},"400G 存储 + 2T 流量",[155,649,650],{},"6",[155,652,653],{},"180",[137,655,656,659,662],{},[155,657,658],{},"1T 存储 + 4T 流量",[155,660,661],{},"12.9",[155,663,664],{},"388",[565,666,667],{"id":667},"湖北十堰",[14,669,670],{},"地区介绍为超大容量，那与前文相比肯定是机械盘了，带宽就不好说了。",[131,672,673,684],{},[134,674,675],{},[137,676,677,680,682],{},[140,678,679],{},"套餐类型",[140,681,582],{},[140,683,585],{},[150,685,686,695,706,717,727,738,749,760,769,778,788,799],{},[137,687,688,691,693],{},[155,689,690],{},"50G 存储 + 流量",[155,692,606],{},[155,694,609],{},[137,696,697,700,703],{},[155,698,699],{},"100G 存储 + 流量",[155,701,702],{},"0.7",[155,704,705],{},"20",[137,707,708,711,714],{},[155,709,710],{},"200G 存储 + 流量",[155,712,713],{},"1.3",[155,715,716],{},"40",[137,718,719,722,724],{},[155,720,721],{},"500G 存储 + 流量",[155,723,639],{},[155,725,726],{},"98",[137,728,729,732,735],{},[155,730,731],{},"1T 存储 + 流量",[155,733,734],{},"6.6",[155,736,737],{},"198",[137,739,740,743,746],{},[155,741,742],{},"2T 存储 + 流量",[155,744,745],{},"9.6",[155,747,748],{},"288",[137,750,751,754,757],{},[155,752,753],{},"100G 存储 + 25G 流量",[155,755,756],{},"0.4",[155,758,759],{},"13",[137,761,762,765,767],{},[155,763,764],{},"200G 存储 + 50G 流量",[155,766,702],{},[155,768,705],{},[137,770,771,774,776],{},[155,772,773],{},"400G 存储 + 100G 流量",[155,775,713],{},[155,777,716],{},[137,779,780,783,785],{},[155,781,782],{},"1T 存储 + 250G 流量",[155,784,639],{},[155,786,787],{},"99",[137,789,790,793,796],{},[155,791,792],{},"2T 存储 + 500G 流量",[155,794,795],{},"6.7",[155,797,798],{},"200",[137,800,801,804,807],{},[155,802,803],{},"4T 存储 + 1T 流量",[155,805,806],{},"13.3",[155,808,809],{},"399",[89,811,813],{"id":812},"缤纷云-s4","缤纷云 S4",[14,815,816],{},"新兴产品，个人目前用作国内服务部分数据备份，毕竟有相对还可以的免费额度（比较复杂的50+30，建议好好看看额度文档），和雨云对比来说，它支持的东西比雨云更多，API 也更完善一些，也兼容 AWS S3，但是只支持按量计费模式，也就是说被刷了也是会超额欠费的，后台并没有用量封顶机制。",[14,818,819,820],{},"官方文档地址：",[105,821,822],{"href":822,"rel":823},"https:\u002F\u002Fdocs.bitiful.com\u002Fbitiful-s4\u002Fintro",[109],[14,825,826],{},"实话说文档写的还不错，但是它们在一些奇奇怪怪的地方上还是问题颇多，在按量计费上是使用的阶梯式计费，其实你也可以看出来是服务大客户的，上万的大客户理论上可以降低成本，不上不下的小用户其实就不大推荐用了。",[14,828,829,830],{},"服务态度比较...个人之前在微信交流群沟通时候印象也不是很好，可以查看下 v2ex 讨论帖：",[105,831,832],{"href":832,"rel":833},"https:\u002F\u002Fwww.v2ex.com\u002Ft\u002F1006572",[109],[89,835,837],{"id":836},"_123-网盘会员直链","123 网盘会员直链",[14,839,840],{},"这种存储方式作为博客直链图床和文件存储的话，其实是一种很新颖的方式，它没有 OSS 式的管理方式（没有 S3），于个人来说性价比也很玄，取决于你对 123 网盘的粘性和会员选择，可以说是买 123 网盘会员的附赠品（只有会员才能使用直链功能和购买直链流量，一年有效期）",[14,842,843],{},"我身边有朋友在使用这种方式作为站点图床，所以干脆也推荐一下吧，之前个人也对此有一定了解。",[14,845,846],{},"功能来说也有 URL 和 Referer 鉴权，文件预览，IP 黑名单，自定义域名（增值服务，需备案，且 HTTPS 是按请求增值服务），静态网页托管，远程鉴权。",[14,848,849],{},"个人推荐购买了 123 网盘会员的用户作为附赠甜品可以使用本功能，在保持会员身份的前提下直链价格还算可以，稳定性咱也不好说，不过 123 背后其实是全国也算有名的大厂，不一定很差。",[14,851,852],{},"如果你是看上他们直链而想要购买的话...见仁见智吧，VIP 会员连续包月要 ￥25 一个月呢，如果对网盘使用需求没那么大不是很建议购买。",[14,854,855],{},"你买了会员就是 20TB 云盘空间了（还能成长，每月成长 800GB，最高成长到 100TB），然后就可以额外购买直链流量包（实际上不单独购买也有 10GB\u002F月的直链流量包，SVIP 会员则是 100GB\u002F月直链流量包）",[14,857,858,859],{},"直链流量包最低 1TB 起售，价格 ￥80，有效期一年，",[43,860,861],{},"且需要是会员身份才能使用直链功能。",[89,863,864],{"id":864},"国内存储资源包方案价格对比",[14,866,867],{},"我们列出已有资源包计费的服务商最终价格对比，均为 100GB 存储包加 100GB 流量包每月，价格按照从低到高排序，没有资源包的服务商暂不列出。",[131,869,870,891],{},[134,871,872],{},[137,873,874,877,879,881,883,885,887,889],{},[140,875,876],{},"服务提供商",[140,878,198],{},[140,880,201],{},[140,882,204],{},[140,884,207],{},[140,886,210],{},[140,888,213],{},[140,890,216],{},[150,892,893,914,933,952,970,989,1008],{},[137,894,895,898,900,903,906,908,910,912],{},[155,896,897],{},"雨云",[155,899,667],{},[155,901,902],{},"100GB",[155,904,905],{},"统一",[155,907,667],{},[155,909,902],{},[155,911,905],{},[155,913,705],{},[137,915,916,919,921,923,925,927,929,931],{},[155,917,918],{},"七牛云",[155,920,232],{},[155,922,523],{},[155,924,526],{},[155,926,232],{},[155,928,531],{},[155,930,534],{},[155,932,537],{},[137,934,935,938,940,942,944,946,948,950],{},[155,936,937],{},"腾讯云",[155,939,223],{},[155,941,226],{},[155,943,229],{},[155,945,232],{},[155,947,235],{},[155,949,238],{},[155,951,241],{},[137,953,954,956,958,960,962,964,966,968],{},[155,955,937],{},[155,957,246],{},[155,959,226],{},[155,961,251],{},[155,963,254],{},[155,965,235],{},[155,967,259],{},[155,969,262],{},[137,971,972,975,977,979,981,983,985,987],{},[155,973,974],{},"华为云",[155,976,374],{},[155,978,377],{},[155,980,380],{},[155,982,374],{},[155,984,385],{},[155,986,327],{},[155,988,390],{},[137,990,991,994,996,998,1000,1002,1004,1006],{},[155,992,993],{},"阿里云",[155,995,232],{},[155,997,317],{},[155,999,320],{},[155,1001,232],{},[155,1003,235],{},[155,1005,327],{},[155,1007,330],{},[137,1009,1010,1012,1014,1016,1018,1020,1022,1024],{},[155,1011,974],{},[155,1013,395],{},[155,1015,377],{},[155,1017,400],{},[155,1019,395],{},[155,1021,385],{},[155,1023,407],{},[155,1025,410],{},[10,1027,1028],{"id":1028},"海外服务商",[14,1030,1031],{},"实话说如果真的没有硬性需求，海外其实挺合适了，毕竟很多都没有国内这么复杂的计费策略，也有很多都没有流出流量费用，所以海外这里我们在计算每个月 100GB 存储可能产生的成本时候就容易了不少。",[89,1033,1035],{"id":1034},"cloudflare-r2","Cloudflare R2",[14,1037,1038],{},"赛博活佛说是，当然 Cloudflare R2 在小需求上确实价格优势还不错，而且能享受 Cloudflare CDN 的便捷（需要域名托管在 Cloudflare）。",[14,1040,1041],{},"兼容 AWS S3 的对象存储，基准功能不是很多，需要绑定域名配合 Cloudflare CDN 的策略配置食用，上限肯定是很高的。",[14,1043,1044,1045],{},"文档页面：",[105,1046,1047],{"href":1047,"rel":1048},"https:\u002F\u002Fdevelopers.cloudflare.com\u002Fr2",[109],[14,1050,1051],{},"也有比较不错的免费额度（标准存储，不是归档存储）：",[131,1053,1054,1064],{},[134,1055,1056],{},[137,1057,1058,1061],{},[140,1059,1060],{},"类型",[140,1062,1063],{},"额度",[150,1065,1066,1074,1086,1097],{},[137,1067,1068,1071],{},[155,1069,1070],{},"存储额度",[155,1072,1073],{},"10GB（所有存储桶的总额）",[137,1075,1076,1083],{},[155,1077,1078],{},[1079,1080,1082],"tip",{"tip":1081},"即 A 类操作，常见于上传和列出存储列表等操作","Class A Operations",[155,1084,1085],{},"每月前一千万次请求免费",[137,1087,1088,1094],{},[155,1089,1090],{},[1079,1091,1093],{"tip":1092},"即 B 类操作，常见于下载文件等操作","Class B Operations",[155,1095,1096],{},"每月前一亿次请求免费",[137,1098,1099,1105],{},[155,1100,1101],{},[1079,1102,1104],{"tip":1103},"也就是下载文件时产生的下载流量","出口流量",[155,1106,1107],{},[1079,1108,1110],{"tip":1109},"从 R2 直接出站，包括通过Workers API、S3 API 以及 r2.dev 域名，都不会产生数据出站（Egress）费用，是免费的。但如果你将其他按用量计费的服务连接到R2存储桶，可能会被这些服务收费。","免费",[14,1112,1113,1114,1118,1119,1122],{},"实话说 R2 的请求额度还算慷慨，所以我们可以假设每月免费请求数没超额的情况下使用 R2 存储 100GB 数据的成本是 ",[1115,1116,1117],"code",{"code":1117},"0.015 × 90","（10GB 免费），为 ",[1115,1120,1121],{"code":1121},"1.35"," 美元每月。",[89,1124,1126],{"id":1125},"blackblaze-b2","Blackblaze B2",[14,1128,1129,1130,1133,1134,1137],{},"单论存储费用其实比 Cloudflare R2 价格低，每 GB 存储 ",[1115,1131,1132],{"code":1132},"0.006"," 美元，也有 10GB 的免费额度，但是出口流量直接用是不全免费的，免费流量为你的存储量三倍（例如存储了 100GB 数据，则出口 300GB 流量是免费的），超额后为每 GB ",[1115,1135,1136],{"code":1136},"0.01"," 美元，并不便宜。",[14,1139,1140],{},"但是有个东西叫带宽联盟，是 Cloudflare 发起的，真是赛博活佛了，如果你给它套上 Cloudflare CDN，对象存储的流量从 Cloudflare 流出，则是免费的。",[14,1142,1143],{},"理论上是不是这样看比 Cloudflare R2 更划算？先别急着高兴，这就要请出第三个主角 ABC 请求了。",[14,1145,1146,1147,1150],{},"虽然 B2 的 A 类请求（上传）是免费的，但关键的 B\u002FC 类请求（下载和列出文件列表，分开计算）免费额度没有 Cloudflare R2 那么慷慨，甚至可以说少的可怜，仅有 2500 次每日，超出的 B\u002FC 请求会按每 1000 次请求 ",[1115,1148,1149],{"code":1149},"0.0004"," 美元计费。",[14,1152,1153],{},"所以你也能看出它的一个应用场景了：下载站和个人备份，这是典型低请求高流量高存储要求的情况，对于一部分下载站和个人用户使用来说，这个每日 2500 次的免费额度就稍微好过不少了，所以说如果有持续的超出 10GB 存储且每日读取和下载量不大，B2 看起来是一个比 R2 更为不错的选择。",[14,1155,1156,1157,1160],{},"那么我们假设每日下载量没有超出免费额度，且存储 100GB 数据的话，成本就是 ",[1115,1158,1159],{"code":1159},"0.006 × 90","（10GB 免费），为 0.54 美元每月，比起 Cloudflare R2 确实低不少。",[14,1162,1163],{},"当然不要忘了套上 Cloudflare CDN 使用，不然超额还有流量费要付（",[89,1165,1167],{"id":1166},"railway-bucket","Railway Bucket",[14,1169,1170,1171,1150],{},"感觉是和前俩叫板推出的服务，就是计费套餐个人看略显复杂（文档写的太不直观），免费套餐也有 10GB 的免费额度，超额后按每 GB 每月（30 天）",[1115,1172,1173],{"code":1173},"0.015",[14,1175,1044,1176],{},[105,1177,1178],{"href":1178,"rel":1179},"https:\u002F\u002Fdocs.railway.com\u002Fguides\u002Fstorage-buckets",[109],[14,1181,1182],{},"文档对出站流量这块写的也是很奇怪，应该是出站流量免费但是还有“服务出站流量并非免费”这一说法，我们先当他免费吧（",[14,1184,1185],{},"没有 API 计费，和下面要介绍的几个在这点比较相像，我们选择把它放在这承上启下（",[14,1187,1188,1189,1191],{},"按照它这个标准计算，假设我们存储 100 GB 数据，则成本是 ",[1115,1190,1117],{"code":1117},"，是 1.35 美元每月。",[14,1193,1194],{},"文档写的太奇怪了，我看不懂（",[89,1196,1198],{"id":1197},"digitalocean-spaces","DigitalOcean Spaces",[14,1200,1201],{},"兼容 AWS S3，他们的定价模式比较特殊，需要先购买基础订阅，每月 5 美元，可以拥有 250 GB 的存储空间和 1 TB（1024 GB）的出站流量，限制为 100 个存储桶。",[14,1203,278,1204],{},[105,1205,1206],{"href":1206,"rel":1207},"https:\u002F\u002Fwww.digitalocean.com\u002Fproducts\u002Fspaces",[109],[14,1209,1210],{},"超额后的价格对比前两家是毫无吸引力的：0.02 美元每 GB 存储（标准存储），0.01 美元每 GB 流量（标准存储）",[14,1212,1213],{},"不过这家没有什么 ABC 请求次数费用计费，这样来看对于大量的高请求次数，低流量消耗的小文件性价比上可能就有些微优势了。",[14,1215,1216],{},"但是首先你需要真的有这需求，不然其他两家按存储价格还是把它按地上打。",[89,1218,1220],{"id":1219},"hetzner-s3-storage","Hetzner S3 Storage",[14,1222,1223],{},"兼容 AWS S3，由大名鼎鼎的德国 Hetzner（人称欧洲阿里云）提供的对象存储服务和 DigitalOcean Spaces 一样，都是先以订阅为基础，然后额外服务。",[14,1225,278,1226],{},[105,1227,1228],{"href":1228,"rel":1229},"https:\u002F\u002Fwww.hetzner.com\u002Fstorage\u002Fobject-storage\u002F",[109],[14,1231,1232,1233,1236,1237,1240,1241,1244,1245,1248],{},"它的价格是每月 ",[1115,1234,1235],{"code":1235},"4.99"," 欧元（欧元），包含 1TB 存储和 1TB 流量，流量超出 1 TB 后，按每 TB ",[1115,1238,1239],{"code":1239},"1.00"," 欧元收费，存储超出 1TB 后，按每 TB 小时 ",[1115,1242,1243],{"code":1243},"0.0067"," 欧元收费（一天就是约 ",[1115,1246,1247],{"code":1247},"0.1608"," 欧元）。",[14,1250,1251],{},"也和 DigitalOcean Spaces 一样，也同样没有什么 ABC 请求次数收费。",[14,1253,1254],{},"看需求吧，这个情况和 DigitalOcean Spaces 一样可以说。",[89,1256,1258],{"id":1257},"wasabi","Wasabi",[14,1260,1261,1262,1265,1266,1269],{},"和前俩一样的基础订阅为基础，Pay as You Go，从 ",[1115,1263,1264],{"code":1264},"6.99"," 美元基础订阅套餐开始，提供 1TB 的基础存储，即使只存储了几十 GB，也会收取相当于 ",[43,1267,1268],{},"1 TB"," 存储容量的最低费用。",[14,1271,1272,1273],{},"Wasabi 官网：",[105,1274,1275],{"href":1275,"rel":1276},"https:\u002F\u002Fwasabi.com",[109],[14,1278,1279],{},"但是极具吸引力的一点它是没有出口流量和 API 请求费用，属于是把前俩先按地上打了，到目前来看，甚至某种程度上在大规模存储上比前面这几个都强。",[14,1281,1282],{},"但是实际上呢，公开存储桶是默认关闭且用户不能自行开启的，需要向 Wasabi 官方申请开启，流量是“合理使用”而不是真正无限的，所以说三色图定律还在追我。",[10,1284,1285],{"id":1285},"海外存储价格对比",[14,1287,1288],{},"因为他们没有统一存储量，我们这里就使用各自的理想存储量来看吧。",[131,1290,1291,1313],{},[134,1292,1293],{},[137,1294,1295,1298,1301,1304,1307,1310],{},[140,1296,1297],{},"服务商",[140,1299,1300],{},"每月价格",[140,1302,1303],{},"每月存储量（不同）",[140,1305,1306],{},"出口流量费用",[140,1308,1309],{},"A 类请求",[140,1311,1312],{},"B\u002FC 类请求",[150,1314,1315,1335,1360,1378,1400,1421],{},[137,1316,1317,1320,1325,1328,1331,1333],{},[155,1318,1319],{},"Cloudflare",[155,1321,1322,1324],{},[1115,1323,1121],{"code":1121}," 美元",[155,1326,1327],{},"100GB（10GB 免费）",[155,1329,1330],{},"无出口流量费用",[155,1332,1085],{},[155,1334,1096],{},[137,1336,1337,1340,1345,1347,1352,1354],{},[155,1338,1339],{},"Blackblaze",[155,1341,1342,1324],{},[1115,1343,1344],{"code":1344},"0.54",[155,1346,1327],{},[155,1348,1349,1350],{},"若使用 Cloudflare CDN 则免费，否则按存储量三倍计算免费出口流量，超额则每 GB ",[1115,1351,1136],{"code":1136},[155,1353,1110],{},[155,1355,1356,1357,1359],{},"2500次\u002F每日免费，若超额按每 1000 次请求 ",[1115,1358,1149],{"code":1149}," 计费",[137,1361,1362,1365,1369,1372,1374,1376],{},[155,1363,1364],{},"Railway",[155,1366,1367,1324],{},[1115,1368,1121],{"code":1121},[155,1370,1371],{},"100 GB",[155,1373,1330],{},[155,1375,1110],{},[155,1377,1110],{},[137,1379,1380,1383,1388,1391,1396,1398],{},[155,1381,1382],{},"DigitalOcean",[155,1384,1385,1324],{},[1115,1386,1387],{"code":1387},"5.00",[155,1389,1390],{},"250 GB",[155,1392,1393,1394],{},"1 TB，超额则每 GB ",[1115,1395,1136],{"code":1136},[155,1397,1110],{},[155,1399,1110],{},[137,1401,1402,1405,1410,1412,1417,1419],{},[155,1403,1404],{},"Hetzner",[155,1406,1407,1409],{},[1115,1408,1235],{"code":1235}," 欧元",[155,1411,1268],{},[155,1413,1414,1415],{},"1 TB，超额则每 TB ",[1115,1416,1239],{"code":1239},[155,1418,1110],{},[155,1420,1110],{},[137,1422,1423,1425,1429,1431,1433,1435],{},[155,1424,1258],{},[155,1426,1427,1324],{},[1115,1428,1264],{"code":1264},[155,1430,1268],{},[155,1432,1330],{},[155,1434,1110],{},[155,1436,1110],{},{"title":1438,"searchDepth":1439,"depth":1439,"links":1440},"",4,[1441,1443,1444,1459,1467],{"id":12,"depth":1442,"text":12},2,{"id":31,"depth":1442,"text":31},{"id":78,"depth":1442,"text":78,"children":1445},[1446,1448,1449,1450,1451,1452,1456,1457,1458],{"id":91,"depth":1447,"text":92},3,{"id":268,"depth":1447,"text":269},{"id":333,"depth":1447,"text":334},{"id":416,"depth":1447,"text":417},{"id":439,"depth":1447,"text":440},{"id":540,"depth":1447,"text":540,"children":1453},[1454,1455],{"id":567,"depth":1439,"text":567},{"id":667,"depth":1439,"text":667},{"id":812,"depth":1447,"text":813},{"id":836,"depth":1447,"text":837},{"id":864,"depth":1447,"text":864},{"id":1028,"depth":1442,"text":1028,"children":1460},[1461,1462,1463,1464,1465,1466],{"id":1034,"depth":1447,"text":1035},{"id":1125,"depth":1447,"text":1126},{"id":1166,"depth":1447,"text":1167},{"id":1197,"depth":1447,"text":1198},{"id":1219,"depth":1447,"text":1220},{"id":1257,"depth":1447,"text":1258},{"id":1285,"depth":1442,"text":1285},[1469],"技术探索","2025-12-04 22:00:00","全面对比腾讯云、阿里云、华为云、七牛云等国内及 Cloudflare、Blackblaze 等海外对象存储服务商，以 100GB 存储和 100GB 流量为基准，整理资源包定价、免费额度、超额计费规则，帮助你选择最具性价比的 OSS 方案。",false,"md","https:\u002F\u002Fblog-files.101045700.xyz\u002F2025\u002F12\u002FS3-compatible-object-storage-solutions.webp",{"slots":1476},{},true,"\u002F2025\u002F12\u002Foss-prepare-list",null,{"text":1481,"minutes":1482,"time":1483,"words":1484},"27 min read",26.81,1608600,5362,1,{"title":5,"description":1471},{"loc":1478},"posts\u002F2025\u002F12\u002Foss-prepare-list","国内的怎么就这么贵啊😡",[1491,1492],"对象存储","OSS","tech","b2UzsydePTism8pWfEniVO7dlt22HUZefSoLXZuFpck",[1496,1502],{"title":1497,"path":1498,"stem":1499,"date":1500,"type":1501,"children":-1},"随笔：逝去的一段时光","\u002F2025\u002F11\u002Fpiece-hy1","posts\u002F2025\u002F11\u002Fpiece-hy1","2025-11-27 05:00:00","story",{"title":1503,"path":1504,"stem":1505,"date":1506,"type":1493,"children":-1},"Fedora Silverblue 安装记录和不可变 Linux 个人杂谈","\u002F2025\u002F12\u002Ffedora-silverblue-install-and-immutable-future","posts\u002F2025\u002F12\u002Ffedora-silverblue-install-and-immutable-future","2025-12-10 05:00:00",1774682146062]