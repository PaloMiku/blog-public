[{"data":1,"prerenderedAt":1643},["ShallowReactive",2],{"global-music-player":3,"post-/2025/12/oss-prepare-list":66,"surround-/2025/12/oss-prepare-list":1631},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":1605,"date":1607,"description":1608,"draft":1609,"extension":1610,"hide-info":1609,"image":1611,"meta":1612,"navigation":1614,"path":1615,"permalink":65,"published":65,"readingTime":1616,"recommend":1621,"references":65,"seo":1622,"sitemap":1623,"stem":1624,"subtitle":1625,"tags":1626,"type":1629,"updated":65,"__hash__":1630},"content/posts/2025/12/oss-prepare-list.md","国内外主流对象存储价格对比",{"type":70,"value":71,"toc":1574},"minimark",[72,76,80,83,89,92,95,98,130,133,136,139,142,145,148,151,156,164,173,176,183,190,193,237,240,243,246,253,326,329,333,336,339,346,349,352,394,398,401,408,411,474,477,481,484,490,493,500,504,507,513,516,555,558,601,604,607,610,613,616,624,627,631,634,748,751,754,947,951,954,961,964,971,975,978,981,984,987,990,993,999,1002,1005,1163,1166,1169,1173,1176,1179,1186,1189,1248,1260,1264,1275,1278,1281,1288,1291,1298,1301,1305,1311,1317,1320,1323,1329,1332,1336,1339,1345,1348,1351,1354,1358,1361,1367,1386,1389,1392,1396,1407,1414,1417,1420,1423,1426],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"在很多 Blog 交流群有时能看到有些博主们在商量自己网站在用什么 CDN，什么 OSS 存储啊，也互相夸赞你的站打开有多快，图片加载有多快等。",[77,81,82],{},"对于 OSS 存储其实在个人以往的《自建一个 Fediverse 实例，我们需要准备什么？》文章中对此已经略有提及，也要感谢猫猫博客站长 Firefly 的博文整理资料参考。",[84,85],"link-banner",{"banner":86,"link":87,"title":88},"https://engagemedia.org/wp-content/uploads/2020/07/Fediverse-3D_logojpg.jpg","/2025/06/self-fediverse-prepare","自建一个 Fediverse 实例，我们需要准备什么？",[77,90,91],{},"不过比起当时的整理来说，目前已经有了些许形势变化，所以还是可以再来回过头看看各家存储的新变化的。",[73,93,94],{"id":94},"须知",[77,96,97],{},"本文介绍以下情况：",[99,100,101,109,115,118,121,124,127],"ul",{},[102,103,104,105],"li",{},"假设用户使用 100GB 标准非归档等存储，会列出",[106,107,108],"strong",{},"选择购买对应存储资源包的情况",[102,110,111,112],{},"假如出站流量也为 100GB 的情况，",[106,113,114],{},"也同样列出购买资源包的情况",[102,116,117],{},"对于国内服务商，也会尽量介绍中国大陆和其他地区计费情况，单位会使用人民币（￥），对于海外服务商则以他们在定价页面标出的货币为准，毕竟汇率也是具有时效性的。",[102,119,120],{},"也可能包括其他优惠可能性等列出，但可能具有时效性",[102,122,123],{},"所有计费等资料均以本文成文时最新资料为准，后续更新不一定及时，个人有更新也会及时在文章内标示。",[102,125,126],{},"如果对象存储方案提供商提供的起步方案高于 100GB，则会灵活变化。",[102,128,129],{},"不列出国内服务商按量计费价格，因为各家政策和实际使用情况实在是乱糟糟，海外按情况给出。",[77,131,132],{},"有人可能会问：“你 100GB 是不是设的门槛太高了？很多个人博客可能压根到不了 100GB。”",[77,134,135],{},"实话说这已经是个人感觉比较好计算（各家基本都有 100GB 标准，低于 100GB 就乱七八糟的了）和未来扩张性比较灵活的一个门槛了，如果你的需求更低还是建议你自行查看他们相关文档。",[77,137,138],{},"注意下文购买资源包的价格都是一个月的情况，且本文只列出提供预付费资源包的价格，按量计费请查看官方文档或价格计算器。",[73,140,141],{"id":141},"国内服务商",[77,143,144],{},"曾经谈起国内 OSS 那是无不色变，“一夜一套房”的梦魇可以说缠绕很多包括我在内的站长许久，那么现在好了很多吗？好像也没有。",[77,146,147],{},"实话说如果你不需要对存储有那么敏感的读写速度要求和稳定性，尤其是个人博客站长，还是适当委屈下访客，担心下自己的钱包选择海外对象存储厂商吧，国内的性价比还是难说的。",[77,149,150],{},"尤其是现在 EdgeOne 免费后，有些站长使用它反代海外对象存储，理论上也算是一种好办法。",[152,153,155],"h3",{"id":154},"腾讯云-cos","腾讯云 COS",[77,157,158,159,163],{},"首先先请出 EdgeOne 的缔造者，",[160,161,162],"del",{},"最大良心云","腾讯云出场。",[77,165,166,167],{},"腾讯云 COS 全文档页面：",[168,169,170],"a",{"href":170,"rel":171},"https://cloud.tencent.com/document/product/436",[172],"nofollow",[77,174,175],{},"实话说对于国内对象存储的价格和其他评价是比较难以客观的，毕竟它们确实有很多乱七八糟的活动和资源包以及免费（试用）额度在内的各种情况，包括猫猫博客的站长在个人相关文章中也没有直接把它加入比较，因为活动和变化可能都太多了，所以我们在本文的比较计划是对于它们的直接计费做出比较，活动等为辅。",[77,177,178,179,182],{},"首先腾讯云 COS 在免费额度上，为所有新用户（即首次开通 COS 服务的个人和企业用户）提供一定量的免费额度资源包，可用于抵扣",[106,180,181],{},"标准存储类型","的数据产生的标准存储容量费用。",[77,184,185,186],{},"免费额度文档页面：",[168,187,188],{"href":188,"rel":189},"https://cloud.tencent.com/document/product/436/6240",[172],[77,191,192],{},"具体的话就是（以二进制计算，例如1TB = 1024GB）：",[194,195,196,212],"table",{},[197,198,199],"thead",{},[200,201,202,206,209],"tr",{},[203,204,205],"th",{},"面向对象",[203,207,208],{},"免费额度资源包",[203,210,211],{},"有效期",[213,214,215,227],"tbody",{},[200,216,217,221,224],{},[218,219,220],"td",{},"个人用户",[218,222,223],{},"50GB标准存储容量包",[218,225,226],{},"6个月（180天）",[200,228,229,232,235],{},[218,230,231],{},"企业用户",[218,233,234],{},"1TB标准存储容量包",[218,236,226],{},[77,238,239],{},"然后什么公有云地域免费，怎么领取balabala等请查看官方文档介绍，本文不做赘述。",[77,241,242],{},"首先我们知道，大部分运营商的政策都是按量计费，腾讯云也是一样的，就算是资源包预付费，也是在超出用量后转按量计费，不盯紧点一夜一套房不是梦。",[77,244,245],{},"首先假如我们在存储和流量上都选择半年 100GB 资源包，那么计费情况会如下所示（划线价格为他们标出的原价，定价页面也有提供折扣情况）：",[77,247,248,249],{},"腾讯云 COS 定价：",[168,250,251],{"href":251,"rel":252},"https://buy.cloud.tencent.com/price/cos",[172],[194,254,255,280],{},[197,256,257],{},[200,258,259,262,265,268,271,274,277],{},[203,260,261],{},"存储地区",[203,263,264],{},"存储包规格",[203,266,267],{},"存储包价格",[203,269,270],{},"流量地区",[203,272,273],{},"流量包规格",[203,275,276],{},"流量包价格",[203,278,279],{},"最终价格",[213,281,282,305],{},[200,283,284,287,290,293,296,299,302],{},[218,285,286],{},"中国大陆通用",[218,288,289],{},"标准存储容量包 100GB",[218,291,292],{},"8.14",[218,294,295],{},"中国大陆",[218,297,298],{},"外网下行流量包 100GB",[218,300,301],{},"34.5",[218,303,304],{},"42.64",[200,306,307,310,312,315,318,320,323],{},[218,308,309],{},"中国香港和海外通用",[218,311,289],{},[218,313,314],{},"9.38",[218,316,317],{},"中国香港和海外",[218,319,298],{},[218,321,322],{},"45.54",[218,324,325],{},"54.92",[77,327,328],{},"什么，你说中国大陆到海外或者海外到中国大陆流量？那可真是难计算了。",[152,330,332],{"id":331},"阿里云-oss","阿里云 OSS",[77,334,335],{},"实话说我以前对阿里云的好感还可以，但是现在是真的不算很好，尤其是在整理本篇文章的时候，阿里云的对象存储文档写的相比腾讯云的文档真的只能说毫无美感。",[77,337,338],{},"尤其是很多页面都有 SPM 追踪统计，我就更无语了，价格计算器在移除 SPM 统计以后甚至不能正常访问，所以本文无法给出 OSS 价格计算器的链接。",[77,340,341,342],{},"官方概述页面：",[168,343,344],{"href":344,"rel":345},"https://www.aliyun.com/product/oss",[172],[77,347,348],{},"总之快速过一下，有关阿里云免费试用额度这块他们是没有明确写在文档页面里的，所以我也不做有效参考资料加入本文。",[77,350,351],{},"资源包只有大陆地区支持购买。",[194,353,354,372],{},[197,355,356],{},[200,357,358,360,362,364,366,368,370],{},[203,359,261],{},[203,361,264],{},[203,363,267],{},[203,365,270],{},[203,367,273],{},[203,369,276],{},[203,371,279],{},[213,373,374],{},[200,375,376,378,381,384,386,388,391],{},[218,377,295],{},[218,379,380],{},"标准 - 本地冗余存储包 100GB",[218,382,383],{},"11",[218,385,295],{},[218,387,298],{},[218,389,390],{},"49",[218,392,393],{},"60",[152,395,397],{"id":396},"华为云-obs","华为云 OBS",[77,399,400],{},"华为云比起前两家来说，要论个人体验似乎也不能说多么好，但个人也算部分服务长久用户了，包括备案也是在华为云办理的，他们比起腾讯云的文档略逊一筹，但比起阿里云的文档来说那是比较好了。",[77,402,403,404],{},"官方文档页面：",[168,405,406],{"href":406,"rel":407},"https://support.huaweicloud.com/obs/index.html",[172],[77,409,410],{},"话说它有免费试用吗？没用过不知道，总之文档里没写，资源包也没有前两家那么通用，需要按地域购买。",[194,412,413,431],{},[197,414,415],{},[200,416,417,419,421,423,425,427,429],{},[203,418,261],{},[203,420,264],{},[203,422,267],{},[203,424,270],{},[203,426,273],{},[203,428,276],{},[203,430,279],{},[213,432,433,454],{},[200,434,435,438,441,444,446,449,451],{},[218,436,437],{},"华北-北京4",[218,439,440],{},"标准单 AZ 存储包 100GB",[218,442,443],{},"9",[218,445,437],{},[218,447,448],{},"公网流出流量包 100GB",[218,450,390],{},[218,452,453],{},"58",[200,455,456,459,461,464,466,468,471],{},[218,457,458],{},"中国-香港",[218,460,440],{},[218,462,463],{},"14",[218,465,458],{},[218,467,448],{},[218,469,470],{},"79",[218,472,473],{},"93",[77,475,476],{},"说实话这个香港流量价格确实有点让人惊掉下巴。",[152,478,480],{"id":479},"又拍云-uss","又拍云 USS",[77,482,483],{},"相信很多博主了解到它还是“又拍云联盟”，到现在为止也可以申请，提供 CDN 和云存储的高额代金券（免费获取每月 10GB 存储空间 + 15GB 流量，需要每年手动申请），只需要页脚挂一个 footer 就行了。",[77,485,341,486],{},[168,487,488],{"href":488,"rel":489},"https://www.upyun.com/products/file-storage",[172],[77,491,492],{},"超出这个额度的计费就不是很划算了，也同样是超额转按量，所以被刷了也是要注意的，他们也没有明确的价格文档或者资源包售卖，只有一个价格计算器。",[77,494,495,496],{},"价格计算器：",[168,497,498],{"href":498,"rel":499},"https://www.upyun.com/pricing",[172],[152,501,503],{"id":502},"七牛云-kodo","七牛云 Kodo",[77,505,506],{},"大不大小不小我也不好说的厂商。",[77,508,341,509],{},[168,510,511],{"href":511,"rel":512},"https://www.qiniu.com/products/kodo",[172],[77,514,515],{},"七牛云也有免费额度，表格如下：",[194,517,518,537],{},[197,519,520],{},[200,521,522,525,528,531,534],{},[203,523,524],{},"标准存储每月免费空间",[203,526,527],{},"标准存储每月免费 CDN 回源流量",[203,529,530],{},"标准存储每月免费请求 PUT/DELETE",[203,532,533],{},"标准存储每月免费读取请求 GET",[203,535,536],{},"每月免费上传流量",[213,538,539],{},[200,540,541,544,546,549,552],{},[218,542,543],{},"10GB",[218,545,543],{},[218,547,548],{},"10万次",[218,550,551],{},"100万次",[218,553,554],{},"无上限",[77,556,557],{},"支持预购买资源包方式，超出资源包的部分一样需要按量付费，只有中国大陆通用的资源包销售，可以选择是当月 1 日生效还是次月 1 日生效：",[194,559,560,578],{},[197,561,562],{},[200,563,564,566,568,570,572,574,576],{},[203,565,261],{},[203,567,264],{},[203,569,267],{},[203,571,270],{},[203,573,273],{},[203,575,276],{},[203,577,279],{},[213,579,580],{},[200,581,582,584,587,590,592,595,598],{},[218,583,295],{},[218,585,586],{},"标准存储空间 100GB",[218,588,589],{},"9.8",[218,591,295],{},[218,593,594],{},"外网流出流量100GB",[218,596,597],{},"28.5",[218,599,600],{},"38.3",[152,602,603],{"id":603},"雨云对象存储",[77,605,606],{},"实话说，我个人是比较支持新兴 IDC 的，理论上只要保证折腾备份，就能便宜（",[77,608,609],{},"当然你要说稳定性的话，个人了解雨云崩过几次，稳定性肯定是不如大厂的。",[77,611,612],{},"对象存储后台也不能说多么好用，不过也兼容 AWS S3，功能持续开发不好说。",[77,614,615],{},"最大的好处是他们确实是真的按资源包计费，弹性计费功能是可开关的，关闭弹性计费超额就停止服务而不是继续出账了。",[77,617,618,619],{},"雨云对象存储链接（恰饭.jpg）：",[168,620,623],{"href":621,"rel":622},"https://www.rainyun.com/ros/palomiku_",[172],"前往雨云官网，带AFF",[77,625,626],{},"他们在本文完稿时有两个地区：浙江宁波和湖北十堰，我们很难说价格问题，因为两边提供的资源包是规格不一的，不过可以稍微简单列举一下。",[628,629,630],"h4",{"id":630},"浙江宁波",[77,632,633],{},"地区介绍为高带宽，低延迟 SSD（固态硬盘），读写应该更快，稳定性就不好说了。",[194,635,636,655],{},[197,637,638],{},[200,639,640,645,650],{},[203,641,642],{},[106,643,644],{},"存储空间 + 流量",[203,646,647],{},[106,648,649],{},"每日平均费用 (元)",[203,651,652],{},[106,653,654],{},"每月费用 (元/月)",[213,656,657,670,683,696,709,722,735],{},[200,658,659,662,665],{},[218,660,661],{},"10G 存储 + 50G 流量",[218,663,664],{},"0.3",[218,666,667],{},[106,668,669],{},"10",[200,671,672,675,678],{},[218,673,674],{},"20G 存储 + 100G 流量",[218,676,677],{},"0.5",[218,679,680],{},[106,681,682],{},"15",[200,684,685,688,691],{},[218,686,687],{},"40G 存储 + 200G 流量",[218,689,690],{},"0.8",[218,692,693],{},[106,694,695],{},"24",[200,697,698,701,704],{},[218,699,700],{},"80G 存储 + 400G 流量",[218,702,703],{},"1.5",[218,705,706],{},[106,707,708],{},"45",[200,710,711,714,717],{},[218,712,713],{},"200G 存储 + 1T 流量",[218,715,716],{},"3.3",[218,718,719],{},[106,720,721],{},"100",[200,723,724,727,730],{},[218,725,726],{},"400G 存储 + 2T 流量",[218,728,729],{},"6",[218,731,732],{},[106,733,734],{},"180",[200,736,737,740,743],{},[218,738,739],{},"1T 存储 + 4T 流量",[218,741,742],{},"12.9",[218,744,745],{},[106,746,747],{},"388",[628,749,750],{"id":750},"湖北十堰",[77,752,753],{},"地区介绍为超大容量，那与前文相比肯定是机械盘了，带宽就不好说了。",[194,755,756,773],{},[197,757,758],{},[200,759,760,765,769],{},[203,761,762],{},[106,763,764],{},"套餐类型",[203,766,767],{},[106,768,649],{},[203,770,771],{},[106,772,654],{},[213,774,775,788,803,818,832,847,862,877,890,903,917,932],{},[200,776,777,782,784],{},[218,778,779],{},[106,780,781],{},"50G 存储 + 流量",[218,783,677],{},[218,785,786],{},[106,787,682],{},[200,789,790,795,798],{},[218,791,792],{},[106,793,794],{},"100G 存储 + 流量",[218,796,797],{},"0.7",[218,799,800],{},[106,801,802],{},"20",[200,804,805,810,813],{},[218,806,807],{},[106,808,809],{},"200G 存储 + 流量",[218,811,812],{},"1.3",[218,814,815],{},[106,816,817],{},"40",[200,819,820,825,827],{},[218,821,822],{},[106,823,824],{},"500G 存储 + 流量",[218,826,716],{},[218,828,829],{},[106,830,831],{},"98",[200,833,834,839,842],{},[218,835,836],{},[106,837,838],{},"1T 存储 + 流量",[218,840,841],{},"6.6",[218,843,844],{},[106,845,846],{},"198",[200,848,849,854,857],{},[218,850,851],{},[106,852,853],{},"2T 存储 + 流量",[218,855,856],{},"9.6",[218,858,859],{},[106,860,861],{},"288",[200,863,864,869,872],{},[218,865,866],{},[106,867,868],{},"100G 存储 + 25G 流量",[218,870,871],{},"0.4",[218,873,874],{},[106,875,876],{},"13",[200,878,879,884,886],{},[218,880,881],{},[106,882,883],{},"200G 存储 + 50G 流量",[218,885,797],{},[218,887,888],{},[106,889,802],{},[200,891,892,897,899],{},[218,893,894],{},[106,895,896],{},"400G 存储 + 100G 流量",[218,898,812],{},[218,900,901],{},[106,902,817],{},[200,904,905,910,912],{},[218,906,907],{},[106,908,909],{},"1T 存储 + 250G 流量",[218,911,716],{},[218,913,914],{},[106,915,916],{},"99",[200,918,919,924,927],{},[218,920,921],{},[106,922,923],{},"2T 存储 + 500G 流量",[218,925,926],{},"6.7",[218,928,929],{},[106,930,931],{},"200",[200,933,934,939,942],{},[218,935,936],{},[106,937,938],{},"4T 存储 + 1T 流量",[218,940,941],{},"13.3",[218,943,944],{},[106,945,946],{},"399",[152,948,950],{"id":949},"缤纷云-s4","缤纷云 S4",[77,952,953],{},"新兴产品，个人目前用作国内服务部分数据备份，毕竟有相对还可以的免费额度（比较复杂的50+30，建议好好看看额度文档），和雨云对比来说，它支持的东西比雨云更多，API 也更完善一些，也兼容 AWS S3，但是只支持按量计费模式，也就是说被刷了也是会超额欠费的，后台并没有用量封顶机制。",[77,955,956,957],{},"官方文档地址：",[168,958,959],{"href":959,"rel":960},"https://docs.bitiful.com/bitiful-s4/intro",[172],[77,962,963],{},"实话说文档写的还不错，但是它们在一些奇奇怪怪的地方上还是问题颇多，在按量计费上是使用的阶梯式计费，其实你也可以看出来是服务大客户的，上万的大客户理论上可以降低成本，不上不下的小用户其实就不大推荐用了。",[77,965,966,967],{},"服务态度比较...个人之前在微信交流群沟通时候印象也不是很好，可以查看下 v2ex 讨论帖：",[168,968,969],{"href":969,"rel":970},"https://www.v2ex.com/t/1006572",[172],[152,972,974],{"id":973},"_123-网盘会员直链","123 网盘会员直链",[77,976,977],{},"这种存储方式作为博客直链图床和文件存储的话，其实是一种很新颖的方式，它没有 OSS 式的管理方式（没有 S3），于个人来说性价比也很玄，取决于你对 123 网盘的粘性和会员选择，可以说是买 123 网盘会员的附赠品（只有会员才能使用直链功能和购买直链流量，一年有效期）",[77,979,980],{},"我身边有朋友在使用这种方式作为站点图床，所以干脆也推荐一下吧，之前个人也对此有一定了解。",[77,982,983],{},"功能来说也有 URL 和 Referer 鉴权，文件预览，IP 黑名单，自定义域名（增值服务，需备案，且 HTTPS 是按请求增值服务），静态网页托管，远程鉴权。",[77,985,986],{},"个人推荐购买了 123 网盘会员的用户作为附赠甜品可以使用本功能，在保持会员身份的前提下直链价格还算可以，稳定性咱也不好说，不过 123 背后其实是全国也算有名的大厂，不一定很差。",[77,988,989],{},"如果你是看上他们直链而想要购买的话...见仁见智吧，VIP 会员连续包月要 ￥25 一个月呢，如果对网盘使用需求没那么大不是很建议购买。",[77,991,992],{},"你买了会员就是 20TB 云盘空间了（还能成长，每月成长 800GB，最高成长到 100TB），然后就可以额外购买直链流量包（实际上不单独购买也有 10GB/月的直链流量包，SVIP 会员则是 100GB/月直链流量包）",[77,994,995,996],{},"直链流量包最低 1TB 起售，价格 ￥80，有效期一年，",[106,997,998],{},"且需要是会员身份才能使用直链功能。",[152,1000,1001],{"id":1001},"国内存储资源包方案价格对比",[77,1003,1004],{},"我们列出已有资源包计费的服务商最终价格对比，均为 100GB 存储包加 100GB 流量包每月，价格按照从低到高排序，没有资源包的服务商暂不列出。",[194,1006,1007,1028],{},[197,1008,1009],{},[200,1010,1011,1014,1016,1018,1020,1022,1024,1026],{},[203,1012,1013],{},"服务提供商",[203,1015,261],{},[203,1017,264],{},[203,1019,267],{},[203,1021,270],{},[203,1023,273],{},[203,1025,276],{},[203,1027,279],{},[213,1029,1030,1051,1070,1089,1107,1126,1145],{},[200,1031,1032,1035,1037,1040,1043,1045,1047,1049],{},[218,1033,1034],{},"雨云",[218,1036,750],{},[218,1038,1039],{},"100GB",[218,1041,1042],{},"统一",[218,1044,750],{},[218,1046,1039],{},[218,1048,1042],{},[218,1050,802],{},[200,1052,1053,1056,1058,1060,1062,1064,1066,1068],{},[218,1054,1055],{},"七牛云",[218,1057,295],{},[218,1059,586],{},[218,1061,589],{},[218,1063,295],{},[218,1065,594],{},[218,1067,597],{},[218,1069,600],{},[200,1071,1072,1075,1077,1079,1081,1083,1085,1087],{},[218,1073,1074],{},"腾讯云",[218,1076,286],{},[218,1078,289],{},[218,1080,292],{},[218,1082,295],{},[218,1084,298],{},[218,1086,301],{},[218,1088,304],{},[200,1090,1091,1093,1095,1097,1099,1101,1103,1105],{},[218,1092,1074],{},[218,1094,309],{},[218,1096,289],{},[218,1098,314],{},[218,1100,317],{},[218,1102,298],{},[218,1104,322],{},[218,1106,325],{},[200,1108,1109,1112,1114,1116,1118,1120,1122,1124],{},[218,1110,1111],{},"华为云",[218,1113,437],{},[218,1115,440],{},[218,1117,443],{},[218,1119,437],{},[218,1121,448],{},[218,1123,390],{},[218,1125,453],{},[200,1127,1128,1131,1133,1135,1137,1139,1141,1143],{},[218,1129,1130],{},"阿里云",[218,1132,295],{},[218,1134,380],{},[218,1136,383],{},[218,1138,295],{},[218,1140,298],{},[218,1142,390],{},[218,1144,393],{},[200,1146,1147,1149,1151,1153,1155,1157,1159,1161],{},[218,1148,1111],{},[218,1150,458],{},[218,1152,440],{},[218,1154,463],{},[218,1156,458],{},[218,1158,448],{},[218,1160,470],{},[218,1162,473],{},[73,1164,1165],{"id":1165},"海外服务商",[77,1167,1168],{},"实话说如果真的没有硬性需求，海外其实挺合适了，毕竟很多都没有国内这么复杂的计费策略，也有很多都没有流出流量费用，所以海外这里我们在计算每个月 100GB 存储可能产生的成本时候就容易了不少。",[152,1170,1172],{"id":1171},"cloudflare-r2","Cloudflare R2",[77,1174,1175],{},"赛博活佛说是，当然 Cloudflare R2 在小需求上确实价格优势还不错，而且能享受 Cloudflare CDN 的便捷（需要域名托管在 Cloudflare）。",[77,1177,1178],{},"兼容 AWS S3 的对象存储，基准功能不是很多，需要绑定域名配合 Cloudflare CDN 的策略配置食用，上限肯定是很高的。",[77,1180,1181,1182],{},"文档页面：",[168,1183,1184],{"href":1184,"rel":1185},"https://developers.cloudflare.com/r2",[172],[77,1187,1188],{},"也有比较不错的免费额度（标准存储，不是归档存储）：",[194,1190,1191,1201],{},[197,1192,1193],{},[200,1194,1195,1198],{},[203,1196,1197],{},"类型",[203,1199,1200],{},"额度",[213,1202,1203,1211,1223,1234],{},[200,1204,1205,1208],{},[218,1206,1207],{},"存储额度",[218,1209,1210],{},"10GB（所有存储桶的总额）",[200,1212,1213,1220],{},[218,1214,1215],{},[1216,1217,1219],"tip",{"tip":1218},"即 A 类操作，常见于上传和列出存储列表等操作","Class A Operations",[218,1221,1222],{},"每月前一千万次请求免费",[200,1224,1225,1231],{},[218,1226,1227],{},[1216,1228,1230],{"tip":1229},"即 B 类操作，常见于下载文件等操作","Class B Operations",[218,1232,1233],{},"每月前一亿次请求免费",[200,1235,1236,1242],{},[218,1237,1238],{},[1216,1239,1241],{"tip":1240},"也就是下载文件时产生的下载流量","出口流量",[218,1243,1244],{},[1216,1245,1247],{"tip":1246},"从 R2 直接出站，包括通过Workers API、S3 API 以及 r2.dev 域名，都不会产生数据出站（Egress）费用，是免费的。但如果你将其他按用量计费的服务连接到R2存储桶，可能会被这些服务收费。","免费",[77,1249,1250,1251,1255,1256,1259],{},"实话说 R2 的请求额度还算慷慨，所以我们可以假设每月免费请求数没超额的情况下使用 R2 存储 100GB 数据的成本是 ",[1252,1253,1254],"code",{"code":1254},"0.015 × 90","（10GB 免费），为 ",[1252,1257,1258],{"code":1258},"1.35"," 美元每月。",[152,1261,1263],{"id":1262},"blackblaze-b2","Blackblaze B2",[77,1265,1266,1267,1270,1271,1274],{},"单论存储费用其实比 Cloudflare R2 价格低，每 GB 存储 ",[1252,1268,1269],{"code":1269},"0.006"," 美元，也有 10GB 的免费额度，但是出口流量直接用是不全免费的，免费流量为你的存储量三倍（例如存储了 100GB 数据，则出口 300GB 流量是免费的），超额后为每 GB ",[1252,1272,1273],{"code":1273},"0.01"," 美元，并不便宜。",[77,1276,1277],{},"但是有个东西叫带宽联盟，是 Cloudflare 发起的，真是赛博活佛了，如果你给它套上 Cloudflare CDN，对象存储的流量从 Cloudflare 流出，则是免费的。",[77,1279,1280],{},"理论上是不是这样看比 Cloudflare R2 更划算？先别急着高兴，这就要请出第三个主角 ABC 请求了。",[77,1282,1283,1284,1287],{},"虽然 B2 的 A 类请求（上传）是免费的，但关键的 B/C 类请求（下载和列出文件列表，分开计算）免费额度没有 Cloudflare R2 那么慷慨，甚至可以说少的可怜，仅有 2500 次每日，超出的 B/C 请求会按每 1000 次请求 ",[1252,1285,1286],{"code":1286},"0.0004"," 美元计费。",[77,1289,1290],{},"所以你也能看出它的一个应用场景了：下载站和个人备份，这是典型低请求高流量高存储要求的情况，对于一部分下载站和个人用户使用来说，这个每日 2500 次的免费额度就稍微好过不少了，所以说如果有持续的超出 10GB 存储且每日读取和下载量不大，B2 看起来是一个比 R2 更为不错的选择。",[77,1292,1293,1294,1297],{},"那么我们假设每日下载量没有超出免费额度，且存储 100GB 数据的话，成本就是 ",[1252,1295,1296],{"code":1296},"0.006 × 90","（10GB 免费），为 0.54 美元每月，比起 Cloudflare R2 确实低不少。",[77,1299,1300],{},"当然不要忘了套上 Cloudflare CDN 使用，不然超额还有流量费要付（",[152,1302,1304],{"id":1303},"railway-bucket","Railway Bucket",[77,1306,1307,1308,1287],{},"感觉是和前俩叫板推出的服务，就是计费套餐个人看略显复杂（文档写的太不直观），免费套餐也有 10GB 的免费额度，超额后按每 GB 每月（30 天）",[1252,1309,1310],{"code":1310},"0.015",[77,1312,1181,1313],{},[168,1314,1315],{"href":1315,"rel":1316},"https://docs.railway.com/guides/storage-buckets",[172],[77,1318,1319],{},"文档对出站流量这块写的也是很奇怪，应该是出站流量免费但是还有“服务出站流量并非免费”这一说法，我们先当他免费吧（",[77,1321,1322],{},"没有 API 计费，和下面要介绍的几个在这点比较相像，我们选择把它放在这承上启下（",[77,1324,1325,1326,1328],{},"按照它这个标准计算，假设我们存储 100 GB 数据，则成本是 ",[1252,1327,1254],{"code":1254},"，是 1.35 美元每月。",[77,1330,1331],{},"文档写的太奇怪了，我看不懂（",[152,1333,1335],{"id":1334},"digitalocean-spaces","DigitalOcean Spaces",[77,1337,1338],{},"兼容 AWS S3，他们的定价模式比较特殊，需要先购买基础订阅，每月 5 美元，可以拥有 250 GB 的存储空间和 1 TB（1024 GB）的出站流量，限制为 100 个存储桶。",[77,1340,341,1341],{},[168,1342,1343],{"href":1343,"rel":1344},"https://www.digitalocean.com/products/spaces",[172],[77,1346,1347],{},"超额后的价格对比前两家是毫无吸引力的：0.02 美元每 GB 存储（标准存储），0.01 美元每 GB 流量（标准存储）",[77,1349,1350],{},"不过这家没有什么 ABC 请求次数费用计费，这样来看对于大量的高请求次数，低流量消耗的小文件性价比上可能就有些微优势了。",[77,1352,1353],{},"但是首先你需要真的有这需求，不然其他两家按存储价格还是把它按地上打。",[152,1355,1357],{"id":1356},"hetzner-s3-storage","Hetzner S3 Storage",[77,1359,1360],{},"兼容 AWS S3，由大名鼎鼎的德国 Hetzner（人称欧洲阿里云）提供的对象存储服务和 DigitalOcean Spaces 一样，都是先以订阅为基础，然后额外服务。",[77,1362,341,1363],{},[168,1364,1365],{"href":1365,"rel":1366},"https://www.hetzner.com/storage/object-storage/",[172],[77,1368,1369,1370,1373,1374,1377,1378,1381,1382,1385],{},"它的价格是每月 ",[1252,1371,1372],{"code":1372},"4.99"," 欧元（欧元），包含 1TB 存储和 1TB 流量，流量超出 1 TB 后，按每 TB ",[1252,1375,1376],{"code":1376},"1.00"," 欧元收费，存储超出 1TB 后，按每 TB 小时 ",[1252,1379,1380],{"code":1380},"0.0067"," 欧元收费（一天就是约 ",[1252,1383,1384],{"code":1384},"0.1608"," 欧元）。",[77,1387,1388],{},"也和 DigitalOcean Spaces 一样，也同样没有什么 ABC 请求次数收费。",[77,1390,1391],{},"看需求吧，这个情况和 DigitalOcean Spaces 一样可以说。",[152,1393,1395],{"id":1394},"wasabi","Wasabi",[77,1397,1398,1399,1402,1403,1406],{},"和前俩一样的基础订阅为基础，Pay as You Go，从 ",[1252,1400,1401],{"code":1401},"6.99"," 美元基础订阅套餐开始，提供 1TB 的基础存储，即使只存储了几十 GB，也会收取相当于 ",[106,1404,1405],{},"1 TB"," 存储容量的最低费用。",[77,1408,1409,1410],{},"Wasabi 官网：",[168,1411,1412],{"href":1412,"rel":1413},"https://wasabi.com",[172],[77,1415,1416],{},"但是极具吸引力的一点它是没有出口流量和 API 请求费用，属于是把前俩先按地上打了，到目前来看，甚至某种程度上在大规模存储上比前面这几个都强。",[77,1418,1419],{},"但是实际上呢，公开存储桶是默认关闭且用户不能自行开启的，需要向 Wasabi 官方申请开启，流量是“合理使用”而不是真正无限的，所以说三色图定律还在追我。",[73,1421,1422],{"id":1422},"海外存储价格对比",[77,1424,1425],{},"因为他们没有统一存储量，我们这里就使用各自的理想存储量来看吧。",[194,1427,1428,1450],{},[197,1429,1430],{},[200,1431,1432,1435,1438,1441,1444,1447],{},[203,1433,1434],{},"服务商",[203,1436,1437],{},"每月价格",[203,1439,1440],{},"每月存储量（不同）",[203,1442,1443],{},"出口流量费用",[203,1445,1446],{},"A 类请求",[203,1448,1449],{},"B/C 类请求",[213,1451,1452,1472,1497,1515,1537,1558],{},[200,1453,1454,1457,1462,1465,1468,1470],{},[218,1455,1456],{},"Cloudflare",[218,1458,1459,1461],{},[1252,1460,1258],{"code":1258}," 美元",[218,1463,1464],{},"100GB（10GB 免费）",[218,1466,1467],{},"无出口流量费用",[218,1469,1222],{},[218,1471,1233],{},[200,1473,1474,1477,1482,1484,1489,1491],{},[218,1475,1476],{},"Blackblaze",[218,1478,1479,1461],{},[1252,1480,1481],{"code":1481},"0.54",[218,1483,1464],{},[218,1485,1486,1487],{},"若使用 Cloudflare CDN 则免费，否则按存储量三倍计算免费出口流量，超额则每 GB ",[1252,1488,1273],{"code":1273},[218,1490,1247],{},[218,1492,1493,1494,1496],{},"2500次/每日免费，若超额按每 1000 次请求 ",[1252,1495,1286],{"code":1286}," 计费",[200,1498,1499,1502,1506,1509,1511,1513],{},[218,1500,1501],{},"Railway",[218,1503,1504,1461],{},[1252,1505,1258],{"code":1258},[218,1507,1508],{},"100 GB",[218,1510,1467],{},[218,1512,1247],{},[218,1514,1247],{},[200,1516,1517,1520,1525,1528,1533,1535],{},[218,1518,1519],{},"DigitalOcean",[218,1521,1522,1461],{},[1252,1523,1524],{"code":1524},"5.00",[218,1526,1527],{},"250 GB",[218,1529,1530,1531],{},"1 TB，超额则每 GB ",[1252,1532,1273],{"code":1273},[218,1534,1247],{},[218,1536,1247],{},[200,1538,1539,1542,1547,1549,1554,1556],{},[218,1540,1541],{},"Hetzner",[218,1543,1544,1546],{},[1252,1545,1372],{"code":1372}," 欧元",[218,1548,1405],{},[218,1550,1551,1552],{},"1 TB，超额则每 TB ",[1252,1553,1376],{"code":1376},[218,1555,1247],{},[218,1557,1247],{},[200,1559,1560,1562,1566,1568,1570,1572],{},[218,1561,1395],{},[218,1563,1564,1461],{},[1252,1565,1401],{"code":1401},[218,1567,1405],{},[218,1569,1467],{},[218,1571,1247],{},[218,1573,1247],{},{"title":1575,"searchDepth":1576,"depth":1576,"links":1577},"",4,[1578,1580,1581,1596,1604],{"id":75,"depth":1579,"text":75},2,{"id":94,"depth":1579,"text":94},{"id":141,"depth":1579,"text":141,"children":1582},[1583,1585,1586,1587,1588,1589,1593,1594,1595],{"id":154,"depth":1584,"text":155},3,{"id":331,"depth":1584,"text":332},{"id":396,"depth":1584,"text":397},{"id":479,"depth":1584,"text":480},{"id":502,"depth":1584,"text":503},{"id":603,"depth":1584,"text":603,"children":1590},[1591,1592],{"id":630,"depth":1576,"text":630},{"id":750,"depth":1576,"text":750},{"id":949,"depth":1584,"text":950},{"id":973,"depth":1584,"text":974},{"id":1001,"depth":1584,"text":1001},{"id":1165,"depth":1579,"text":1165,"children":1597},[1598,1599,1600,1601,1602,1603],{"id":1171,"depth":1584,"text":1172},{"id":1262,"depth":1584,"text":1263},{"id":1303,"depth":1584,"text":1304},{"id":1334,"depth":1584,"text":1335},{"id":1356,"depth":1584,"text":1357},{"id":1394,"depth":1584,"text":1395},{"id":1422,"depth":1579,"text":1422},[1606],"技术探索","2025-12-04T22:00:00","全面对比腾讯云、阿里云、华为云、七牛云等国内及 Cloudflare、Blackblaze 等海外对象存储服务商，以 100GB 存储和 100GB 流量为基准，整理资源包定价、免费额度、超额计费规则，帮助你选择最具性价比的 OSS 方案。",false,"md","https://blog-files.101045700.xyz/2025/12/S3-compatible-object-storage-solutions.webp",{"slots":1613},{},true,"/2025/12/oss-prepare-list",{"text":1617,"minutes":1618,"time":1619,"words":1620},"27 min read",26.81,1608600,5362,1,{"title":68,"description":1608