[{"data":1,"prerenderedAt":317},["ShallowReactive",2],{"global-music-player":3,"post-/2025/10/otterwiki-deploy":66,"surround-/2025/10/otterwiki-deploy":305},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":282,"date":284,"description":285,"draft":286,"extension":287,"hide-info":286,"image":89,"meta":288,"navigation":290,"path":291,"permalink":65,"published":65,"readingTime":292,"recommend":65,"references":65,"seo":297,"sitemap":298,"stem":299,"subtitle":65,"tags":300,"type":303,"updated":65,"__hash__":304},"content/posts/2025/10/otterwiki-deploy.md","OtterWiki 部署：基于 Python 的轻量知识库系统",{"type":70,"value":71,"toc":268},"minimark",[72,76,80,83,90,93,96,99,111,115,118,127,130,133,136,147,152,155,161,168,172,183,191,201,208,218,222,225,231,242,250,253,259,262,265],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"前两天我简单介绍了下 Affine 知识库系统，然后有人可能就有疑问了，Affine 占用那么高，我只是想部署一个小知识库，也不需要那么多复杂的特性，有没有轻巧一点的系统呢？",[77,81,82],{},"还真有，在之前个人写小 Wiki 在线整理时曾经了解并使用过 OtterWiki 这个知识库系统，使用 Flask 框架，基于 Python 编写，使用 Markdown 作为标记语言，总体来说还是比较舒服的，页面设计不算十分前卫但也不算落后。",[77,84,85],{},[86,87],"img",{"alt":88,"src":89},"","https://blog-files.101045700.xyz/2025/10/otterwiki.png",[77,91,92],{},"且自身还支持 Git Http 服务器，可以通过 Git 协议拉取和管理知识库内容。还是有点意思的。",[73,94,95],{"id":95},"要求",[77,97,98],{},"OtterWiki 的 CPU 需求非常低，你甚至可以在树莓派上运行它。所需的 RAM 大约为 100MiB，官方给出的推荐部署方式是使用 Docker 部署。",[77,100,101,102,106,107,110],{},"需要使用专用域名，例如",[103,104,105],"code",{"code":105},"wiki.example.com","，不能使用子目录",[103,108,109],{"code":109},"example.com/wiki","，浏览器需要启用 Javascript。",[73,112,114],{"id":113},"安装-docker","安装 Docker",[77,116,117],{},"我们使用 Linuxmirrors 提供的 Docker 安装脚本来执行 Docker 的安装，它可以在多种 Linux 系统上安装 Docker。",[119,120,125],"pre",{"className":121,"code":123,"language":124,"meta":88},[122],"language-bash","bash \u003C(curl -sSL https://linuxmirrors.cn/docker.sh)\n","bash",[103,126,123],{"__ignoreMap":88},[77,128,129],{},"在遵照脚本步骤完成安装 Docker 后，我们进行下一步操作。",[73,131,132],{"id":132},"反向代理服务",[77,134,135],{},"我个人推荐使用 Caddy 作为反向代理服务的选择，它和 OtterWiki 一样占用的性能极低，且可以自动为域名申请 Https 证书。",[77,137,138,139,146],{},"Caddy 的部署和安装可以参见",[140,141,145],"a",{"href":142,"rel":143},"https://caddyserver.com/docs/install",[144],"nofollow","官方文档","，我们在这里仅介绍 Debian/Ubuntu 环境下的安装和使用方式。",[148,149,151],"h3",{"id":150},"安装-caddy","安装 Caddy",[77,153,154],{},"使用以下命令在 Debian/Ubuntu 环境下一键安装和启动 Caddy 本身以及需求的组件以及配置 Caddy 官方软件包仓库（稳定版）：",[119,156,159],{"className":157,"code":158,"language":124,"meta":88},[122],"sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl\ncurl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg\ncurl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list\nchmod o+r /usr/share/keyrings/caddy-stable-archive-keyring.gpg\nchmod o+r /etc/apt/sources.list.d/caddy-stable.list\nsudo apt update\nsudo apt install caddy\n",[103,160,158],{"__ignoreMap":88},[77,162,163,164,167],{},"执行此安装操作后，Caddy 将自动启动并作为名为 ",[103,165,166],{"code":166},"caddy"," 的 systemd 服务运行 Caddy。",[148,169,171],{"id":170},"配置-caddy-反向代理","配置 Caddy 反向代理",[77,173,174,175,178,179,182],{},"我们打开",[103,176,177],{"code":177},"/etc/caddy/","目录下的",[103,180,181],{"code":181},"Caddyfile","文件，在最下面首先添加如下配置：",[119,184,189],{"className":185,"code":187,"language":188,"meta":88},[186],"language-json","wiki.example.com {\n  reverse_proxy 127.0.0.1:8080\n  encode zstd gzip\n}\n","json",[103,190,187],{"__ignoreMap":88},[77,192,193,194,196,197,200],{},"这代表 Caddy 会反代",[103,195,105],{"code":105},"的请求，并把请求转发到在本地",[103,198,199],{"code":199},"8080","端口上暴露的服务，我们这篇教程会让 OtterWiki 在 8080 端口上部署，这是官方给出的默认配置端口，如果你想要更换端口，那么在上面的配置文件和后面的配置文件中你都需要更换对应端口。",[77,202,203,204,207],{},"Caddy 支持通过配置文件启用 Zstandard和 Gzip 压缩功能，这是主流的两种压缩算法。我们只需要把",[103,205,206],{"code":206}," encode zstd gzip","加入域名配置文件下方即可，后续加入其他配置也是类似这样放置。",[77,209,210,211,213,214,217],{},"同样你也需要更换",[103,212,105],{"code":105},"为你实际想部署的域名，完成配置后，确保域名已经解析到服务器的前提下，使用",[103,215,216],{"code":216},"systemctl restart caddy","重启 Caddy 服务。",[73,219,221],{"id":220},"安装-otterwiki","安装 OtterWiki",[77,223,224],{},"我们先新建放置 OtterWiki 数据的文件夹，然后终端进入其中。",[119,226,229],{"className":227,"code":228,"language":124,"meta":88},[122],"mkdir otterwiki\ncd otterwiki\n",[103,230,228],{"__ignoreMap":88},[77,232,233,234,237,238,241],{},"在",[103,235,236],{"code":236},"otterwiki","目录下新建",[103,239,240],{"code":240},"docker-compose.yml","文件并填入如下内容",[119,243,248],{"className":244,"code":246,"language":247,"meta":88},[245],"language-yaml","services:\n  otterwiki:\n    image: redimp/otterwiki:2\n    restart: unless-stopped\n    ports:\n      - 127.0.0.1:8080:80\n    volumes:\n      - ./app-data:/app-data\n","yaml",[103,249,246],{"__ignoreMap":88},[77,251,252],{},"接下来使用以下命令拉取和启动编排镜像文件：",[119,254,257],{"className":255,"code":256,"language":124,"meta":88},[122],"docker compose up -d\n",[103,258,256],{"__ignoreMap":88},[77,260,261],{},"如果你的域名解析和 Caddy 配置正确，稍等片刻你就可以在域名上看到 OtterWiki 了。",[73,263,264],{"id":264},"结束",[77,266,267],{},"OtterWiki 启动后注册的第一个账户将作为管理员账户，所以部署启动后请尽快先注册账户哦。",{"title":88,"searchDepth":269,"depth":269,"links":270},4,[271,273,274,275,280,281],{"id":75,"depth":272,"text":75},2,{"id":95,"depth":272,"text":95},{"id":113,"depth":272,"text":114},{"id":132,"depth":272,"text":132,"children":276},[277,279],{"id":150,"depth":278,"text":151},3,{"id":170,"depth":278,"text":171},{"id":220,"depth":272,"text":221},{"id":264,"depth":272,"text":264},[283],"技术探索","2025-10-24T22:00:00","本文介绍了轻量级知识库系统 OtterWiki 的完整部署流程。系统基于 Python Flask 开发，采用 Markdown 语法，支持 Git 协议管理内容，最低仅需 100MiB 内存。部署步骤包括：使用一键脚本安装 Docker，通过官方仓库安装 Caddy 并配置自动 HTTPS 反向代理，创建专用目录后编写 docker-compose.yml 启动服务，默认监听 8080 端口。首次注册账户将自动获得管理员权限，适合资源有限的个人或小团队快速搭建私有 Wiki。",false,"md",{"slots":289},{},true,"/2025/10/otterwiki-deploy",{"text":293,"minutes":294,"time":295,"words":296},"5 min read",4.505,270300,901,{"title":68,"description":285},{"loc":291},"posts/2025/10/otterwiki-deploy",[301,302],"自托管","知识库","tech","FGieJLmpzGsg2NkKG65ZRgIzojolxfgp_2tHb4E8ZzE",[306,311],{"title":307,"path":308,"stem":309,"date":310,"type":303,"children":-1},"Misskey 部署：新一代联邦星际微博平台","/2025/10/misskey-fediverse-deploy","posts/2025/10/misskey-fediverse-deploy","2025-10-24T05:00:00",{"title":312,"path":313,"stem":314,"date":315,"type":316,"children":-1},"迟来的个人对《拔作岛》第一部游戏动漫杂谈","/2025/10/nukitashi-gv-end","posts/2025/10/nukitashi-gv-end","2025-10-25T02:00:00","story",1774206435534]