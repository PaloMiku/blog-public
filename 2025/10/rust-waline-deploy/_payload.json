[{"data":1,"prerenderedAt":195},["ShallowReactive",2],{"global-music-player":3,"post-/2025/10/rust-waline-deploy":66,"surround-/2025/10/rust-waline-deploy":183},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":160,"date":162,"description":163,"draft":164,"extension":165,"hide-info":164,"image":65,"meta":166,"navigation":168,"path":169,"permalink":65,"published":65,"readingTime":170,"recommend":65,"references":65,"seo":175,"sitemap":176,"stem":177,"subtitle":65,"tags":178,"type":181,"updated":65,"__hash__":182},"content/posts/2025/10/rust-waline-deploy.md","Waline-Mini 部署体验：基于 Rust 的 Waline 评论系统？",{"type":70,"value":71,"toc":154},"minimark",[72,76,88,95,98,101,104,107,110,113,124,127,133,140,145,148],[73,74,75],"h2",{"id":75},"前言",[77,78,79,80,87],"p",{},"最近逛 Github 也是看到个离谱的东西：waline-mini，上面描述是使用 Rust 实现的高性能 Waline 评论系统，作者是",[81,82,86],"a",{"href":83,"rel":84},"https://github.com/JQiue",[85],"nofollow","jQiue","。",[77,89,90,91],{},"Github 开源地址：",[81,92,93],{"href":93,"rel":94},"https://github.com/JQiue/waline-mini",[85],[77,96,97],{},"说实话给我看懵了，Waline 我是认识的，也是很早期开始发展的 Node.js 评论系统了，在早期因为我的一些个人原因我的大部分站点最终选定的是 Twikoo 作为评论系统。",[77,99,100],{},"不过 Waline 确实是一个还不错的评论系统，本身也能在各路云函数上运行，配置要求已经可以说是很低了，但是我是真没想到如今还有大佬写出了 Rust 实现的版本。",[77,102,103],{},"文档介绍其内存占用只有 Node.js 版本 Waline 内存占用的 1/25（5612kb=5.48mb 内存占用），我只能说不愧是 Rust。",[73,105,106],{"id":106},"部署",[77,108,109],{},"我们选择一种更快速，更经济的尝试来部署下 Waline-mini，今天我们使用 Zeabur 来进行尝试，看看部署后 Zeabur 给出的消耗预算是多少，本质其实还是使用 Docker 来部署。",[77,111,112],{},"项目给出的 Docker Compose 文件如下，不一定是最新的，建议查看官方文档。",[114,115,121],"pre",{"className":116,"code":118,"language":119,"meta":120},[117],"language-yaml","services:\n  waline:\n    image: jqiue/waline-mini:latest\n    container_name: waline-mini\n    ports:\n      - '8360:8360'\n    volumes:\n      - waline-db:/app/db\n    environment:\n      - DATABASE_URL=${DATABASE_URL:-sqlite:////app/db/waline.sqlite?mode=rwc}\n      - JWT_TOKEN=${JWT_TOKEN}\n      - SITE_NAME=${SITE_NAME}\n      - SITE_URL=${SITE_URL}\n    restart: unless-stopped\n\nvolumes:\n  waline-db:\n    driver: local\n","yaml","",[122,123,118],"code",{"__ignoreMap":120},[77,125,126],{},"前往 Zeabur，创建项目，选择使用“Docker 容器镜像”部署，本文主要是部署体验文，不详细撰述该如何部署，且目前项目仍是开发状态，未来部署方式也可能会有变化。",[77,128,129],{},[130,131],"img",{"alt":120,"src":132},"https://blog-files.101045700.xyz/2025/10/r-waline/zeabur-docker.webp",[77,134,135,136,139],{},"部署后我们可以通过",[122,137,138],{"code":138},"waline.example.com/ui","访问后台并注册账号，第一个注册的用户即为 Waline 管理员",[77,141,142],{},[130,143],{"alt":120,"src":144},"https://blog-files.101045700.xyz/2025/10/r-waline/waline-ui.webp",[77,146,147],{},"可以看到 Waline 还原完整度确实很高了，后台基本 100% 还原。",[77,149,150,151],{},"还有你们最关心的资源占用图，可以看到平均内存使用量为 3.48MB，确实很低了。\n",[130,152],{"alt":120,"src":153},"https://blog-files.101045700.xyz/2025/10/r-waline/zeabur-used.webp",{"title":120,"searchDepth":155,"depth":155,"links":156},4,[157,159],{"id":75,"depth":158,"text":75},2,{"id":106,"depth":158,"text":106},[161],"技术探索","2025-10-25T03:00:00","本文介绍了作者因 GitHub 上的 waline-mini 项目而产生的惊喜与实测过程。作为一款使用 Rust 重写的 Waline 评论系统，waline-mini 据称内存占用仅为 Node.js 原版的 1/25（约 5.5MB）。文章记录了作者通过 Zeabur 平台使用 Docker 快速部署的体验：配置简洁、支持 SQLite、默认监听 8360 端口，首个注册账户即成为管理员。实测后台 UI 与原版高度一致，平均内存仅 3.48 MB，验证了 Rust 带来的极致轻量，适合对资源占用敏感的站点。",false,"md",{"slots":167},{},true,"/2025/10/rust-waline-deploy",{"text":171,"minutes":172,"time":173,"words":174},"3 min read",2.345,140700,469,{"title":68,"description":163},{"loc":169},"posts/2025/10/rust-waline-deploy",[179,180],"自托管","评论系统","tech","IPlLg2NBYvZj8RkZtBhFyt27YHg3uTqQ4DThoyxuRcg",[184,190],{"title":185,"path":186,"stem":187,"date":188,"type":189,"children":-1},"迟来的个人对《拔作岛》第一部游戏动漫杂谈","/2025/10/nukitashi-gv-end","posts/2025/10/nukitashi-gv-end","2025-10-25T02:00:00","story",{"title":191,"path":192,"stem":193,"date":194,"type":189,"children":-1},"博客～真周年随笔（大概是一周年）","/2025/11/blog-1th-note","posts/2025/11/blog-1th-note","2025-11-04T08:00:00",1774206434671]