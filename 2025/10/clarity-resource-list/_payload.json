[{"data":1,"prerenderedAt":141},["ShallowReactive",2],{"\u002F2025\u002F10\u002Fclarity-resource-list":3,"surround-\u002F2025\u002F10\u002Fclarity-resource-list":130},{"id":4,"title":5,"body":6,"categories":105,"date":107,"description":108,"draft":109,"extension":110,"image":111,"meta":112,"navigation":114,"path":115,"permalink":116,"published":116,"readingTime":117,"recommend":116,"references":116,"seo":122,"sitemap":123,"stem":124,"subtitle":116,"tags":125,"type":128,"updated":116,"__hash__":129},"content\u002Fposts\u002F2025\u002F10\u002Fclarity-resource-list.md","为 Clarity 主题增加 ResourceList 资源列表组件",{"type":7,"value":8,"toc":94},"minimark",[9,13,17,20,23,35,40,48,51,61,64,67,91],[10,11,12],"h2",{"id":12},"前言",[14,15,16],"p",{},"本站使用的是纸鹿的 Clarity 博客主题（个人修改）版，最近加上了一个资源列表和下载组件，用来替换部分页面组件和未来准备的可能性下载需求。",[14,18,19],{},"本篇文章讲解如何添加和使用本组件到 Clarity 主题博客中。",[10,21,22],{"id":22},"组件文件",[14,24,25,26,30,31,34],{},"在 ",[27,28,29],"code",{"code":29},"\u002Fapp\u002Fcomponents\u002Fcontent\u002F"," 目录下新建 ",[27,32,33],{"code":33},"ResourceList.vue"," 并填入以下代码：",[36,37,39],"h3",{"id":38},"github-gist","Github Gist",[14,41,42],{},[43,44,45],"a",{"href":45,"rel":46},"https:\u002F\u002Fgist.github.com\u002FPaloMiku\u002F11e5c3e6ccdad906e0dca2aea26228ba",[47],"nofollow",[36,49,50],{"id":50},"本站",[52,53,59],"pre",{"className":54,"code":56,"language":57,"meta":58},[55],"language-vue","\u003Cscript setup lang=\"ts\">\ninterface ResourceItem {\n  id?: string | number\n  title: string\n  subtitle?: string\n  tags?: string[]\n  link?: string\n  summary?: string\n  extractPassword?: string\n  downloadPassword?: string\n}\n\ndefineProps\u003C{\n  items: ResourceItem[]\n}>()\n\u003C\u002Fscript>\n\n\u003Ctemplate>\n\u003Col class=\"resource-list\">\n\t\u003Cli v-for=\"item in items\" :key=\"item.id ?? item.title\" class=\"resource-item card\">\n\t\t\u003Cdiv class=\"resource-content\">\n\t\t\t\u003Cdiv>\n\t\t\t\t\u003Cdiv class=\"resource-title\">\n\t\t\t\t\t{{ item.title }}\n\t\t\t\t\u003C\u002Fdiv>\n\t\t\t\t\u003Cp v-if=\"item.subtitle\" class=\"resource-subtitle\">\n\t\t\t\t\t{{ item.subtitle }}\n\t\t\t\t\u003C\u002Fp>\n\t\t\t\t\u003Cp v-if=\"item.summary\" class=\"resource-summary\">\n\t\t\t\t\t{{ item.summary }}\n\t\t\t\t\u003C\u002Fp>\n\t\t\t\u003C\u002Fdiv>\n\n\t\t\t\u003Cdiv class=\"resource-meta\">\n\t\t\t\t\u003Cdiv v-if=\"item.extractPassword || item.downloadPassword\" class=\"passwords\">\n\t\t\t\t\t\u003Cspan v-if=\"item.extractPassword\">解压: {{ item.extractPassword }}\u003C\u002Fspan>\n\t\t\t\t\t\u003Cspan v-if=\"item.downloadPassword\">下载: {{ item.downloadPassword }}\u003C\u002Fspan>\n\t\t\t\t\u003C\u002Fdiv>\n\t\t\t\t\u003Cdiv class=\"tags\">\n\t\t\t\t\t\u003CBadge v-for=\"tag in item.tags\" :key=\"tag\" :text=\"tag\" \u002F>\n\t\t\t\t\u003C\u002Fdiv>\n\t\t\t\u003C\u002Fdiv>\n\t\t\u003C\u002Fdiv>\n\n\t\t\u003CZRawLink\n\t\t\tv-if=\"item.link\"\n\t\t\t:to=\"item.link\"\n\t\t\tclass=\"download-btn\"\n\t\t\taria-label=\"下载资源\"\n\t\t\ttitle=\"下载资源\"\n\t\t\ttarget=\"_blank\"\n\t\t\trel=\"noopener\"\n\t\t>\n\t\t\t\u003CIcon name=\"ph:download-simple\" \u002F>\n\t\t\u003C\u002FZRawLink>\n\t\t\u003Cbutton\n\t\t\tv-else\n\t\t\tclass=\"download-btn\"\n\t\t\tdisabled\n\t\t\taria-label=\"下载资源\"\n\t\t\ttitle=\"下载资源\"\n\t\t>\n\t\t\t\u003CIcon name=\"ph:download-simple\" \u002F>\n\t\t\u003C\u002Fbutton>\n\t\u003C\u002Fli>\n\u003C\u002Fol>\n\u003C\u002Ftemplate>\n\n\u003Cstyle lang=\"scss\" scoped>\n.resource-list {\n  margin: 0;\n  padding: 0;\n  display: grid;\n  gap: 1em;\n\n  @media (max-width: 600px) {\n    gap: 0.75em;\n  }\n}\n\n.resource-item {\n  display: flex;\n  align-items: center;\n  gap: 1em;\n  padding: 1em;\n\n  @media (max-width: 600px) {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 0.5em;\n    padding: 0.75em;\n  }\n}\n\n.resource-content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75em;\n  min-width: 0;\n\n  > div {\n    display: flex;\n    flex-direction: column;\n    gap: 0.3em;\n  }\n}\n\n.resource-title {\n  font-weight: 700;\n  font-size: 1.05em;\n  color: var(--c-text);\n}\n\n.resource-subtitle,\n.resource-summary {\n  margin: 0;\n  font-size: 0.9em;\n}\n\n.resource-subtitle {\n  color: var(--c-text-2);\n}\n\n.resource-summary {\n  color: var(--c-text-1);\n}\n\n.resource-meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5em;\n  font-size: 0.8em;\n\n  @media (max-width: 600px) {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n\n.passwords span {\n  color: var(--c-text-2);\n  background: var(--c-bg-2);\n  padding: 0.2em 0.4em;\n  border-radius: 0.3em;\n}\n\n.passwords,\n.tags {\n  display: flex;\n  flex-wrap: wrap;\n}\n\n.passwords {\n  gap: 0.5em;\n}\n\n.tags {\n  gap: 0.25em;\n}\n\n.download-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  width: 2.4em;\n  height: 2.4em;\n  border-radius: 0.5em;\n  background: var(--c-primary);\n  color: white;\n  font-size: 1.1em;\n  transition: all 0.2s;\n\n  &:hover:not(:disabled) {\n    transform: translateY(-2px);\n    box-shadow: 0 0.5em 1em var(--ld-shadow);\n  }\n\n  &:disabled {\n    opacity: 0.5;\n  }\n\n  @media (max-width: 600px) {\n    width: 2.2em;\n    height: 2.2em;\n    font-size: 1em;\n  }\n}\n\u003C\u002Fstyle>\n","vue","",[27,60,56],{"__ignoreMap":58},[10,62,63],{"id":63},"使用",[14,65,66],{},"保存组件并启动开发服务器测试。",[68,69,71],"tab",{":tabs":70},"[\"组件\",\"语法\"]",[72,73,74,78,82],"template",{"v-slot:tab1":58},[75,76],"resource-list",{":items":77},"[{\"id\":1,\"title\":\"示例资源 1\",\"subtitle\":\"这是一个副标题\",\"summary\":\"这是资源的简短描述\",\"tags\":[\"标签1\",\"标签2\"],\"link\":\"https:\u002F\u002Fexample.com\u002Fdownload1\",\"extractPassword\":\"abc123\",\"downloadPassword\":\"def456\"},{\"id\":2,\"title\":\"示例资源 2\",\"subtitle\":\"另一个副标题\",\"summary\":\"另一个资源的简短描述\",\"tags\":[\"标签3\"],\"link\":\"https:\u002F\u002Fexample.com\u002Fdownload2\"}]",[79,80,81],"h1",{"id":81},"tab2",[52,83,89],{"className":84,"code":86,"language":87,"meta":88},[85],"language-mdc","::resource-list\n---\nitems:\n  - id: 1\n    title: 示例资源 1\n    subtitle: 这是一个副标题\n    summary: 这是资源的简短描述\n    tags: [\"标签1\", \"标签2\"]\n    link: \"https:\u002F\u002Fexample.com\u002Fdownload1\"\n    extractPassword: \"abc123\"\n    downloadPassword: \"def456\"\n  - id: 2\n    title: 示例资源 2\n    subtitle: 另一个副标题\n    summary: 另一个资源的简短描述\n    tags: [\"标签3\"]\n    link: \"https:\u002F\u002Fexample.com\u002Fdownload2\"\n---\n::\n","mdc","wrap expand",[27,90,86],{"__ignoreMap":58},[14,92,93],{},"成功渲染如上“组件”所示效果即成功应用。",{"title":58,"searchDepth":95,"depth":95,"links":96},4,[97,99,104],{"id":12,"depth":98,"text":12},2,{"id":22,"depth":98,"text":22,"children":100},[101,103],{"id":38,"depth":102,"text":39},3,{"id":50,"depth":102,"text":50},{"id":63,"depth":98,"text":63},[106],"站点魔改","2025-10-20 22:00:00","本文介绍了为Clarity博客主题增加ResourceList资源列表组件的方法，提供了完整的Vue组件代码与使用语法，用于创建包含标题、链接、密码等信息的资源下载列表。",false,"md","https:\u002F\u002Fblog-files.101045700.xyz\u002F2025\u002F10\u002FResourceList.webp",{"slots":113},{},true,"\u002F2025\u002F10\u002Fclarity-resource-list",null,{"text":118,"minutes":119,"time":120,"words":121},"3 min read",2.795,167700,559,{"title":5,"description":108},{"loc":115},"posts\u002F2025\u002F10\u002Fclarity-resource-list",[126,127],"Clarity","Vue","tech","52wXp19cThXda3qLHAMXiNs9jLSHlhAFoNz8rjqScn8",[131,136],{"title":132,"path":133,"stem":134,"date":135,"type":128,"children":-1},"我的 KDE Plasma 6 美化方案分享","\u002F2025\u002F08\u002Fkde-customization","posts\u002F2025\u002F08\u002Fkde-customization","2025-08-28 05:30:00",{"title":137,"path":138,"stem":139,"date":140,"type":128,"children":-1},"大盘鸡做 NAS？FnOS 个人 VPS 部署体验","\u002F2025\u002F10\u002Ffnos-vps-started","posts\u002F2025\u002F10\u002Ffnos-vps-started","2025-10-21 05:00:00",1774957946769]