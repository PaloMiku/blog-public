rtist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":166,"date":168,"description":169,"draft":170,"extension":171,"hide-info":170,"image":172,"meta":173,"navigation":175,"path":176,"permalink":65,"published":65,"readingTime":177,"recommend":65,"references":65,"seo":182,"sitemap":183,"stem":184,"subtitle":65,"tags":185,"type":188,"updated":65,"__hash__":189},"content/posts/2025/10/clarity-resource-list.md","为 Clarity 主题增加 ResourceList 资源列表组件",{"type":70,"value":71,"toc":155},"minimark",[72,76,80,83,86,98,103,111,114,124,127,130,152],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"本站使用的是纸鹿的 Clarity 博客主题（个人修改）版，最近加上了一个资源列表和下载组件，用来替换部分页面组件和未来准备的可能性下载需求。",[77,81,82],{},"本篇文章讲解如何添加和使用本组件到 Clarity 主题博客中。",[73,84,85],{"id":85},"组件文件",[77,87,88,89,93,94,97],{},"在 ",[90,91,92],"code",{"code":92},"/app/components/content/"," 目录下新建 ",[90,95,96],{"code":96},"ResourceList.vue"," 并填入以下代码：",[99,100,102],"h3",{"id":101},"github-gist","Github Gist",[77,104,105],{},[106,107,108],"a",{"href":108,"rel":109},"https://gist.github.com/PaloMiku/11e5c3e6ccdad906e0dca2aea26228ba",[110],"nofollow",[99,112,113],{"id":113},"本站",[115,116,122],"pre",{"className":117,"code":119,"language":120,"meta":121},[118],"language-vue","\u003Cscript setup lang=\"ts\">\ninterface ResourceItem {\n  id?: string | number\n  title: string\n  subtitle?: string\n  tags?: string[]\n  link?: string\n  summary?: string\n  extractPassword?: string\n  downloadPassword?: string\n}\n\ndefineProps\u003C{\n  items: ResourceItem[]\n}>()\n\u003C/script>\n\n\u003Ctemplate>\n\u003Col class=\"resource-list\">\n\t\u003Cli v-for=\"item in items\" :key=\"item.id ?? item.title\" class=\"resource-item card\">\n\t\t\u003Cdiv class=\"resource-content\">\n\t\t\t\u003Cdiv>\n\t\t\t\t\u003Cdiv class=\"resource-title\">\n\t\t\t\t\t{{ item.title }}\n\t\t\t\t\u003C/div>\n\t\t\t\t\u003Cp v-if=\"item.subtitle\" class=\"resource-subtitle\">\n\t\t\t\t\t{{ item.subtitle }}\n\t\t\t\t\u003C/p>\n\t\t\t\t\u003Cp v-if=\"item.summary\" class=\"resource-summary\">\n\t\t\t\t\t{{ item.summary }}\n\t\t\t\t\u003C/p>\n\t\t\t\u003C/div>\n\n\t\t\t\u003Cdiv class=\"resource-meta\">\n\t\t\t\t\u003Cdiv v-if=\"item.extractPassword || item.downloadPassword\" class=\"passwords\">\n\t\t\t\t\t\u003Cspan v-if=\"item.extractPassword\">解压: {{ item.extractPassword }}\u003C/span>\n\t\t\t\t\t\u003Cspan v-if=\"item.downloadPassword\">下载: {{ item.downloadPassword }}\u003C/span>\n\t\t\t\t\u003C/div>\n\t\t\t\t\u003Cdiv class=\"tags\">\n\t\t\t\t\t\u003CBadge v-for=\"tag in item.tags\" :key=\"tag\" :text=\"tag\" />\n\t\t\t\t\u003C/div>\n\t\t\t\u003C/div>\n\t\t\u003C/div>\n\n\t\t\u003CZRawLink\n\t\t\tv-if=\"item.link\"\n\t\t\t:to=\"item.link\"\n\t\t\tclass=\"download-btn\"\n\t\t\taria-label=\"下载资源\"\n\t\t\ttitle=\"下载资源\"\n\t\t\ttarget=\"_blank\"\n\t\t\trel=\"noopener\"\n\t\t>\n\t\t\t\u003CIcon name=\"ph:download-simple\" />\n\t\t\u003C/ZRawLink>\n\t\t\u003Cbutton\n\t\t\tv-else\n\t\t\tclass=\"download-btn\"\n\t\t\tdisabled\n\t\t\taria-label=\"下载资源\"\n\t\t\ttitle=\"下载资源\"\n\t\t>\n\t\t\t\u003CIcon name=\"ph:download-simple\" />\n\t\t\u003C/button>\n\t\u003C/li>\n\u003C/ol>\n\u003C/template>\n\n\u003Cstyle lang=\"scss\" scoped>\n.resource-list {\n  margin: 0;\n  padding: 0;\n  display: grid;\n  gap: 1em;\n\n  @media (max-width: 600px) {\n    gap: 0.75em;\n  }\n}\n\n.resource-item {\n  display: flex;\n  align-items: center;\n  gap: 1em;\n  padding: 1em;\n\n  @media (max-width: 600px) {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 0.5em;\n    padding: 0.75em;\n  }\n}\n\n.resource-content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75em;\n  min-width: 0;\n\n  > div {\n    display: flex;\n    flex-direction: column;\n    gap: 0.3em;\n  }\n}\n\n.resource-title {\n  font-weight: 700;\n  font-size: 1.05em;\n  color: var(--c-text);\n}\n\n.resource-subtitle,\n.resource-summary {\n  margin: 0;\n  font-size: 0.9em;\n}\n\n.resource-subtitle {\n  color: var(--c-text-2);\n}\n\n.resource-summary {\n  color: var(--c-text-1);\n}\n\n.resource-meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5em;\n  font-size: 0.8em;\n\n  @media (max-width: 600px) {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n\n.passwords span {\n  color: var(--c-text-2);\n  background: var(--c-bg-2);\n  padding: 0.2em 0.4em;\n  border-radius: 0.3em;\n}\n\n.passwords,\n.tags {\n  display: flex;\n  flex-wrap: wrap;\n}\n\n.passwords {\n  gap: 0.5em;\n}\n\n.tags {\n  gap: 0.25em;\n}\n\n.download-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  width: 2.4em;\n  height: 2.4em;\n  border-radius: 0.5em;\n  background: var(--c-primary);\n  color: white;\n  font-size: 1.1em;\n  transition: all 0.2s;\n\n  &:hover:not(:disabled) {\n    transform: translateY(-2px);\n    box-shadow: 0 0.5em 1em var(--ld-shadow);\n  }\n\n  &:disabled {\n    opacity: 0.5;\n  }\n\n  @media (max-width: 600px) {\n    width: 2.2em;\n    height: 2.2em;\n    font-size: 1em;\n  }\n}\n\u003C/style>\n","vue","",[90,123,119],{"__ignoreMap":121},[73,125,126],{"id":126},"使用",[77,128,129],{},"保存组件并启动开发服务器测试。",[131,132,134,141],"tab",{":tabs":133},"[\"组件\",\"语法\"]",[135,136,137],"template",{"v-slot:tab1":121},[138,139],"resource-list",{":items":140},"[{\"id\":1,\"title\":\"示例资源 1\",\"subtitle\":\"这是一个副标题\",\"summary\":\"这是资源的简短描述\",\"tags\":[\"标签1\",\"标签2\"],\"link\":\"https://example.com/download1\",\"extractPassword\":\"abc123\",\"downloadPassword\":\"def456\"},{\"id\":2,\"title\":\"示例资源 2\",\"subtitle\":\"另一个副标题\",\"summary\":\"另一个资源的简短描述\",\"tags\":[\"标签3\"],\"link\":\"https://example.com/download2\"}]",[135,142,143],{"v-slot:tab2":121},[115,144,150],{"className":145,"code":147,"language":148,"meta":149},[146],"language-mdc","::resource-list\n---\nitems:\n  - id: 1\n    title: 示例资源 1\n    subtitle: 这是一个副标题\n    summary: 这是资源的简短描述\n    tags: [\"标签1\", \"标签2\"]\n    link: \"https://example.com/download1\"\n    extractPassword: \"abc123\"\n    downloadPassword: \"def456\"\n  - id: 2\n    title: 示例资源 2\n    subtitle: 另一个副标题\n    summary: 另一个资源的简短描述\n    tags: [\"标签3\"]\n    link: \"https://example.com/download2\"\n---\n::\n","mdc","wrap expand",[90,151,147],{"__ignoreMap":121},[77,153,154],{},"成功渲染如上“组件”所示效果即成功应用。",{"title":121,"searchDepth":156,"depth":156,"links":157},4,[158,160,165],{"id":75,"depth":159,"text":75},2,{"id":85,"depth":159,"text":85,"children":161},[162,164],{"id":101,"depth":163,"text":102},3,{"id":113,"depth":163,"text":113},{"id":126,"depth":159,"text":126},[167],"站点魔改","2025-10-20T22:00:00","本文介绍了为Clarity博客主题增加ResourceList资源列表组件的方法，提供了完整的Vue组件代码与使用语法，用于创建包含标题、链接、密码等信息的资源下载列表。",false,"md","https://blog-files.101045700.xyz/2025/10/ResourceList.webp",{"slots":174},{},true,"/2025/10/clarity-resource-list",{"text":178,"minutes":179,"time":180,"words":181},"3 min read",2.795,167700,559,{"title":68,"description":169},{"loc":176},"posts/2025/10/clarity-resource-list",[186,187],"Clarity","Vue","tech","K6M8PG7gnJnzAIVlmfcxfkiVu1k0F_nq_GWO_BpSGbY",[191,196],{"title":192,"path":193,"stem":194,"date":195,"type":188,"children":-1},"我的 KDE Plasma 6 美化方案分享","/2025/08/kde-customization","posts/2025/08/kde-customization","2025-08-28T05:30:00",{"title":197,"path":198,"stem":199,"date":200,"type":188,"children":-1},"大盘鸡做 NAS？FnOS 个人 VPS 部署体验","/2025/10/fnos-vps-started","posts/2025/10/fnos-vps-started","2025-10-21T05:00:00",1773069189005]