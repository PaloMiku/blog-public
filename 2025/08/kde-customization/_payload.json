[{"data":1,"prerenderedAt":319},["ShallowReactive",2],{"global-music-player":3,"post-/2025/08/kde-customization":66,"surround-/2025/08/kde-customization":308},{"musicList":4,"error":65},[5,11,14,17,20,23,26,29,32,35,38,41,44,47,50,53,56,59,62],{"id":6,"title":7,"artist":8,"source":9,"url":10},"403010","加载中...","获取中...","netease","https://music.163.com/#/song?id=403010",{"id":12,"title":7,"artist":8,"source":9,"url":13},"2121025432","https://music.163.com/#/song?id=2121025432",{"id":15,"title":7,"artist":8,"source":9,"url":16},"760528","https://music.163.com/#/song?id=760528",{"id":18,"title":7,"artist":8,"source":9,"url":19},"1484017181","https://music.163.com/#/song?id=1484017181",{"id":21,"title":7,"artist":8,"source":9,"url":22},"22706984","https://music.163.com/#/song?id=22706984",{"id":24,"title":7,"artist":8,"source":9,"url":25},"1311319929","https://music.163.com/#/song?id=1311319929",{"id":27,"title":7,"artist":8,"source":9,"url":28},"2734259397","https://music.163.com/#/song?id=2734259397",{"id":30,"title":7,"artist":8,"source":9,"url":31},"760533","https://music.163.com/#/song?id=760533",{"id":33,"title":7,"artist":8,"source":9,"url":34},"22706980","https://music.163.com/#/song?id=22706980",{"id":36,"title":7,"artist":8,"source":9,"url":37},"22707008","https://music.163.com/#/song?id=22707008",{"id":39,"title":7,"artist":8,"source":9,"url":40},"1446832656","https://music.163.com/#/song?id=1446832656",{"id":42,"title":7,"artist":8,"source":9,"url":43},"22706979","https://music.163.com/#/song?id=22706979",{"id":45,"title":7,"artist":8,"source":9,"url":46},"1446837300","https://music.163.com/#/song?id=1446837300",{"id":48,"title":7,"artist":8,"source":9,"url":49},"1303019256","https://music.163.com/#/song?id=1303019256",{"id":51,"title":7,"artist":8,"source":9,"url":52},"541492408","https://music.163.com/#/song?id=541492408",{"id":54,"title":7,"artist":8,"source":9,"url":55},"530057368","https://music.163.com/#/song?id=530057368",{"id":57,"title":7,"artist":8,"source":9,"url":58},"542058337","https://music.163.com/#/song?id=542058337",{"id":60,"title":7,"artist":8,"source":9,"url":61},"1958727599","https://music.163.com/#/song?id=1958727599",{"id":63,"title":7,"artist":8,"source":9,"url":64},"1818615632","https://music.163.com/#/song?id=1818615632",null,{"id":67,"title":68,"body":69,"categories":282,"date":284,"description":285,"draft":286,"extension":287,"hide-info":286,"image":96,"meta":288,"navigation":290,"path":291,"permalink":65,"published":65,"readingTime":292,"recommend":297,"references":65,"seo":298,"sitemap":299,"stem":300,"subtitle":301,"tags":302,"type":305,"updated":306,"__hash__":307},"content/posts/2025/08/kde-customization.md","我的 KDE Plasma 6 美化方案分享",{"type":70,"value":71,"toc":266},"minimark",[72,76,80,83,89,92,97,100,104,107,110,114,117,120,129,136,139,142,145,149,152,155,159,162,165,168,171,253,256,259],[73,74,75],"h2",{"id":75},"前言",[77,78,79],"p",{},"个人把主力 Linux 系统从 CachyOS（Arch Linux）更换到了 Fedora 43（KDE Plasma Desktop Edition）。",[77,81,82],{},"对桌面也重新做了整理和美化，个人还是很喜欢 KDE Plasma 的，使用 Linux 也已有一年有余，今天分享下我目前使用的桌面美化方案。",[84,85,86],"alert",{},[77,87,88],{},"本文内容已于 2025.11.04 更新，删减壁纸和部分内容，新增 Panel-colorizer 插件效果。",[77,90,91],{},"一个好的美化方案不仅可以让自己赏心悦目，也可以通过组件位置合理放置提升个人的工作效率，本文使用到的插件和配色方案等均可在 KDE 商店下载到。",[93,94],"pic",{"caption":95,"src":96},"桌面效果图","https://blog-files.101045700.xyz/2025/08/kde-customization/preview.webp",[73,98,99],{"id":99},"方案",[101,102,103],"h3",{"id":103},"上下布局",[77,105,106],{},"上方使用空面板，从左到右组件分别为“应用程序启动器”，“窗口列表”、“全局菜单”、“面板间隙”、“数字时钟”、“面板间隙”、“系统托盘”。",[77,108,109],{},"下方放置应用程序菜单栏，使用“图标任务管理器”实现类似 Dock 栏的效果。",[101,111,113],{"id":112},"panel-colorizer","Panel-colorizer",[77,115,116],{},"在 2025 年 10 月系统升级 Fedora 43 后发现了 Panel-colorizer 这个插件，可以对 KDE 面板进行颜色和透明度的更多自定义设置。",[77,118,119],{},"桌面的上下面板均使用了本插件，设置了不同的透明度和颜色。",[77,121,122,123],{},"Github 地址：",[124,125,126],"a",{"href":126,"rel":127},"https://github.com/luisbocanegra/plasma-panel-colorizer",[128],"nofollow",[77,130,131,132],{},"KDE 商店链接：",[124,133,134],{"href":134,"rel":135},"https://store.kde.org/p/2130967",[128],[77,137,138],{},"若是从 KDE 商店安装本插件，需要先检查系统是否已安装相关依赖包，可在项目 Github README 中查看不同系统需求的依赖包安装方式。",[77,140,141],{},"在面板激活本插件十分简单，安装后添加在需要使用的面板添加 Panel Colorizer 挂件，然后进入挂件配置即可对目前附加的面板进行修改。",[77,143,144],{},"这里只是提供了个人的一种选择思路，你可以根据插件设置自定义属于自己的更强大的主题配色方案。",[146,147,148],"h4",{"id":148},"上面板",[77,150,151],{},"配置透明效果的步骤其实很简单。",[77,153,154],{},"首先使用插件内置的 ChromeOS 预设，然后打开外观设置，翻到侧边外观选项卡，下翻找到“Color”然后禁用它的颜色即可（如下图）。",[93,156],{"caption":157,"src":158},"Panel-colorizer 上面板配置","https://blog-files.101045700.xyz/2025/08/kde-customization/config.webp",[146,160,161],{"id":161},"下面板",[77,163,164],{},"下面板的配置就更简单了，直接使用插件内置的 Translucent 预设即可。",[101,166,167],{"id":167},"主题方案",[77,169,170],{},"前往 系统设置 > 全局主题 设置",[172,173,174,187],"table",{},[175,176,177],"thead",{},[178,179,180,184],"tr",{},[181,182,183],"th",{},"类型",[181,185,186],{},"名称",[188,189,190,199,207,215,222,229,237,245],"tbody",{},[178,191,192,196],{},[193,194,195],"td",{},"全局主题",[193,197,198],{},"Fedora",[178,200,201,204],{},[193,202,203],{},"颜色",[193,205,206],{},"Moe",[178,208,209,212],{},[193,210,211],{},"应用程序外观样式",[193,213,214],{},"Breeze 微风",[178,216,217,220],{},[193,218,219],{},"Plasma 外观样式",[193,221,206],{},[178,223,224,227],{},[193,225,226],{},"窗口装饰元素",[193,228,214],{},[178,230,231,234],{},[193,232,233],{},"图标",[193,235,236],{},"Colloid",[178,238,239,242],{},[193,240,241],{},"光标",[193,243,244],{},"Hoshino Swimsuit",[178,246,247,250],{},[193,248,249],{},"欢迎屏幕",[193,251,252],{},"Lagtrain",[101,254,255],{"id":255},"桌面时钟",[77,257,258],{},"使用 Redmi Clock 插件",[77,260,261,262],{},"插件 KDE 商店链接：",[124,263,264],{"href":264,"rel":265},"https://store.kde.org/p/2175475",[128],{"title":267,"searchDepth":268,"depth":268,"links":269},"",4,[270,272],{"id":75,"depth":271,"text":75},2,{"id":99,"depth":271,"text":99,"children":273},[274,276,280,281],{"id":103,"depth":275,"text":103},3,{"id":112,"depth":275,"text":113,"children":277},[278,279],{"id":148,"depth":268,"text":148},{"id":161,"depth":268,"text":161},{"id":167,"depth":275,"text":167},{"id":255,"depth":275,"text":255},[283],"技术探索","2025-08-28T05:30:00","本文分享了作者将主力系统换至Fedora 43 KDE后的桌面美化方案：采用上下双面板布局，上方空面板配应用启动器、全局菜单等，下方图标任务管理器作Dock；引入Panel-colorizer插件，为上下面板分别设置ChromeOS透明与Translucent预设；主题选Fedora全局主题+Moe配色+Colloid图标，时钟用Redmi Clock插件，全套均可在KDE商店获取。",false,"md",{"slots":289},{},true,"/2025/08/kde-customization",{"text":293,"minutes":294,"time":295,"words":296},"4 min read",3.27,196200,654,10,{"title":68,"description":285},{"loc":291},"posts/2025/08/kde-customization","其实并不是很难的吧😆",[303,304],"KDE","Linux","tech","2025-11-04T18:30:00","g3ollf6u7l2kJG8pqZnxAYVAqvSMAh8RQwJh5D3hcts",[309,314],{"title":310,"path":311,"stem":312,"date":313,"type":305,"children":-1},"《痴情哥哥与病弱妹妹的乡间生活》 Steam 版在 Linux/Deck 下的运行问题修复","/2025/06/sickly-days-linux-run","posts/2025/06/sickly-days-linux-run","2025-06-22T05:30:00",{"title":315,"path":316,"stem":317,"date":318,"type":305,"children":-1},"为 Clarity 主题增加 ResourceList 资源列表组件","/2025/10/clarity-resource-list","posts/2025/10/clarity-resource-list","2025-10-20T22:00:00",1774206434799]