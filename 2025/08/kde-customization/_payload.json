[{"data":1,"prerenderedAt":257},["ShallowReactive",2],{"\u002F2025\u002F08\u002Fkde-customization":3,"surround-\u002F2025\u002F08\u002Fkde-customization":246},{"id":4,"title":5,"body":6,"categories":219,"date":221,"description":222,"draft":223,"extension":224,"image":33,"meta":225,"navigation":227,"path":228,"permalink":229,"published":229,"readingTime":230,"recommend":235,"references":229,"seo":236,"sitemap":237,"stem":238,"subtitle":239,"tags":240,"type":243,"updated":244,"__hash__":245},"content\u002Fposts\u002F2025\u002F08\u002Fkde-customization.md","我的 KDE Plasma 6 美化方案分享",{"type":7,"value":8,"toc":203},"minimark",[9,13,17,20,26,29,34,37,41,44,47,51,54,57,66,73,76,79,82,86,89,92,96,99,102,105,108,190,193,196],[10,11,12],"h2",{"id":12},"前言",[14,15,16],"p",{},"个人把主力 Linux 系统从 CachyOS（Arch Linux）更换到了 Fedora 43（KDE Plasma Desktop Edition）。",[14,18,19],{},"对桌面也重新做了整理和美化，个人还是很喜欢 KDE Plasma 的，使用 Linux 也已有一年有余，今天分享下我目前使用的桌面美化方案。",[21,22,23],"alert",{},[14,24,25],{},"本文内容已于 2025.11.04 更新，删减壁纸和部分内容，新增 Panel-colorizer 插件效果。",[14,27,28],{},"一个好的美化方案不仅可以让自己赏心悦目，也可以通过组件位置合理放置提升个人的工作效率，本文使用到的插件和配色方案等均可在 KDE 商店下载到。",[30,31],"pic",{"caption":32,"src":33},"桌面效果图","https:\u002F\u002Fblog-files.101045700.xyz\u002F2025\u002F08\u002Fkde-customization\u002Fpreview.webp",[10,35,36],{"id":36},"方案",[38,39,40],"h3",{"id":40},"上下布局",[14,42,43],{},"上方使用空面板，从左到右组件分别为“应用程序启动器”，“窗口列表”、“全局菜单”、“面板间隙”、“数字时钟”、“面板间隙”、“系统托盘”。",[14,45,46],{},"下方放置应用程序菜单栏，使用“图标任务管理器”实现类似 Dock 栏的效果。",[38,48,50],{"id":49},"panel-colorizer","Panel-colorizer",[14,52,53],{},"在 2025 年 10 月系统升级 Fedora 43 后发现了 Panel-colorizer 这个插件，可以对 KDE 面板进行颜色和透明度的更多自定义设置。",[14,55,56],{},"桌面的上下面板均使用了本插件，设置了不同的透明度和颜色。",[14,58,59,60],{},"Github 地址：",[61,62,63],"a",{"href":63,"rel":64},"https:\u002F\u002Fgithub.com\u002Fluisbocanegra\u002Fplasma-panel-colorizer",[65],"nofollow",[14,67,68,69],{},"KDE 商店链接：",[61,70,71],{"href":71,"rel":72},"https:\u002F\u002Fstore.kde.org\u002Fp\u002F2130967",[65],[14,74,75],{},"若是从 KDE 商店安装本插件，需要先检查系统是否已安装相关依赖包，可在项目 Github README 中查看不同系统需求的依赖包安装方式。",[14,77,78],{},"在面板激活本插件十分简单，安装后添加在需要使用的面板添加 Panel Colorizer 挂件，然后进入挂件配置即可对目前附加的面板进行修改。",[14,80,81],{},"这里只是提供了个人的一种选择思路，你可以根据插件设置自定义属于自己的更强大的主题配色方案。",[83,84,85],"h4",{"id":85},"上面板",[14,87,88],{},"配置透明效果的步骤其实很简单。",[14,90,91],{},"首先使用插件内置的 ChromeOS 预设，然后打开外观设置，翻到侧边外观选项卡，下翻找到“Color”然后禁用它的颜色即可（如下图）。",[30,93],{"caption":94,"src":95},"Panel-colorizer 上面板配置","https:\u002F\u002Fblog-files.101045700.xyz\u002F2025\u002F08\u002Fkde-customization\u002Fconfig.webp",[83,97,98],{"id":98},"下面板",[14,100,101],{},"下面板的配置就更简单了，直接使用插件内置的 Translucent 预设即可。",[38,103,104],{"id":104},"主题方案",[14,106,107],{},"前往 系统设置 > 全局主题 设置",[109,110,111,124],"table",{},[112,113,114],"thead",{},[115,116,117,121],"tr",{},[118,119,120],"th",{},"类型",[118,122,123],{},"名称",[125,126,127,136,144,152,159,166,174,182],"tbody",{},[115,128,129,133],{},[130,131,132],"td",{},"全局主题",[130,134,135],{},"Fedora",[115,137,138,141],{},[130,139,140],{},"颜色",[130,142,143],{},"Moe",[115,145,146,149],{},[130,147,148],{},"应用程序外观样式",[130,150,151],{},"Breeze 微风",[115,153,154,157],{},[130,155,156],{},"Plasma 外观样式",[130,158,143],{},[115,160,161,164],{},[130,162,163],{},"窗口装饰元素",[130,165,151],{},[115,167,168,171],{},[130,169,170],{},"图标",[130,172,173],{},"Colloid",[115,175,176,179],{},[130,177,178],{},"光标",[130,180,181],{},"Hoshino Swimsuit",[115,183,184,187],{},[130,185,186],{},"欢迎屏幕",[130,188,189],{},"Lagtrain",[38,191,192],{"id":192},"桌面时钟",[14,194,195],{},"使用 Redmi Clock 插件",[14,197,198,199],{},"插件 KDE 商店链接：",[61,200,201],{"href":201,"rel":202},"https:\u002F\u002Fstore.kde.org\u002Fp\u002F2175475",[65],{"title":204,"searchDepth":205,"depth":205,"links":206},"",4,[207,209],{"id":12,"depth":208,"text":12},2,{"id":36,"depth":208,"text":36,"children":210},[211,213,217,218],{"id":40,"depth":212,"text":40},3,{"id":49,"depth":212,"text":50,"children":214},[215,216],{"id":85,"depth":205,"text":85},{"id":98,"depth":205,"text":98},{"id":104,"depth":212,"text":104},{"id":192,"depth":212,"text":192},[220],"技术探索","2025-08-28 05:30:00","本文分享了作者将主力系统换至Fedora 43 KDE后的桌面美化方案：采用上下双面板布局，上方空面板配应用启动器、全局菜单等，下方图标任务管理器作Dock；引入Panel-colorizer插件，为上下面板分别设置ChromeOS透明与Translucent预设；主题选Fedora全局主题+Moe配色+Colloid图标，时钟用Redmi Clock插件，全套均可在KDE商店获取。",false,"md",{"slots":226},{},true,"\u002F2025\u002F08\u002Fkde-customization",null,{"text":231,"minutes":232,"time":233,"words":234},"4 min read",3.27,196200,654,10,{"title":5,"description":222},{"loc":228},"posts\u002F2025\u002F08\u002Fkde-customization","其实并不是很难的吧😆",[241,242],"KDE","Linux","tech","2025-11-04T18:30:00","sTZgLr_VgnJR2LykJMBS1ilGW2rKg03ckWWCLzrk26k",[247,252],{"title":248,"path":249,"stem":250,"date":251,"type":243,"children":-1},"《痴情哥哥与病弱妹妹的乡间生活》 Steam 版在 Linux\u002FDeck 下的运行问题修复","\u002F2025\u002F06\u002Fsickly-days-linux-run","posts\u002F2025\u002F06\u002Fsickly-days-linux-run","2025-06-22 05:30:00",{"title":253,"path":254,"stem":255,"date":256,"type":243,"children":-1},"为 Clarity 主题增加 ResourceList 资源列表组件","\u002F2025\u002F10\u002Fclarity-resource-list","posts\u002F2025\u002F10\u002Fclarity-resource-list","2025-10-20 22:00:00",1775025020196]